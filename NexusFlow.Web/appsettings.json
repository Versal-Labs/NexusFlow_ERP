{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Hangfire": {
    "WorkerCount": 5,
    "DashboardPath": "/hangfire",
    "Queues": [ "critical", "default", "low" ],
    "RetryAttempts": 3
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "%PROGRAMDATA%/NexusFlow/ERP/logs/nexusflow-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },

  "JwtSettings": {
    "Issuer": "NexusFlowServer",
    "Audience": "NexusFlowMobileApp",
    "ExpiryMinutes": 60
  }
}
