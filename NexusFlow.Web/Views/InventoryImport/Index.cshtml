@{
    ViewData["Title"] = "Import Legacy Inventory";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Import Legacy Inventory</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-question-circle"></i> Help
        </button>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12 col-lg-8 offset-lg-2">
        <div class="card shadow-sm mt-4">
            <div class="card-body text-center p-5">
                
                <div id="dropzone" class="border border-2 border-dashed rounded p-5 bg-light transition-all" style="cursor: pointer;">
                    <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-3"></i>
                    <h5>Drag and drop your Legacy Inventory CSV here</h5>
                    <p class="text-muted mb-0">or click to browse files</p>
                    <small class="text-danger mt-2 d-block">Note: Only .csv files are supported. If using Excel, save as CSV first.</small>
                    <input type="file" id="fileInput" class="d-none" accept=".csv">
                </div>
                
                <div id="processingState" style="display:none;" class="py-4">
                    <div class="spinner-border text-primary mb-3" role="status" style="width: 4rem; height: 4rem;"></div>
                    <h4>Importing Legacy Data...</h4>
                    <p class="text-muted">This may take a few moments depending on the file size. Please do not close or refresh this window.</p>
                    <div class="progress mt-4" style="height: 10px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated w-100" role="progressbar"></div>
                    </div>
                </div>

                <div id="successState" style="display:none;" class="py-4">
                    <i class="fas fa-check-circle fa-5x text-success mb-3"></i>
                    <h4 class="text-success">Import Successful!</h4>
                    <p class="fs-5 mt-3 text-secondary">Your inventory has been updated.</p>
                    
                    <div class="mt-4">
                        <a href="/" class="btn btn-primary px-4 me-2">Return to Dashboard</a>
                        <button class="btn btn-outline-secondary px-4" onclick="location.reload()">Import Another File</button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/inventory-import.js" asp-append-version="true"></script>
}