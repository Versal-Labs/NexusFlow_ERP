@{
    ViewData["Title"] = "Chart of Accounts";
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0">Chart of Accounts</h4>
            <small class="text-muted">Hierarchical general ledger configuration (Base Currency: LKR).</small>
        </div>
        <button class="btn btn-primary btn-sm shadow-sm" onclick="coaApp.openDrawer()">
            <i class="bi bi-plus-lg"></i> Add Root Account
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle fs-13 mb-0" id="coaTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40%;">Account Name</th>
                            <th>Code</th>
                            <th>Type</th>
                            <th class="text-center">Status</th>
                            <th class="text-end">Balance (LKR)</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="coaTbody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="accountDrawer">
    <div class="offcanvas-header bg-light border-bottom">
        <h5 class="offcanvas-title fs-6" id="drawerTitle">New Account</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <form id="accountForm">
            <input type="hidden" id="AccountId" value="0" />
            <input type="hidden" id="ParentAccountId" />

            <div class="mb-3">
                <label class="form-label fw-semibold">Parent Account</label>
                <input type="text" class="form-control form-control-sm bg-light" id="ParentAccountName" readonly placeholder="Root (None)">
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">GL Code <span class="text-danger">*</span></label>
                <input type="text" class="form-control form-control-sm font-monospace" id="Code" required autocomplete="off">
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Account Name <span class="text-danger">*</span></label>
                <input type="text" class="form-control form-control-sm" id="Name" required autocomplete="off">
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Account Type <span class="text-danger">*</span></label>
                <select class="form-select form-select-sm" id="Type" required>
                    <option value="1">Asset</option>
                    <option value="2">Liability</option>
                    <option value="3">Equity</option>
                    <option value="4">Revenue</option>
                    <option value="5">Expense</option>
                </select>
                <small class="text-muted" id="TypeHelpText">Must match parent account type.</small>
            </div>

            <div class="mb-3">
                <div class="form-check form-switch p-2 border rounded bg-light">
                    <input class="form-check-input ms-0 me-2" type="checkbox" id="IsTransactionAccount" checked>
                    <label class="form-check-label fw-medium">Transaction Account</label>
                </div>
            </div>

            <div class="mb-3">
                <div class="form-check form-switch p-2 border rounded bg-light">
                    <input class="form-check-input ms-0 me-2" type="checkbox" id="RequiresReconciliation">
                    <label class="form-check-label fw-medium">Requires Bank Reconciliation</label>
                </div>
            </div>
        </form>
    </div>
    <div class="offcanvas-footer p-3 border-top bg-light text-end">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="offcanvas">Cancel</button>
        <button type="button" class="btn btn-primary btn-sm" onclick="coaApp.saveAccount()">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/chart-of-accounts.js" asp-append-version="true"></script>
}