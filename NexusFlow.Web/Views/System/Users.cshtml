@{
    ViewData["Title"] = "Identity & Access Management";
}

<div class="container-fluid py-3 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-users-gear text-primary me-2"></i>Identity & Access</h4>
            <p class="text-muted mb-0 fs-14">Manage users, define roles, and strictly control ERP access.</p>
        </div>
        <div>
            <button class="btn btn-outline-dark shadow-sm btn-sm px-3 fw-bold me-2" onclick="iamApp.openRoleModal()">
                <i class="fa-solid fa-shield-halved me-1"></i> New Role
            </button>
            <button class="btn btn-primary shadow-sm btn-sm px-3 fw-bold" onclick="iamApp.openUserModal()">
                <i class="fa-solid fa-user-plus me-1"></i> New User
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white pt-3 pb-0 border-bottom-0">
            <ul class="nav nav-tabs border-bottom" id="iamTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold text-dark" id="users-tab" data-bs-toggle="tab" data-bs-target="#users-pane" type="button" role="tab">
                        <i class="fa-solid fa-users me-1"></i> System Users
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold text-secondary" id="roles-tab" data-bs-toggle="tab" data-bs-target="#roles-pane" type="button" role="tab">
                        <i class="fa-solid fa-user-lock me-1"></i> Security Roles
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body p-3">
            <div class="tab-content" id="iamTabsContent">
                
                <div class="tab-pane fade show active" id="users-pane" role="tabpanel" tabindex="0">
                    <table id="usersGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                        <thead class="table-light text-secondary">
                            <tr>
                                <th class="ps-3">Full Name</th>
                                <th>Email Address</th>
                                <th>Assigned Role</th>
                                <th class="text-center">Status</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                    </table>
                </div>

                <div class="tab-pane fade" id="roles-pane" role="tabpanel" tabindex="0">
                    <table id="rolesGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                        <thead class="table-light text-secondary">
                            <tr>
                                <th class="ps-3">Role Name</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="userModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fw-bold fs-6" id="userModalTitle"><i class="fa-solid fa-user-shield me-2"></i>Provision User</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 fs-13 bg-light">
                <form id="userForm">
                    <input type="hidden" id="UserId" /> <div class="row g-3">
                        
                    <div class="col-md-12">
                        <label class="form-label fw-bold mb-1">Full Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm" id="FullName" required>
                    </div>
                        
                    <div class="col-md-12">
                        <label class="form-label fw-bold mb-1">Email Address (Login ID) <span class="text-danger">*</span></label>
                        <input type="email" class="form-control form-control-sm" id="Email" required>
                    </div>
                    <div class="col-md-6" id="divPassword">
                        <label class="form-label fw-bold mb-1">Temporary Password <span class="text-danger">*</span></label>
                        <input type="password" class="form-control form-control-sm" id="Password" pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold mb-1">System Role <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm" id="Role" required></select>
                    </div>
                </div>
            </form>
        </div>
        <div class="modal-footer bg-white border-top py-2 d-flex justify-content-between">
            <div>
                <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm px-4 fw-bold shadow-sm" onclick="iamApp.saveUser(event)">
                    <i class="fa-solid fa-check me-2"></i> Save User
                </button>
            </div>
        </div>
    </div>
</div>
</div>

<div class="modal fade" id="roleModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-secondary text-white py-2">
                <h5 class="modal-title fw-bold fs-6" id="roleModalTitle"><i class="fa-solid fa-shield-halved me-2"></i>Security Role</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 fs-13 bg-light">
                <form id="roleForm">
                    <input type="hidden" id="RoleId" /> <div class="mb-3">
                    <label class="form-label fw-bold mb-1">Role Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control form-control-sm" id="RoleName" required>
                    <small class="text-muted d-block mt-1">Spaces will be automatically removed.</small>
                </div>
            </form>
        </div>
        <div class="modal-footer bg-white border-top py-2">
            <button type="button" class="btn btn-light btn-sm px-3 border" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-dark btn-sm px-4 fw-bold shadow-sm" onclick="iamApp.saveRole(event)">
                <i class="fa-solid fa-check me-2"></i> Save
            </button>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/system/iam-users.js" asp-append-version="true"></script>
}