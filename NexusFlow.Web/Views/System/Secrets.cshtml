@{
    ViewData["Title"] = "Secret Vault";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <div>
        <h1 class="h2">Secret Vault</h1>
        <p class="text-muted small mb-0">SuperAdmin-only runtime keys for database, Azure Blob Storage, Syncfusion, and JWT security.</p>
    </div>
    <button type="button" class="btn btn-outline-danger d-none" id="btnRestartApp">
        <i class="fa-solid fa-rotate me-1"></i> Restart Application
    </button>
</div>

<div class="alert alert-warning border-warning-subtle shadow-sm" role="alert">
    <div class="fw-semibold mb-1"><i class="fa-solid fa-triangle-exclamation me-1"></i> Production safety notice</div>
    <div class="small">
        Secret values are never displayed after saving. Rotate any Azure Storage key or other credential that has been pasted into chat, logs, tickets, or screenshots before storing it here.
    </div>
</div>

<div class="row g-3 mb-3" id="secretRuntimeSummary">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-muted text-uppercase fw-semibold">Instance</div>
                <div class="fw-semibold" data-summary="instanceId">Loading...</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-muted text-uppercase fw-semibold">Profile</div>
                <div class="fw-semibold" data-summary="deploymentProfile">Loading...</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-muted text-uppercase fw-semibold">Storage Mode</div>
                <div class="fw-semibold" data-summary="storageMode">Loading...</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-muted text-uppercase fw-semibold">Blob Container</div>
                <div class="fw-semibold text-break" data-summary="azureBlobContainer">Loading...</div>
            </div>
        </div>
    </div>
</div>

<div id="restartBanner" class="alert alert-danger d-none shadow-sm" role="alert"></div>

<div id="secretCards" class="row g-3">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-muted">Loading secret status...</div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/system/secret-vault.js" asp-append-version="true"></script>
}
