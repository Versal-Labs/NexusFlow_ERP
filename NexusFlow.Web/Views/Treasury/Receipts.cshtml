@{
    ViewData["Title"] = "Customer Receipts";
}

@section Styles {
    <style>
        .dataTables_filter { text-align: left !important; }
        .dataTables_filter label { width: 100%; display: flex; align-items: center; }
        .dataTables_filter input { margin-left: 10px; width: auto; flex-grow: 1; max-width: 300px; }
        .receipt-amount-box { background-color: #f8f9fa; border-radius: 8px; padding: 15px; border: 1px solid #e9ecef; }
    </style>
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-hand-holding-dollar text-success me-2"></i>Customer Receipts</h4>
            <p class="text-muted mb-0 fs-14">Record payments, auto-allocate to invoices, and manage post-dated cheques.</p>
        </div>
        <button class="btn btn-primary btn-sm shadow-sm px-3 fw-bold" onclick="receiptApp.openModal()">
            <i class="fa-solid fa-plus me-1"></i> Receive Payment
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-white">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-center fs-13">
                <div class="col-md-3">
                    <label class="form-label mb-0 fw-bold text-muted">Customer</label>
                    <select class="form-select form-select-sm" id="filterCustomer"></select>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-0 fw-bold text-muted">Payment Method</label>
                    <select class="form-select form-select-sm" id="filterMethod">
                        <option value="">All Methods</option>
                        <option value="1">Cash</option>
                        <option value="2">Bank Transfer</option>
                        <option value="3">Cheque (PDC)</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label mb-0 fw-bold text-muted">Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control" id="filterStartDate">
                        <span class="input-group-text">to</span>
                        <input type="date" class="form-control" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-3 text-end mt-4">
                    <button class="btn btn-sm btn-outline-secondary me-1" onclick="receiptApp.resetFilters()"><i class="fa-solid fa-eraser"></i> Clear</button>
                    <button class="btn btn-sm btn-primary px-3" onclick="receiptApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Apply</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="receiptsGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Receipt #</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Method</th>
                        <th class="text-end">Amount Received</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="receiptModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-success text-white py-2">
                <h5 class="modal-title fw-bold fs-6"><i class="fa-solid fa-cash-register me-2"></i>Record Payment</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-light fs-13">
                <form id="receiptForm">
                    <div class="row g-3 mb-3 bg-white p-3 rounded border shadow-sm">
                        <div class="col-md-7 border-end">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1">Customer <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm select2" id="CustomerId" required style="width: 100%;"></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Payment Method</label>
                                    <select class="form-select form-select-sm" id="Method" onchange="receiptApp.onMethodChange()">
                                        <option value="1">Cash</option>
                                        <option value="2">Bank Transfer</option>
                                        <option value="3">Cheque</option>
                                    </select>
                                </div>
                                <div class="col-md-6" id="divDepositTo">
                                    <label class="form-label fw-bold mb-1">Deposit To <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="AccountId" required></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Payment Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control form-control-sm" id="Date" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Remarks</label>
                                    <input type="text" class="form-control form-control-sm" id="Remarks" placeholder="Transfer Ref...">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="bg-light p-3 rounded h-100 border border-primary border-opacity-25">
                                <label class="form-label fw-bold text-primary mb-1">Actual Amount Received <span class="text-danger">*</span></label>
                                <div class="input-group input-group-lg mb-3 shadow-sm">
                                    <span class="input-group-text bg-white fw-bold text-muted">LKR</span>
                                    <input type="number" class="form-control fw-bold text-success font-monospace" id="ReceiptAmount" value="0.00" min="0.01" step="0.01" required onclick="this.select()">
                                    <button class="btn btn-primary fw-bold px-3" type="button" onclick="receiptApp.autoAllocate()" title="Auto-Apply to oldest invoices">
                                        <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Auto-Apply
                                    </button>
                                </div>
                                
                                <div id="chequeSection" class="d-none">
                                    <h6 class="fw-bold text-dark border-bottom pb-1"><i class="fa-solid fa-money-check-pen me-2"></i>Cheque Details</h6>
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <label class="form-label fw-bold mb-1 fs-12">Bank <span class="text-danger">*</span></label>
                                            <select class="form-select form-select-sm select2" id="BankId" style="width: 100%;" onchange="receiptApp.onBankChange()"></select>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label fw-bold mb-1 fs-12">Branch <span class="text-danger">*</span></label>
                                            <select class="form-select form-select-sm select2" id="BankBranchId" style="width: 100%;" disabled></select>
                                        </div>
                                        
                                        <div class="col-6 mt-2">
                                            <label class="form-label fw-bold mb-1 fs-12">Cheque No. <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control form-control-sm font-monospace" id="ChequeNumber">
                                        </div>
                                        <div class="col-6 mt-2">
                                            <label class="form-label fw-bold mb-1 fs-12">PDC Date <span class="text-danger">*</span></label>
                                            <input type="date" class="form-control form-control-sm" id="ChequeDate">
                                        </div>
                                        <div class="col-12 mt-2">
                                            <div class="alert alert-warning py-1 px-2 fs-12 mb-0"><i class="fa-solid fa-vault me-1"></i> Cheque will be placed in Undeposited Funds.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <h6 class="fw-bold text-primary mb-0"><i class="fa-solid fa-file-invoice me-2"></i>Invoice Allocation</h6>
                        <div class="fs-12 text-muted fw-bold">
                            Allocated: <span id="lblAllocated" class="text-dark font-monospace me-3">0.00</span>
                            Unallocated Credit: <span id="lblUnallocated" class="text-success font-monospace">0.00</span>
                        </div>
                    </div>
                    
                    <div class="table-responsive border rounded bg-white" style="max-height: 300px; overflow-y: auto;">
                        <table class="table table-sm table-hover align-middle mb-0" id="allocationTable">
                            <thead class="table-light sticky-top shadow-sm">
                                <tr>
                                    <th>Invoice #</th>
                                    <th>Date</th>
                                    <th>Due Date</th>
                                    <th class="text-end">Invoice Total</th>
                                    <th class="text-end">Open Balance</th>
                                    <th class="text-end" style="width: 150px;">Apply Amount</th>
                                </tr>
                            </thead>
                            <tbody id="allocationBody">
                                <tr><td colspan="6" class="text-center text-muted fst-italic py-3">Select a customer to view unpaid invoices.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-3 border-top">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success btn-sm px-4 shadow-sm fw-bold" onclick="receiptApp.save()">
                    <i class="fa-solid fa-check-double me-1"></i> Confirm Receipt
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewReceiptModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-light border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2 d-flex justify-content-between align-items-center">
                <h5 class="modal-title fw-bold mb-0"><i class="fa-solid fa-file-invoice-dollar me-2"></i>Receipt Details</h5>
                <div>
                    <button class="btn btn-sm btn-light text-dark me-1" id="btnModalPrint" title="Export PDF"><i class="fa-solid fa-print"></i></button>
                    <button type="button" class="btn-close btn-close-white ms-2" data-bs-dismiss="modal"></button>
                </div>
            </div>
            
            <div class="modal-body p-4 bg-white">
                <div class="row border-bottom pb-3 mb-4">
                    <div class="col-6">
                        <h2 class="fw-bold text-dark mb-0">RECEIPT</h2>
                        <h5 class="text-muted font-monospace" id="viewRefNo">RCPT-0000</h5>
                        <div class="mt-2 text-muted fs-13"><strong>Date:</strong> <span id="viewDate"></span></div>
                    </div>
                    <div class="col-6 text-end">
                        <h2 class="fw-bold text-success mb-0 font-monospace" id="viewAmount">$0.00</h2>
                        <div class="text-muted fs-13 text-uppercase fw-bold">Amount Received</div>
                        <div class="mt-2" id="viewMethodBadge"></div>
                    </div>
                </div>

                <div class="row mb-4 fs-13">
                    <div class="col-6">
                        <h6 class="fw-bold text-muted mb-1 text-uppercase">Received From:</h6>
                        <div class="fs-5 fw-bold text-dark" id="viewCustomer"></div>
                        <div class="mt-2"><strong>Remarks:</strong> <span id="viewRemarks" class="text-muted"></span></div>
                    </div>
                    <div class="col-6 text-end" id="viewChequeBox" style="display:none;">
                        <div class="bg-light border rounded p-2 text-start d-inline-block w-100">
                            <h6 class="fw-bold text-primary mb-1 fs-12 text-uppercase"><i class="fa-solid fa-money-check me-1"></i> Cheque Details</h6>
                            <div><strong>Bank:</strong> <span id="viewBank"></span></div>
                            <div><strong>Cheque No:</strong> <span id="viewChequeNo" class="font-monospace"></span></div>
                            <div><strong>PDC Date:</strong> <span id="viewChequeDate"></span></div>
                        </div>
                    </div>
                </div>

                <h6 class="fw-bold text-dark mb-2 border-bottom pb-2"><i class="fa-solid fa-link me-2"></i>Invoices Paid by this Receipt</h6>
                <table class="table table-sm table-bordered align-middle fs-13 mb-0">
                    <thead class="table-light text-secondary text-center">
                        <tr>
                            <th class="text-start">Invoice #</th>
                            <th>Invoice Date</th>
                            <th class="text-end">Invoice Total</th>
                            <th class="text-end text-success">Amount Applied</th>
                        </tr>
                    </thead>
                    <tbody id="viewAllocationsBody"></tbody>
                </table>
            </div>
            
            <div class="modal-footer bg-light border-top shadow-sm py-2 d-flex justify-content-between">
                <div>
                    <button type="button" class="btn btn-outline-danger btn-sm" id="btnModalVoid"><i class="fa-solid fa-ban me-1"></i> Void Receipt</button>
                </div>
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/treasury/receipts.js" asp-append-version="true"></script>
}