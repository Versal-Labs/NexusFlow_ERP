@{
    ViewData["Title"] = "Supplier Payments";
}

<div class="container-fluid py-3 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-money-bill-transfer text-danger me-2"></i>Supplier Payments</h4>
            <p class="text-muted mb-0 fs-14">Pay supplier bills via Cash, Bank Transfer, Own Cheque, or Endorsed Customer Cheque.</p>
        </div>
        <button class="btn btn-danger shadow-sm btn-sm px-3 fw-bold" onclick="window.paymentApp.openCreateModal()">
            <i class="fa-solid fa-plus me-1"></i> New Payment
        </button>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 border-bottom">
            <div class="row g-2">
                <div class="col-md-4">
                    <select class="form-select form-select-sm select2" id="filterPaySupplierId">
                        <option value="">All Suppliers</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm" id="filterMethod" onchange="paymentApp.reloadGrid()">
                        <option value="">All Methods</option>
                        <option value="1">Cash</option>
                        <option value="2">Transfer</option>
                        <option value="4">Own Cheque</option>
                        <option value="5">Endorsed Cheque</option>
                    </select>
                </div>
                <div class="col-md-5 text-end">
                    <button class="btn btn-sm btn-outline-secondary" onclick="paymentApp.resetFilters()"><i class="fa-solid fa-rotate-right me-1"></i>Reset</button>
                </div>
            </div>
        </div>

        <div class="card-body p-3">
            <table id="paymentsGrid" class="table table-hover table-sm align-middle mb-0 w-100 fs-13">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-3">Payment #</th>
                        <th>Date</th>
                        <th>Supplier</th>
                        <th>Method</th>
                        <th class="text-end">Amount Paid</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="paymentModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content bg-light border-0 shadow-lg">
            <div class="modal-header bg-danger text-white py-2">
                <h5 class="modal-title fw-bold fs-6"><i class="fa-solid fa-money-check-dollar me-2"></i>Record Outbound Payment</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-4 fs-13">
                <form id="paymentForm">
                    <div class="row g-3 mb-3 bg-white p-3 rounded border shadow-sm">
                        <div class="col-md-7 border-end">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1">Supplier / Subcontractor <span class="text-danger">*</span></label>
                                    <select class="form-select select2" id="supplierId" required style="width: 100%;"></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Payment Method</label>
                                    <select class="form-select form-select-sm" id="method" onchange="paymentApp.onMethodChange()">
                                        <option value="1">Cash</option>
                                        <option value="2">Bank Transfer</option>
                                        <option value="4">Issue Own Cheque</option>
                                        <option value="5" class="fw-bold text-primary">Endorse Customer Cheque (Swap)</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Payment Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control form-control-sm" id="paymentDate" required>
                                </div>
                                
                                <div class="col-md-12" id="divPayFrom">
                                    <label class="form-label fw-bold mb-1">Pay From (Bank/Cash) <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="accountId"></select>
                                </div>

                                <div class="col-md-12 d-none" id="divEndorseCheque">
                                    <label class="form-label fw-bold mb-1 text-primary"><i class="fa-solid fa-vault me-1"></i> Select Cheque from Safe <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm select2" id="endorseChequeId" style="width: 100%;" onchange="paymentApp.onEndorsedChequeSelect()"></select>
                                </div>

                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1">Reference / Notes</label>
                                    <input type="text" class="form-control form-control-sm" id="referenceNo" placeholder="Wire Transfer ID or internal note...">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="bg-light p-3 rounded h-100 border border-danger border-opacity-25">
                                <label class="form-label fw-bold text-danger mb-1">Total Amount to Pay <span class="text-danger">*</span></label>
                                <div class="input-group input-group-lg mb-2 shadow-sm">
                                    <span class="input-group-text bg-white fw-bold text-muted">LKR</span>
                                    <input type="number" class="form-control fw-bold text-danger font-monospace" id="amount" value="0.00" min="0.01" step="0.01" required onclick="this.select()">
                                    <button class="btn btn-danger fw-bold px-3" type="button" onclick="paymentApp.autoAllocate()" title="Auto-Apply to oldest bills">
                                        <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Auto-Apply
                                    </button>
                                </div>
                                <small class="text-muted d-block" id="amountHelpText">Enter the amount you are paying the supplier.</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <h6 class="fw-bold text-danger mb-0"><i class="fa-solid fa-file-invoice me-2"></i>Bill Allocation</h6>
                        <div class="fs-12 text-muted fw-bold">
                            Allocated: <span id="lblAllocated" class="text-dark font-monospace me-3">0.00</span>
                            Unallocated (AP Advance): <span id="lblUnallocated" class="text-success font-monospace">0.00</span>
                        </div>
                    </div>
                    
                    <div class="table-responsive border rounded bg-white" style="max-height: 250px; overflow-y: auto;">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead class="table-light sticky-top shadow-sm">
                                <tr>
                                    <th>Bill #</th>
                                    <th>Date</th>
                                    <th>Due Date</th>
                                    <th class="text-end">Bill Total</th>
                                    <th class="text-end">Open Balance</th>
                                    <th class="text-end" style="width: 150px;">Apply Amount</th>
                                </tr>
                            </thead>
                            <tbody id="allocationBody">
                                <tr><td colspan="6" class="text-center text-muted fst-italic py-3">Select a supplier to view unpaid bills.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light border-top py-2">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm px-4 fw-bold shadow-sm" id="btnSavePayment">
                    <i class="fa-solid fa-check me-2"></i> Post Payment
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewPaymentModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fw-bold fs-6"><i class="fa-solid fa-eye me-2"></i>Payment Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-light fs-13">
                
                <div class="row mb-4">
                    <div class="col-sm-6">
                        <h6 class="text-muted mb-1 text-uppercase fw-bold" style="font-size: 11px;">Payment Reference</h6>
                        <div class="fs-5 fw-bold text-danger font-monospace" id="viewRefNo">-</div>
                    </div>
                    <div class="col-sm-6 text-end">
                        <h6 class="text-muted mb-1 text-uppercase fw-bold" style="font-size: 11px;">Total Amount Paid</h6>
                        <div class="fs-4 fw-bold text-success font-monospace" id="viewAmount">-</div>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="bg-white p-3 rounded border shadow-sm h-100">
                            <table class="table table-sm table-borderless mb-0">
                                <tr><td class="text-muted fw-bold w-50">Date:</td><td class="fw-bold text-end" id="viewDate">-</td></tr>
                                <tr><td class="text-muted fw-bold">Supplier:</td><td class="fw-bold text-end" id="viewSupplier">-</td></tr>
                                <tr><td class="text-muted fw-bold">Method:</td><td class="fw-bold text-end" id="viewMethod">-</td></tr>
                            </table>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="bg-white p-3 rounded border shadow-sm h-100">
                            <table class="table table-sm table-borderless mb-0">
                                <tr><td class="text-muted fw-bold w-50">Source:</td><td class="fw-bold text-end" id="viewSource">-</td></tr>
                                <tr><td class="text-muted fw-bold">Remarks:</td><td class="text-end" id="viewRemarks">-</td></tr>
                            </table>
                        </div>
                    </div>
                </div>

                <h6 class="fw-bold text-dark border-bottom pb-2 mb-3"><i class="fa-solid fa-list-check me-2"></i>Bills Paid by this Transaction</h6>
                <div class="table-responsive border rounded bg-white">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Bill #</th>
                                <th>Bill Date</th>
                                <th class="text-end">Amount Applied</th>
                            </tr>
                        </thead>
                        <tbody id="viewAllocationsBody">
                        </tbody>
                    </table>
                </div>

            </div>
            <div class="modal-footer bg-white border-top py-2">
                <button type="button" class="btn btn-secondary btn-sm px-4 shadow-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/treasury/supplier-payments.js" asp-append-version="true"></script>
}