@{
    ViewData["Title"] = "Payroll Configuration Hub";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-cogs text-secondary me-2"></i>Payroll Configuration</h4>
            <p class="text-muted mb-0 fs-14">Manage global rules, employee assignments, and loan schedules.</p>
        </div>
    </div>

    <ul class="nav nav-tabs fw-bold mb-3" id="configTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-components" type="button">Global Components</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-assignments" type="button">Employee Assignments</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-loans" type="button">Loans & Advances</button>
        </li>
    </ul>

    <div class="tab-content" id="configTabsContent">

        <div class="tab-pane fade show active" id="tab-components">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-list-ul me-2"></i>Allowances & Deductions</h6>
                    <button class="btn btn-sm btn-primary shadow-sm" onclick="pcApp.openComponentModal()">
                        <i class="fa-solid fa-plus me-1"></i> New Component
                    </button>
                </div>
                <div class="card-body p-3">
                    <table id="componentsGrid" class="table table-hover table-sm w-100 fs-13 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Calculation</th>
                                <th class="text-end">Default Rate</th>
                                <th class="text-center">Taxable?</th>
                                <th class="text-center">EPF?</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-assignments">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-user-tag me-2"></i>Mapped Components</h6>
                    <button class="btn btn-sm btn-success shadow-sm" onclick="pcApp.openAssignmentModal()">
                        <i class="fa-solid fa-link me-1"></i> Assign Component
                    </button>
                </div>
                <div class="card-body p-3">
                    <table id="assignmentsGrid" class="table table-hover table-sm w-100 fs-13 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>Component Name</th>
                                <th class="text-end">Override Rate</th>
                                <th class="text-center">Status</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-loans">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-hand-holding-dollar me-2"></i>Active Loans</h6>
                    <button class="btn btn-sm btn-warning text-dark fw-bold shadow-sm" onclick="pcApp.openLoanModal()">
                        <i class="fa-solid fa-money-bill-transfer me-1"></i> Issue New Loan
                    </button>
                </div>
                <div class="card-body p-3">
                    <table id="loansGrid" class="table table-hover table-sm w-100 fs-13 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>Disbursed</th>
                                <th class="text-end">Principal</th>
                                <th class="text-center">Term</th>
                                <th class="text-end text-danger">Monthly EMI</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="loanModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-warning py-2">
                <h5 class="modal-title fw-bold text-dark fs-6"><i class="fa-solid fa-hand-holding-dollar me-2"></i>Issue Employee Loan</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-light fs-13">
                <form id="loanForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold mb-1">Employee <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm select2-emp" id="LoanEmployeeId" required></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold mb-1">Disbursement Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control form-control-sm" id="LoanDate" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-1">Principal (LKR) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control form-control-sm fw-bold text-primary" id="LoanPrincipal" required min="1">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-1">Annual Interest (%) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control form-control-sm" id="LoanInterest" value="0.00" step="0.1" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-1">Term (Months) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control form-control-sm" id="LoanTerm" required min="1">
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold mb-1">Start Deduction Month <span class="text-danger">*</span></label>
                            <input type="month" class="form-control form-control-sm" id="LoanStartMonth" required>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-white py-2">
                <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning btn-sm px-4 fw-bold shadow-sm" onclick="pcApp.saveLoan()">
                    <i class="fa-solid fa-check me-1"></i> Issue Loan & Generate Schedule
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/hr/payroll-config.js" asp-append-version="true"></script>
}