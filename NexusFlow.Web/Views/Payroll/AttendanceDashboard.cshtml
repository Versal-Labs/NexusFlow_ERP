@{
    ViewData["Title"] = "Time & Attendance Dashboard";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-user-clock text-primary me-2"></i>Time & Attendance</h4>
            <p class="text-muted mb-0 fs-14">Monitor daily punches, fix errors, and verify shift compliance.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm shadow-sm fw-bold" onclick="attApp.syncBiometrics()">
                <i class="fa-solid fa-rotate me-1"></i> Sync Machines
            </button>
            <button class="btn btn-primary btn-sm shadow-sm fw-bold" onclick="attApp.processDay()">
                <i class="fa-solid fa-gears me-1"></i> Process Data
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-white">
        <div class="card-body py-2 px-3">
            <div class="row align-items-center">
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted mb-1 fs-12">Select Date</label>
                    <input type="date" class="form-control form-control-sm fw-bold" id="filterDate" onchange="attApp.reloadGrid()">
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="attendanceGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary text-center">
                    <tr>
                        <th class="text-start ps-3">Employee</th>
                        <th>Shift Profile</th>
                        <th>First In</th>
                        <th>Last Out</th>
                        <th class="text-danger">Late (Min)</th>
                        <th class="text-success">OT (Min)</th>
                        <th>Status</th>
                        <th class="text-center pe-3">Action</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="overrideModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-warning py-2">
                <h5 class="modal-title fw-bold text-dark fs-6"><i class="fa-solid fa-pen-to-square me-2"></i>Override Attendance</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-light fs-13">
                <form id="overrideForm">
                    <input type="hidden" id="OverrideRecordId" />
                    
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label fw-bold mb-1">First In Time</label>
                            <input type="time" class="form-control form-control-sm" id="OverrideFirstIn">
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold mb-1">Last Out Time</label>
                            <input type="time" class="form-control form-control-sm" id="OverrideLastOut">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold mb-1">Status <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm" id="OverrideStatus" required>
                                <option value="1">Present</option>
                                <option value="2">Absent</option>
                                <option value="3">Half Day</option>
                                <option value="4">On Leave</option>
                                <option value="5">Rest Day</option>
                                <option value="6">Error (Missing Punch)</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold mb-1">Remarks (Audit Trail) <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-sm" id="OverrideRemarks" placeholder="E.g., Approved manual out-punch" required>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-white py-2">
                <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning btn-sm px-4 fw-bold shadow-sm" onclick="attApp.saveOverride()">
                    <i class="fa-solid fa-check me-1"></i> Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/hr/attendance-dashboard.js" asp-append-version="true"></script>
}