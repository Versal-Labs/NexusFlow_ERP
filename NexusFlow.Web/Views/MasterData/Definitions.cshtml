@{
    ViewData["Title"] = "Product Attributes";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <div>
        <h1 class="h2">Product Attributes</h1>
        <p class="text-muted small mb-0">Manage global product definitions and variants.</p>
    </div>
</div>

<ul class="nav nav-tabs mb-3" id="attributeTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="brands-tab" data-bs-toggle="tab" data-bs-target="#brands-pane" type="button" role="tab">
            <i class="bi bi-tag me-1"></i> Brands
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="categories-tab" data-bs-toggle="tab" data-bs-target="#categories-pane" type="button" role="tab">
            <i class="bi bi-diagram-3 me-1"></i> Categories
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="uom-tab" data-bs-toggle="tab" data-bs-target="#uom-pane" type="button" role="tab">
            <i class="bi bi-speedometer2 me-1"></i> Units of Measure
        </button>
    </li>
</ul>

<div class="tab-content" id="attributeTabsContent">

    <div class="tab-pane fade show active" id="brands-pane" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold">Brand Registry</h6>
                    <button class="btn btn-sm btn-primary" onclick="brandApp.openCreatePanel()">
                        <i class="bi bi-plus-lg me-1"></i> New Brand
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="tblBrands" class="table table-striped table-hover w-100 mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width: 10%">ID</th>
                                <th style="width: 30%">Brand Name</th>
                                <th style="width: 40%">Description</th>
                                <th class="text-end pe-4" style="width: 20%">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="categories-pane" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-diagram-3 me-2 text-primary"></i>Category & Posting Groups Registry</h6>
                    <button class="btn btn-sm btn-primary shadow-sm" onclick="categoryApp.openCreatePanel()">
                        <i class="bi bi-plus-lg me-1"></i> New Category
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="tblCategories" class="table table-striped table-hover w-100 mb-0">
                        <thead class="table-light text-secondary">
                            <tr>
                                <th class="ps-4">Code</th>
                                <th>Category Name</th>
                                <th>Parent</th>
                                <th>Revenue A/C</th>
                                <th>Inventory A/C</th>
                                <th>COGS A/C</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="uom-pane" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold">Unit Registry</h6>
                    <button class="btn btn-sm btn-primary" onclick="unitApp.openCreatePanel()">
                        <i class="bi bi-plus-lg me-1"></i> New Unit
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="tblUnits" class="table table-striped table-hover w-100 mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width: 10%">ID</th>
                                <th style="width: 40%">Unit Name</th>
                                <th style="width: 30%">Symbol</th>
                                <th class="text-end pe-4" style="width: 20%">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasBrand" aria-labelledby="offcanvasBrandLabel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title" id="offcanvasBrandLabel">Manage Brand</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <form id="frmBrand">
            <input type="hidden" id="hdnBrandId" value="0" />
            <div class="mb-3">
                <label class="form-label fw-semibold">Brand Name <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="txtName" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea class="form-control" id="txtDescription" rows="3"></textarea>
            </div>
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Save Brand</button>
            </div>
        </form>
    </div>
</div>

<div class="offcanvas offcanvas-end shadow-lg" tabindex="-1" id="offcanvasCategory" aria-labelledby="offcanvasCategoryLabel" style="width: 500px;">
    <div class="offcanvas-header bg-light border-bottom">
        <h5 class="offcanvas-title fw-bold" id="offcanvasCategoryLabel">
            <i class="bi bi-diagram-3 text-primary me-2"></i>Manage Category
        </h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-0 bg-white">
        <form id="frmCategory" class="needs-validation" novalidate>
            <input type="hidden" id="hdnCategoryId" value="0" />
            
            <div class="p-4">
                <h6 class="text-primary border-bottom pb-2 mb-3 fs-14 fw-bold">
                    <i class="bi bi-tag me-2"></i>1. Classification
                </h6>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold fs-13 mb-1">Code <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm text-uppercase font-monospace" id="txtCatCode" placeholder="MENS" required>
                        <div class="invalid-feedback">Required.</div>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-semibold fs-13 mb-1">Category Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm" id="txtCatName" placeholder="e.g. Men's Shirts" required>
                        <div class="invalid-feedback">Required.</div>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-semibold fs-13 mb-1">Parent Category</label>
                        <select class="form-select form-select-sm" id="ddlParentCategory"></select>
                    </div>
                </div>
            </div>

            <div class="p-4 bg-light border-top">
                <h6 class="text-primary border-bottom pb-2 mb-3 fs-14 fw-bold">
                    <i class="bi bi-bank me-2"></i>2. GL Posting Groups
                </h6>
                <div class="alert alert-primary py-2 fs-12 mb-3 shadow-sm border-0">
                    <i class="bi bi-info-circle-fill me-1"></i> Products inside this category will inherit these financial rules for Journal Entries.
                </div>
                
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-3">
                        <label class="form-label fw-semibold fs-13 mb-1 text-dark">Sales Revenue Account <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm" id="ddlSalesAccount" required></select>
                        <div class="invalid-feedback">A Revenue Account is mandatory for invoicing.</div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-3">
                        <label class="form-label fw-semibold fs-13 mb-1 text-dark">Inventory Asset Account</label>
                        <select class="form-select form-select-sm" id="ddlInventoryAccount"></select>
                        <small class="text-muted d-block mt-1" style="font-size: 11px;">Leave blank if this category is strictly for Non-Stock Services.</small>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-3">
                        <label class="form-label fw-semibold fs-13 mb-1 text-dark">Cost of Goods Sold (COGS)</label>
                        <select class="form-select form-select-sm" id="ddlCogsAccount"></select>
                    </div>
                </div>
            </div>

            <div class="p-3 bg-white border-top d-flex justify-content-end gap-2 sticky-bottom">
                <button type="button" class="btn btn-light border btn-sm px-4" data-bs-dismiss="offcanvas">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm px-4 shadow-sm">
                    <i class="bi bi-save me-2"></i>Save Configuration
                </button>
            </div>
        </form>
    </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasUnit" aria-labelledby="offcanvasUnitLabel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title" id="offcanvasUnitLabel">Manage Unit</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <form id="frmUnit">
            <input type="hidden" id="hdnUnitId" value="0" />
            <div class="mb-3">
                <label class="form-label fw-semibold">Unit Name <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="txtUnitName" placeholder="e.g. Kilogram" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Symbol <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="txtUnitSymbol" placeholder="e.g. kg" required>
            </div>
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Save Unit</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/master/brands.js" asp-append-version="true"></script>
    <script src="~/js/master/categories.js" asp-append-version="true"></script>
    <script src="~/js/master/units.js" asp-append-version="true"></script>
    <script src="~/js/master/definitions-orchestrator.js" asp-append-version="true"></script>
}