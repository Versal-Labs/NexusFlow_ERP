@{
    ViewData["Title"] = "Quotations & Sales Orders";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-file-contract text-primary me-2"></i>Quotations & Orders</h4>
            <p class="text-muted mb-0 fs-14">Draft presales quotes and submit formal orders for Back-Office fulfillment.</p>
        </div>
        <button class="btn btn-primary shadow-sm btn-lg px-4 rounded-pill" onclick="orderApp.openCreateModal()">
            <i class="fa-solid fa-plus me-2"></i>New Order / Quote
        </button>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <table id="ordersGrid" class="table table-hover table-striped align-middle mb-0 w-100 fs-13">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-4">Order #</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Sales Rep</th>
                        <th class="text-end">Total Amount</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="orderModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content bg-light">
            <div class="modal-header bg-white border-bottom shadow-sm py-2">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-tablet-screen-button text-primary me-2"></i>Digital Order Entry</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-3">
                <form id="orderForm" class="h-100">
                    <div class="row h-100 g-3">
                        
                        <div class="col-lg-7 d-flex flex-column">
                            <div class="card border-0 shadow-sm flex-grow-1">
                                <div class="card-header bg-white py-3">
                                    <h6 class="mb-0 fw-bold text-primary"><i class="fa-solid fa-magnifying-glass me-2"></i>Product Selection</h6>
                                </div>
                                <div class="card-body p-3">
                                    <div class="mb-3">
                                        <select class="form-select form-select-lg select2" id="ProductSearch" style="width: 100%;">
                                            <option value="">Search by SKU, Name, or Variant...</option>
                                        </select>
                                    </div>
                                    
                                    <div class="table-responsive border rounded" style="max-height: calc(100vh - 350px); overflow-y: auto;">
                                        <table class="table table-sm table-hover align-middle mb-0" id="cartTable">
                                            <thead class="table-light sticky-top">
                                                <tr>
                                                    <th>Item Description</th>
                                                    <th style="width: 15%" class="text-center">Qty</th>
                                                    <th style="width: 20%" class="text-end">Unit Price</th>
                                                    <th style="width: 20%" class="text-end">Line Disc.</th>
                                                    <th style="width: 20%" class="text-end">Total</th>
                                                    <th style="width: 5%"></th>
                                                </tr>
                                            </thead>
                                            <tbody id="cartBody">
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="text-muted mt-2 fs-12"><i class="fa-solid fa-circle-info text-primary me-1"></i> Stock levels and exact tax are computed during Back-Office conversion.</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-5 d-flex flex-column">
                            <div class="card border-0 shadow-sm flex-grow-1">
                                <div class="card-body p-4 d-flex flex-column">
                                    
                                    <h6 class="fw-bold text-primary border-bottom pb-2 mb-3"><i class="fa-solid fa-user-tie me-2"></i>Customer Details</h6>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold fs-13 mb-1">Select Customer <span class="text-danger">*</span></label>
                                        <select class="form-select select2" id="CustomerId" required style="width: 100%;"></select>
                                    </div>
                                    <div class="mb-3 row g-2">
                                        <div class="col-6">
                                            <label class="form-label fw-bold fs-13 mb-1">Order Date <span class="text-danger">*</span></label>
                                            <input type="date" class="form-control" id="OrderDate" required>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label fw-bold fs-13 mb-1">Sales Rep <span class="text-danger">*</span></label>
                                            <select class="form-select" id="SalesRepId" required></select>
                                        </div>
                                    </div>
                                    <div class="mb-4">
                                        <label class="form-label fw-bold fs-13 mb-1">Customer Notes / Requests</label>
                                        <textarea class="form-control" id="Notes" rows="2" placeholder="e.g., Deliver after 3 PM..."></textarea>
                                    </div>

                                    <div class="mt-auto bg-light p-3 rounded border">
                                        <div class="d-flex justify-content-between fs-4 text-dark mb-3">
                                            <span class="fw-bold">Estimated Total:</span>
                                            <span class="font-monospace fw-bold text-primary" id="lblGrandTotal">0.00</span>
                                        </div>
                                        
                                        <div class="d-grid gap-2">
                                            <button type="button" class="btn btn-warning btn-lg fw-bold text-dark shadow-sm" onclick="orderApp.save(true)">
                                                <i class="fa-solid fa-file-signature me-2"></i> Save as Quotation (Draft)
                                            </button>
                                            <button type="button" class="btn btn-success btn-lg fw-bold shadow-sm" onclick="orderApp.save(false)">
                                                <i class="fa-solid fa-paper-plane me-2"></i> Submit Order to Back-Office
                                            </button>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewerModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-light">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-file-lines me-2"></i>Document Viewer</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="bg-white p-4 m-3 shadow-sm border" style="min-height: 500px;">
                    <div class="d-flex justify-content-between align-items-start mb-4 border-bottom pb-3">
                        <div>
                            <h3 class="fw-bold text-dark mb-0">SALES ORDER</h3>
                            <h5 class="text-primary font-monospace" id="docOrderNo">SO-0000</h5>
                        </div>
                        <div class="text-end">
                            <span id="docStatusBadge" class="badge bg-secondary fs-6 mb-2">Status</span>
                            <div class="text-muted fs-13"><strong>Date:</strong> <span id="docDate"></span></div>
                            <div class="text-muted fs-13"><strong>Rep:</strong> <span id="docRep"></span></div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="fw-bold text-muted mb-1 fs-12 text-uppercase">Customer Information</h6>
                        <div class="fs-14 fw-bold text-dark" id="docCustomer"></div>
                        <div class="fs-13 text-muted mt-2"><strong>Notes:</strong> <span id="docNotes">-</span></div>
                    </div>

                    <table class="table table-sm table-bordered align-middle fs-13">
                        <thead class="table-light text-secondary text-center">
                            <tr>
                                <th class="text-start">Description</th>
                                <th>Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Disc.</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody id="docItemsBody"></tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="text-end fw-bold">GRAND TOTAL</td>
                                <td class="text-end fw-bold text-primary fs-6" id="docTotal">0.00</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sales/sales-orders.js" asp-append-version="true"></script>
}