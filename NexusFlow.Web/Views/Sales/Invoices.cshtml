@{
    ViewData["Title"] = "Sales Invoices";
}

@section Styles {
    <style>
        .dataTables_filter { text-align: left !important; }
        .dataTables_filter label { width: 100%; display: flex; align-items: center; }
        .dataTables_filter input { margin-left: 10px; width: auto; flex-grow: 1; max-width: 300px; }
        .invoice-totals-box { background-color: #f8f9fa; border-radius: 8px; padding: 15px; border: 1px solid #e9ecef; }
        
        /* Fix for squished select dropdowns inside input groups */
        .discount-type-select { width: 65px !important; flex-shrink: 0; padding-left: 5px; padding-right: 15px; text-align: center; }
        
        /* Fix Select2 container width inside tables */
        .select2-container { width: 100% !important; }
    </style>
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-file-invoice-dollar text-success me-2"></i>Sales Invoices</h4>
            <p class="text-muted mb-0 fs-14">Manage customer billings, recognize revenue, and process RMAs.</p>
        </div>
        <button class="btn btn-primary shadow-sm btn-sm px-3 fw-bold" onclick="window.invoiceApp.openCreateModal()">
            <i class="fa-solid fa-plus me-1"></i> Create Invoice
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-white">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-center fs-13">
                <div class="col-md-3">
                    <label class="form-label mb-0 fw-bold text-muted">Customer</label>
                    <select class="form-select form-select-sm" id="filterCustomer"></select>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-0 fw-bold text-muted">Status</label>
                    <select class="form-select form-select-sm" id="filterStatus">
                        <option value="">All Statuses</option>
                        <option value="Open">Open (Unpaid)</option>
                        <option value="Partial">Partially Paid</option>
                        <option value="Paid">Paid in Full</option>
                        <option value="Overdue">Overdue</option>
                        <option value="Voided">Voided</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label mb-0 fw-bold text-muted">Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control" id="filterStartDate">
                        <span class="input-group-text">to</span>
                        <input type="date" class="form-control" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-3 text-end mt-4">
                    <button class="btn btn-sm btn-outline-secondary me-1 fw-bold" onclick="window.invoiceApp.resetFilters()"><i class="fa-solid fa-eraser"></i> Clear</button>
                    <button class="btn btn-sm btn-primary px-3 fw-bold" onclick="window.invoiceApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Apply</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="invoiceGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Invoice #</th>
                        <th>Date</th>
                        <th>Due Date</th>
                        <th>Customer</th>
                        <th class="text-end">Grand Total</th>
                        <th class="text-end">Paid</th>           
                        <th class="text-end">Balance Due</th>    
                        <th class="text-center">Status</th>
                        <th class="text-center">Payment Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="invoiceModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fs-6 fw-bold"><i class="fa-solid fa-file-invoice text-success me-2"></i>New Sales Invoice</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body fs-13 p-4 bg-white">
                <form id="invoiceForm">
                    <div class="row g-3 mb-4 pb-4 border-bottom">
                        <div class="col-md-2">
                            <label class="form-label fw-bold mb-1">Invoice #</label>
                            <input type="text" class="form-control form-control-sm font-monospace text-primary fw-bold" value="[Auto-Generated]" readonly disabled>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold mb-1">Customer PO #</label>
                            <input type="text" class="form-control form-control-sm font-monospace fw-bold" id="CustomerPoNumber" placeholder="Optional">
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-bold mb-1">Customer <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm select2" id="CustomerId" required style="width: 100%;"></select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold mb-1">Sales Rep</label>
                            <select class="form-select form-select-sm" id="SalesRepId">
                                <option value="">-- Internal Sales --</option>
                            </select>
                        </div>
                        
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-1">Dispatch Warehouse <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm" id="WarehouseId" onchange="invoiceApp.onWarehouseChange()" required></select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-1">Invoice Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control form-control-sm calc-trigger" id="Date" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-1">Due Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control form-control-sm calc-trigger" id="DueDate" required>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="text-primary mb-0 fw-bold"><i class="fa-solid fa-list me-2"></i>Line Items</h6>
                        <button type="button" class="btn btn-sm btn-outline-dark bg-light border fw-bold shadow-sm" onclick="invoiceApp.addLine()">
                            <i class="fa-solid fa-plus text-success me-1"></i> Add Product
                        </button>
                    </div>

                    <div class="table-responsive mb-4 border rounded" style="overflow: visible;">
                        <table class="table table-sm table-bordered align-middle mb-0" id="linesTable">
                            <thead class="table-light text-center text-secondary">
                                <tr>
                                    <th style="width: 40%" class="text-start">Product / Service</th>
                                    <th style="width: 10%">Qty</th>
                                    <th style="width: 15%">Unit Price</th>
                                    <th style="width: 20%">Discount</th>
                                    <th style="width: 10%" class="text-end">Line Total</th>
                                    <th style="width: 5%"></th>
                                </tr>
                            </thead>
                            <tbody id="linesBody"></tbody>
                        </table>
                    </div>

                    <div class="row">
                        <div class="col-md-7">
                            <label class="form-label fw-bold mb-1">Internal Notes & Remarks</label>
                            <textarea class="form-control form-control-sm mb-3" id="Notes" rows="3" placeholder="Add specific terms, shipping notes, or customer references here..."></textarea>

                            <div class="form-check form-switch p-3 bg-light border rounded d-inline-block">
                                <input class="form-check-input ms-0 me-2 mt-1 calc-trigger" type="checkbox" id="ApplyVat" checked style="cursor:pointer">
                                <label class="form-check-label fw-bold" for="ApplyVat" style="cursor:pointer">Apply Standard VAT (18%)</label>
                                <div class="text-muted small ms-4">Disable for tax-exempt exports.</div>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="invoice-totals-box shadow-sm">
                                <div class="d-flex justify-content-between mb-2 align-items-center">
                                    <span class="fw-bold text-muted">Sub Total (Gross):</span>
                                    <span class="font-monospace fs-6" id="lblSubTotal">0.00</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 align-items-center">
                                    <span class="fw-bold text-muted">Global Discount:</span>
                                    <div class="input-group input-group-sm w-50">
                                        <input type="number" class="form-control text-end calc-trigger" id="GlobalDiscountVal" value="0" min="0" step="0.01" onclick="this.select()">
                                        <select class="form-select discount-type-select calc-trigger" id="GlobalDiscountType">
                                            <option value="$">$</option>
                                            <option value="%">%</option>
                                        </select>
                                    </div>
                                </div>
                                
                                <div class="d-flex justify-content-between mb-2 align-items-center text-success" id="discountRow" style="display: none;">
                                    <span class="fw-bold">Total Discount Saved:</span>
                                    <span class="font-monospace fw-bold" id="lblTotalDiscount">- 0.00</span>
                                </div>

                                <div class="d-flex justify-content-between mb-2 align-items-center" id="vatRow">
                                    <span class="fw-bold text-muted">VAT (18% Est):</span>
                                    <span class="font-monospace text-danger" id="lblTax">+ 0.00</span>
                                </div>
                                <hr class="my-2 border-secondary">
                                <div class="d-flex justify-content-between fs-5 text-dark mt-3">
                                    <span class="fw-bold">Grand Total:</span>
                                    <span class="font-monospace fw-bold text-primary" id="lblGrandTotal">0.00</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-3 border-top">
                <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
                <div class="ms-auto">
                    <button type="button" class="btn btn-warning btn-sm px-4 shadow-sm me-2 text-dark fw-bold" onclick="invoiceApp.saveInvoice(true)">
                        <i class="fa-solid fa-file-pen me-1"></i> Save as Draft
                    </button>
                    <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm fw-bold" onclick="invoiceApp.saveInvoice(false)">
                        <i class="fa-solid fa-check-double me-1"></i> Post Invoice
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="rmaModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white py-2">
                <h5 class="modal-title fs-6 fw-bold"><i class="fa-solid fa-arrow-rotate-left me-2"></i>Process Sales Return (RMA)</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body fs-13 p-4 bg-light">
                <form id="rmaForm">
                    <input type="hidden" id="RmaInvoiceId" value="0" />
                    
                    <div class="alert alert-warning border-warning shadow-sm pb-2 pt-3 px-3 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-bold mb-0 text-dark">Original Invoice: <span id="lblRmaInvoiceNo" class="font-monospace text-primary"></span></h6>
                        </div>
                        <p class="mb-0 fs-12 text-dark">Processing a return will permanently reverse Revenue, restore inventory, and execute commission clawbacks.</p>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold mb-1">Return To Warehouse <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm" id="RmaWarehouseId" required></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold mb-1">Reason for Return <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm" id="RmaReason" required>
                                <option value="">-- Select Reason --</option>
                                <option value="Defective / Damaged">Defective / Damaged</option>
                                <option value="Wrong Item Shipped">Wrong Item Shipped</option>
                                <option value="Customer Dissatisfied">Customer Dissatisfied</option>
                                <option value="Transit Damage">Transit Damage</option>
                            </select>
                        </div>
                    </div>

                    <h6 class="fw-bold text-dark mt-4 mb-2">Return Quantities</h6>
                    <div class="table-responsive border rounded bg-white shadow-sm">
                        <table class="table table-sm table-hover align-middle mb-0" id="rmaTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Item Description</th>
                                    <th class="text-center" style="width: 15%">Invoiced Qty</th>
                                    <th class="text-end" style="width: 20%">Unit Price</th>
                                    <th class="text-center" style="width: 20%">Return Qty</th>
                                </tr>
                            </thead>
                            <tbody id="rmaBody"></tbody>
                        </table>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-white py-2 border-top">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm px-4 shadow-sm fw-bold" onclick="invoiceApp.submitReturn()">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i> Execute RMA
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewerModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-light">
            <div class="modal-header bg-dark text-white py-2 d-flex justify-content-between align-items-center">
                <h5 class="modal-title fw-bold mb-0 fs-6"><i class="fa-solid fa-magnifying-glass-chart me-2"></i>Invoice Details</h5>
                <div>
                    <button class="btn btn-sm btn-light text-dark me-1 fw-bold" id="btnModalPrint" title="Export PDF"><i class="fa-solid fa-print me-1"></i> Print</button>
                    <button class="btn btn-sm btn-success me-1 fw-bold text-dark" id="btnModalReceive" title="Receive Payment"><i class="fa-solid fa-hand-holding-dollar me-1"></i> Receive Payment</button>
                    <button type="button" class="btn-close btn-close-white ms-2" data-bs-dismiss="modal"></button>
                </div>
            </div>
            
            <div class="modal-body p-0">
                <div class="bg-white p-5 m-3 shadow-sm border rounded" style="min-height: 600px; position: relative;">
                    <div id="voidStamp" class="d-none" style="position: absolute; top: 30%; left: 25%; font-size: 8rem; color: rgba(220, 53, 69, 0.15); font-weight: 900; transform: rotate(-30deg); border: 10px solid rgba(220, 53, 69, 0.15); padding: 10px; pointer-events: none;">VOIDED</div>
                    <div class="row border-bottom pb-4 mb-4">
                        <div class="col-6">
                            <h2 class="fw-bold text-dark mb-0">INVOICE</h2>
                            <h5 class="text-muted font-monospace" id="docInvoiceNo">INV-0000</h5>
                            <small class="text-muted fw-bold d-none" id="docPoWrapper">PO: <span id="docPoNo" class="text-dark"></span></small>
                        </div>
                        <div class="col-6 text-end">
                            <h3 class="fw-bold text-danger mb-0" id="docBalanceDueLarge">$0.00</h3>
                            <div class="text-muted fs-13 text-uppercase fw-bold">Balance Due</div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-6">
                            <h6 class="fw-bold text-muted mb-1 fs-12 text-uppercase">Bill To:</h6>
                            <div class="fs-15 fw-bold text-dark" id="docCustomer"></div>
                        </div>
                        <div class="col-6 text-end fs-13">
                            <div><strong>Invoice Date:</strong> <span id="docDate"></span></div>
                            <div><strong>Due Date:</strong> <span id="docDueDate" class="fw-bold text-danger"></span></div>
                        </div>
                    </div>
                    <table class="table table-sm table-bordered align-middle fs-13 mb-4">
                        <thead class="table-light text-secondary text-center">
                            <tr>
                                <th class="text-start">Description</th>
                                <th style="width: 10%">Qty</th>
                                <th class="text-end" style="width: 15%">Rate</th>
                                <th class="text-end" style="width: 15%">Discount</th> 
                                <th class="text-end" style="width: 15%">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="docItemsBody"></tbody>
                    </table>
                    
                    <div class="row">
                        <div class="col-7">
                            <h6 class="fw-bold text-muted mb-1 fs-12 text-uppercase">Notes & Remarks</h6>
                            <div class="text-dark fs-13 bg-light p-2 rounded border" style="min-height: 60px;" id="docNotes">-</div>
                        </div>
                        <div class="col-5">
                            <table class="table table-sm table-borderless text-end fs-14 mb-0">
                                <tr><td class="text-muted">Subtotal (Gross)</td><td class="fw-bold" id="docSubtotal">0.00</td></tr>
                                
                                <tr id="docDiscountRow" style="display:none;">
                                    <td class="text-success">Total Discount</td>
                                    <td class="fw-bold text-success" id="docTotalDiscount">-0.00</td>
                                </tr>
                                
                                <tr><td class="text-muted border-bottom">Tax</td><td class="fw-bold border-bottom" id="docTax">0.00</td></tr>
                                <tr><td class="text-dark fw-bold fs-5">Total</td><td class="text-dark fw-bold fs-5" id="docTotal">0.00</td></tr>
                                <tr><td class="text-success pb-3 border-bottom">Amount Paid</td><td class="text-success pb-3 border-bottom" id="docPaid">-0.00</td></tr>
                                <tr><td class="text-danger fw-bold fs-5">Balance Due</td><td class="text-danger fw-bold fs-5" id="docBalanceDue">0.00</td></tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="modal-footer bg-light border-top shadow-sm py-2 d-flex justify-content-between">
                <div>
                    <button type="button" class="btn btn-outline-dark btn-sm me-1 fw-bold" id="btnModalDuplicate"><i class="fa-solid fa-copy me-1"></i> Duplicate</button>
                    <button type="button" class="btn btn-outline-danger btn-sm fw-bold" id="btnModalVoid"><i class="fa-solid fa-ban me-1"></i> Void Document</button>
                </div>
                <button type="button" class="btn btn-secondary btn-sm px-4 fw-bold" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sales-invoice.js" asp-append-version="true"></script>
}