@{
    ViewData["Title"] = "Sales Invoices";
}

@section Styles {
    <style>
        .dataTables_filter {
            text-align: left !important;
        }

            .dataTables_filter label {
                width: 100%;
                display: flex;
                align-items: center;
            }

            .dataTables_filter input {
                margin-left: 10px;
                width: auto;
                flex-grow: 1;
                max-width: 300px;
            }

        .invoice-totals-box {
            background-color: #f8f9fa;
            border-radius: 8px;
            padding: 15px;
            border: 1px solid #e9ecef;
        }
    </style>
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0">Sales Invoices</h4>
            <small class="text-muted">Manage customer billings and recognize revenue.</small>
        </div>
        <button class="btn btn-primary btn-sm shadow-sm" onclick="invoiceApp.openCreateModal()">
            <i class="fa-solid fa-file-invoice me-1"></i> Create Invoice
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="invoiceGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Invoice #</th>
                        <th>Date</th>
                        <th>Due Date</th>
                        <th>Customer</th>
                        <th class="text-end">Grand Total</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="invoiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light">
                <h5 class="modal-title fs-6"><i class="fa-solid fa-file-invoice text-primary me-2"></i>New Sales Invoice</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body fs-13 p-4 bg-white">
                <form id="invoiceForm">
                    <div class="row g-3 mb-4 pb-4 border-bottom">
                        <div class="col-md-2">
                            <label class="form-label fw-bold mb-1">Invoice #</label>
                            <input type="text" class="form-control form-control-sm font-monospace text-primary fw-bold" value="[Auto-Generated]" readonly disabled>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-1">Customer <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm select2" id="CustomerId" required style="width: 100%;"></select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold mb-1">Sales Rep</label>
                            <select class="form-select form-select-sm" id="SalesRepId">
                                <option value="">-- Internal Sales --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold mb-1">Dispatch Warehouse <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm" id="WarehouseId" required></select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold mb-1">Invoice Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control form-control-sm" id="Date" required>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold mb-1">Due Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control form-control-sm" id="DueDate" required>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="text-primary mb-0"><i class="fa-solid fa-list me-2"></i>Line Items</h6>
                        <button type="button" class="btn btn-sm btn-light border" onclick="invoiceApp.addLine()">
                            <i class="fa-solid fa-plus text-success"></i> Add Item
                        </button>
                    </div>

                    <div class="table-responsive mb-4 border rounded">
                        <table class="table table-sm table-bordered align-middle mb-0" id="linesTable">
                            <thead class="table-light text-center">
                                <tr>
                                    <th style="width: 35%" class="text-start">Product / Service</th>
                                    <th style="width: 10%">Qty</th>
                                    <th style="width: 15%">Unit Price</th>
                                    <th style="width: 20%">Discount</th>
                                    <th style="width: 15%" class="text-end">Line Total</th>
                                    <th style="width: 5%"></th>
                                </tr>
                            </thead>
                            <tbody id="linesBody"></tbody>
                        </table>
                    </div>

                    <div class="row">
                        <div class="col-md-7">
                            <label class="form-label fw-bold mb-1">Internal Notes & Remarks</label>
                            <textarea class="form-control form-control-sm mb-3" id="Notes" rows="3" placeholder="Add specific terms, shipping notes, or customer references here..."></textarea>

                            <div class="form-check form-switch p-3 bg-light border rounded d-inline-block">
                                <input class="form-check-input ms-0 me-2 mt-1 calc-trigger" type="checkbox" id="ApplyVat" checked style="cursor:pointer">
                                <label class="form-check-label fw-bold" for="ApplyVat" style="cursor:pointer">Apply Standard VAT (18%)</label>
                                <div class="text-muted small ms-4">Disable for tax-exempt exports.</div>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="invoice-totals-box shadow-sm">
                                <div class="d-flex justify-content-between mb-2 align-items-center">
                                    <span class="fw-bold text-muted">Sub Total:</span>
                                    <span class="font-monospace fs-6" id="lblSubTotal">0.00</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 align-items-center">
                                    <span class="fw-bold text-muted">Global Discount:</span>
                                    <div class="input-group input-group-sm w-50">
                                        <input type="number" class="form-control text-end calc-trigger" id="GlobalDiscountVal" value="0" min="0" step="0.01">
                                        <select class="form-select text-center calc-trigger" id="GlobalDiscountType" style="max-width: 60px;">
                                            <option value="$">$</option>
                                            <option value="%">%</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between mb-2 align-items-center" id="vatRow">
                                    <span class="fw-bold text-muted">VAT (18% Est):</span>
                                    <span class="font-monospace text-danger" id="lblTax">+ 0.00</span>
                                </div>
                                <hr class="my-2">
                                <div class="d-flex justify-content-between fs-5 text-dark mt-3">
                                    <span class="fw-bold">Grand Total:</span>
                                    <span class="font-monospace fw-bold text-primary" id="lblGrandTotal">0.00</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-3 border-top">
                <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
                <div class="ms-auto">
                    <button type="button" class="btn btn-warning btn-sm px-4 shadow-sm me-2 text-dark fw-bold" onclick="invoiceApp.saveInvoice(true)">
                        <i class="fa-solid fa-file-pen me-1"></i> Save as Draft
                    </button>
                    <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm" onclick="invoiceApp.saveInvoice(false)">
                        <i class="fa-solid fa-check-double me-1"></i> Post Invoice
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sales-invoice.js" asp-append-version="true"></script>
}