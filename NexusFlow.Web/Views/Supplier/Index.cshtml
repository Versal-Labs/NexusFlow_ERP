@{
    ViewData["Title"] = "Supplier Master";
}

@section Styles {
    <style>
        .dataTables_filter { text-align: left !important; }
        .dataTables_filter label { width: 100%; display: flex; align-items: center; }
        .dataTables_filter input { margin-left: 10px; width: auto; flex-grow: 1; max-width: 300px; }
        .locked-field { background-color: #e9ecef; cursor: not-allowed; border-color: #dee2e6; }
    </style>
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-truck-field text-primary me-2"></i>Supplier Directory</h4>
            <small class="text-muted">Manage vendors, locations, and strict financial mappings.</small>
        </div>
        <button class="btn btn-primary btn-sm shadow-sm fw-bold" onclick="supplierApp.openEditor()">
            <i class="fa-solid fa-plus me-1"></i> New Vendor
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-3 bg-light">
        <div class="card-body py-2 px-3 d-flex gap-3 align-items-center">
            <span class="fw-bold text-muted fs-13"><i class="fa-solid fa-filter me-1"></i> Filters:</span>
            <select class="form-select form-select-sm w-auto shadow-sm" id="filterDistrict">
                <option value="">All Districts</option>
            </select>
            <select class="form-select form-select-sm w-auto shadow-sm" id="filterCity">
                <option value="">All Cities</option>
            </select>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="supplierGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th>Company Name</th>
                        <th>Tax / VAT ID</th>
                        <th>Contact Person</th>
                        <th>Location</th>
                        <th>Supplier Group</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="supplierModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fs-6 fw-bold" id="drawerTitle">Register Vendor</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body fs-13 p-4 bg-white">
                <form id="frmSupplier">
                    <input type="hidden" id="Id" name="Id" value="0">

                    <div class="row">
                        <div class="col-lg-6 pe-lg-4 border-end">
                            <h6 class="text-primary border-bottom pb-1 mb-3 fw-bold"><i class="fa-solid fa-id-card me-2"></i>1. Identity & Contact</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-md-8">
                                    <label class="form-label fw-bold mb-1">Company Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="Name" name="Name" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">Tax / VAT ID <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm font-monospace" id="TaxRegNo" name="TaxRegNo" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Supplier Group <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="SupplierGroupId" name="SupplierGroupId" required></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Business Reg No</label>
                                    <input type="text" class="form-control form-control-sm font-monospace" id="BusinessRegNo" name="BusinessRegNo">
                                </div>
                                
                                <div class="col-md-12 mt-3">
                                    <label class="form-label fw-bold mb-1">Primary Contact <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="ContactPerson" name="ContactPerson" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Primary Email <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control form-control-sm" id="Email" name="Email" required placeholder="vendor@company.com">
                                </div>
                                <div class="col-md-6">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <label class="form-label fw-bold mb-0">Accounts / Billing Email</label>
                                        <div class="form-check form-check-inline mb-0 me-0">
                                            <input class="form-check-input" type="checkbox" id="chkSameAsPrimary" style="transform: scale(0.85); cursor: pointer;">
                                            <label class="form-check-label fs-12 text-muted user-select-none" for="chkSameAsPrimary" style="cursor: pointer;">Same as Primary</label>
                                        </div>
                                    </div>
                                    <input type="email" class="form-control form-control-sm" id="AccountsEmail" name="AccountsEmail" placeholder="billing@company.com">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Phone <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="Phone" name="Phone" required pattern="^\+?[0-9\s\-\(\)]{9,15}$" title="Valid phone number required">
                                </div>
                            </div>

                            <h6 class="text-primary border-bottom pb-1 mb-3 fw-bold"><i class="fa-solid fa-map-location-dot me-2"></i>2. Geographic Location</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1">Address Line 1 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="AddressLine1" name="AddressLine1" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">Province <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" name="Province" id="Province" required></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">District <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" name="District" id="District" required disabled></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">City <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" name="City" id="City" required disabled></select>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 ps-lg-4">
                            <div class="d-flex justify-content-between align-items-end border-bottom pb-1 mb-3">
                                <h6 class="text-primary mb-0 fw-bold"><i class="fa-solid fa-scale-balanced me-2"></i>3. Financial Settings</h6>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="unlockAccountsToggle">
                                    <label class="form-check-label fs-12 text-muted" for="unlockAccountsToggle">Unlock GL Mapping</label>
                                </div>
                            </div>
                            <div class="row g-2 mb-4">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1">A/P Control Account (Liability) <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm locked-field" id="DefaultPayableAccountId" name="DefaultPayableAccountId" required></select>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1">Default Expense Account</label>
                                    <select class="form-select form-select-sm locked-field" id="DefaultExpenseAccountId" name="DefaultExpenseAccountId"></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">Currency <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="CurrencyCode" name="CurrencyCode" required>
                                        <option value="LKR">LKR</option>
                                        <option value="USD">USD</option>
                                        <option value="EUR">EUR</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">Payment Term</label>
                                    <select class="form-select form-select-sm" id="PaymentTermId" name="PaymentTermId"></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">Credit Limit</label>
                                    <input type="number" class="form-control form-control-sm text-end fw-bold text-dark" id="CreditLimit" name="CreditLimit" value="0.00" step="0.01">
                                </div>
                            </div>

                            <h6 class="text-primary border-bottom pb-1 mb-3 fw-bold"><i class="fa-solid fa-building-columns me-2"></i>4. Banking Setup</h6>
                            <div class="row g-2 mb-3 bg-light p-2 rounded border mt-2">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1 text-muted">Bank Name</label>
                                    <select class="form-select form-select-sm" name="BankId" id="BankId">
                                        <option value="">-- Select Bank --</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1 text-muted">Branch</label>
                                    <select class="form-select form-select-sm" name="BankBranchId" id="BankBranchId" disabled>
                                        <option value="">-- Select Branch --</option>
                                    </select>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1 text-muted">Account Number</label>
                                    <input type="text" class="form-control form-control-sm font-monospace text-primary fw-bold" id="BankAccountNumber" name="BankAccountNumber" placeholder="Numeric account number">
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-3 border-top d-flex justify-content-between align-items-center">
                <div class="form-check form-switch ms-2">
                    <input class="form-check-input" type="checkbox" id="IsActive" name="IsActive" checked>
                    <label class="form-check-label fw-bold text-success" for="IsActive">Active Vendor</label>
                </div>
                <div>
                    <button type="button" class="btn btn-secondary btn-sm px-4 me-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm fw-bold" onclick="supplierApp.saveSupplier(event)">
                        <i class="fa-solid fa-check-double me-1"></i> Save Vendor
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/purchasing/supplier-master.js" asp-append-version="true"></script>
}