@{
    ViewData["Title"] = "Supplier Master";
}

@section Styles {
    <style>
        /* Force DataTables search box to align left */
        .dataTables_filter {
            text-align: left !important;
        }

            .dataTables_filter label {
                width: 100%;
                display: flex;
                align-items: center;
            }

            .dataTables_filter input {
                margin-left: 10px;
                width: auto;
                flex-grow: 1;
                max-width: 300px;
            }
    </style>
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0">Supplier Directory</h4>
            <small class="text-muted">Manage vendors, compliance, and banking details.</small>
        </div>
        <button class="btn btn-primary btn-sm shadow-sm" onclick="supplierApp.openEditor()">
            <i class="fa-solid fa-plus"></i> New Vendor
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="supplierGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Company Name</th>
                        <th>Tax / VAT ID</th>
                        <th>Contact</th>
                        <th>Supplier Group</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="supplierModal" tabindex="-1" aria-labelledby="supplierModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light">
                <h5 class="modal-title fs-6" id="drawerTitle">
                    <i class="fa-solid fa-truck-field text-primary me-2"></i>Register Vendor
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body fs-13 p-4 bg-white">
                <form id="frmSupplier">
                    <input type="hidden" id="Id" name="Id" value="0">

                    <div class="row">
                        <div class="col-lg-6 pe-lg-4 border-end">
                            <h6 class="text-primary border-bottom pb-1 mb-3"><i class="fa-solid fa-id-card me-2"></i>1. Identity & Classification</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Company Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="Name" name="Name" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Trade Name (DBA)</label>
                                    <input type="text" class="form-control form-control-sm" id="TradeName" name="TradeName">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Business Reg No</label>
                                    <input type="text" class="form-control form-control-sm" id="BusinessRegNo" name="BusinessRegNo">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Tax / VAT ID <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="TaxRegNo" name="TaxRegNo" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Supplier Group</label>
                                    <select class="form-select form-select-sm" id="SupplierGroupId" name="SupplierGroupId"></select>
                                </div>
                            </div>

                            <h6 class="text-primary border-bottom pb-1 mb-3"><i class="fa-solid fa-scale-balanced me-2"></i>2. Financial Setup</h6>
                            <div class="row g-2 mb-3">
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">A/P Control Account (Liability) <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="DefaultPayableAccountId" name="DefaultPayableAccountId" required></select>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Default Expense Account</label>
                                    <select class="form-select form-select-sm" id="DefaultExpenseAccountId" name="DefaultExpenseAccountId"></select>
                                    <small class="text-muted d-block mt-1">Primarily used for service/utility vendors.</small>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold mb-1">Currency <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="CurrencyCode" name="CurrencyCode" required>
                                        <option value="LKR">LKR</option>
                                        <option value="USD">USD</option>
                                        <option value="EUR">EUR</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold mb-1">Payment Term</label>
                                    <select class="form-select form-select-sm" id="PaymentTermId" name="PaymentTermId"></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold mb-1">Credit Limit</label>
                                    <input type="number" class="form-control form-control-sm text-end" id="CreditLimit" name="CreditLimit" value="0.00" step="0.01">
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 ps-lg-4">
                            <h6 class="text-primary border-bottom pb-1 mb-3"><i class="fa-solid fa-address-book me-2"></i>3. Contact & Address</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Primary Contact</label>
                                    <input type="text" class="form-control form-control-sm" id="ContactPerson" name="ContactPerson">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Email <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control form-control-sm" id="Email" name="Email" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Phone</label>
                                    <input type="text" class="form-control form-control-sm" id="Phone" name="Phone">
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Website</label>
                                    <input type="text" class="form-control form-control-sm" id="Website" name="Website">
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Address Line 1 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="AddressLine1" name="AddressLine1" required>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Address Line 2</label>
                                    <input type="text" class="form-control form-control-sm" id="AddressLine2" name="AddressLine2">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold mb-1">City</label>
                                    <input type="text" class="form-control form-control-sm" id="City" name="City">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold mb-1">State / Prov</label>
                                    <input type="text" class="form-control form-control-sm" id="State" name="State">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold mb-1">Zip Code</label>
                                    <input type="text" class="form-control form-control-sm" id="ZipCode" name="ZipCode">
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Country</label>
                                    <select class="form-select form-select-sm" id="Country" name="Country">
                                        <option value="LKR">Sri Lanka</option>
                                        <option value="USA">United States</option>
                                        <option value="GB">United Kingdom</option>
                                    </select>
                                </div>
                            </div>

                            <h6 class="text-primary border-bottom pb-1 mb-3"><i class="fa-solid fa-building-columns me-2"></i>4. Banking Details</h6>
                            <div class="row g-2 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Bank Name</label>
                                    <input type="text" class="form-control form-control-sm" id="BankName" name="BankName">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Branch</label>
                                    <input type="text" class="form-control form-control-sm" id="BankBranch" name="BankBranch">
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Account Number</label>
                                    <input type="text" class="form-control form-control-sm font-monospace" id="BankAccountNumber" name="BankAccountNumber">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">SWIFT / BIC</label>
                                    <input type="text" class="form-control form-control-sm font-monospace" id="BankSwiftCode" name="BankSwiftCode">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">IBAN</label>
                                    <input type="text" class="form-control form-control-sm font-monospace" id="BankIBAN" name="BankIBAN">
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-3 border-top d-flex justify-content-between align-items-center">
                <div class="form-check form-switch ms-2">
                    <input class="form-check-input" type="checkbox" id="IsActive" name="IsActive" checked>
                    <label class="form-check-label fw-semibold" for="IsActive">Active Vendor</label>
                </div>
                <div>
                    <button type="button" class="btn btn-secondary btn-sm px-4 me-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm" onclick="supplierApp.saveSupplier()">
                        <i class="fa-solid fa-save"></i> Save Vendor
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/purchasing/supplier-master.js" asp-append-version="true"></script>
}