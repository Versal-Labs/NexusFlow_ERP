@{
    ViewData["Title"] = "Cheque Vault (PDCs)";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-vault text-warning me-2"></i>Treasury Cheque Vault</h4>
            <p class="text-muted mb-0 fs-14">Track Undeposited Funds, execute bank deposits, and manage dishonored (bounced) cheques.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-white">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-end fs-13">
                <div class="col-md-2">
                    <label class="form-label mb-1 fw-bold text-muted">Cheque Status</label>
                    <select class="form-select form-select-sm" id="filterStatus">
                        <option value="">All Statuses</option>
                        <option value="0" selected>In Safe (Undeposited)</option>
                        <option value="1">Deposited (Awaiting Clear)</option>
                        <option value="2">Endorsed to Supplier</option>
                        <option value="3">Cleared</option>
                        <option value="4">Bounced / Dishonored</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted">Customer</label>
                    <select class="form-select form-select-sm select2" id="filterCustomer" style="width: 100%;"></select>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1 fw-bold text-muted">Bank</label>
                    <select class="form-select form-select-sm select2" id="filterBank" onchange="vaultApp.onBankFilterChange()" style="width: 100%;"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted">Branch</label>
                    <select class="form-select form-select-sm select2" id="filterBranch" style="width: 100%;" disabled></select>
                </div>
                <div class="col-md-2 text-end">
                    <button class="btn btn-sm btn-outline-secondary me-1" onclick="vaultApp.resetFilters()"><i class="fa-solid fa-eraser"></i></button>
                    <button class="btn btn-sm btn-primary px-3 fw-bold" onclick="vaultApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Filter</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="chequeGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Cheque #</th>
                        <th>Bank & Branch</th>
                        <th>PDC Date</th>
                        <th>Customer</th>
                        <th class="text-end">Amount</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="bounceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-burst me-2"></i>Dishonor (Bounce) Cheque</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <form id="bounceForm">
                    <input type="hidden" id="BounceChequeId" />
                    
                    <div class="alert alert-warning shadow-sm fs-13 border-warning">
                        <strong>Warning:</strong> This action will instantly reverse the General Ledger and reinstate the customer's Accounts Receivable debt. Associated invoices will be marked as Unpaid.
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Date of Rejection (Bank Date) <span class="text-danger">*</span></label>
                        <input type="date" class="form-control shadow-sm" id="BounceDate" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Reason for Dishonor <span class="text-danger">*</span></label>
                        <select class="form-select shadow-sm" id="BounceReason" required>
                            <option value="">-- Select Reason --</option>
                            <option value="Insufficient Funds (NSF)">Insufficient Funds (NSF)</option>
                            <option value="Signature Mismatch">Signature Mismatch</option>
                            <option value="Post-Dated Cheque Presented Early">Post-Dated Cheque Presented Early</option>
                            <option value="Account Closed">Account Closed</option>
                            <option value="Payment Stopped by Drawer">Payment Stopped by Drawer</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-white border-top">
                <button type="button" class="btn btn-light border btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm px-4 shadow-sm fw-bold" onclick="vaultApp.executeBounce()">
                    <i class="fa-solid fa-triangle-exclamation me-1"></i> Execute Bounce
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="endorseModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-handshake me-2"></i>Endorse Cheque to Supplier</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <form id="endorseForm">
                    <input type="hidden" id="EndorseChequeId" />
                    <input type="hidden" id="EndorseChequeAmount" value="0" />

                    <div class="alert alert-secondary shadow-sm d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <span class="d-block text-muted fw-bold fs-12 text-uppercase">Cheque to Endorse</span>
                            <span class="fs-5 fw-bold text-dark font-monospace" id="lblEndorseChequeNo"></span>
                        </div>
                        <div class="text-end">
                            <span class="d-block text-muted fw-bold fs-12 text-uppercase">Value</span>
                            <span class="fs-4 fw-bold text-success font-monospace" id="lblEndorseAmount"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Select Supplier <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="EndorseSupplierId" style="width:100%;" required></select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Date of Endorsement</label>
                            <input type="date" class="form-control" id="EndorseDate" required>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <h6 class="fw-bold text-primary mb-0"><i class="fa-solid fa-file-invoice-dollar me-2"></i>Apply to Supplier Bills</h6>
                        <button class="btn btn-sm btn-outline-primary fw-bold" type="button" onclick="vaultApp.autoAllocateEndorse()">
                            <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Auto-Apply
                        </button>
                    </div>

                    <div class="table-responsive border rounded bg-white" style="max-height: 250px; overflow-y: auto;">
                        <table class="table table-sm table-hover align-middle mb-0 fs-13">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Bill #</th>
                                    <th>Date</th>
                                    <th class="text-end">Total</th>
                                    <th class="text-end">Balance</th>
                                    <th class="text-end" style="width: 130px;">Apply</th>
                                </tr>
                            </thead>
                            <tbody id="endorseAllocationsBody">
                                <tr><td colspan="5" class="text-center text-muted fst-italic py-3">Select a supplier to view unpaid bills.</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="text-end mt-2 fs-13 text-muted fw-bold">
                        Allocated: <span id="lblEndorseAllocated" class="text-dark font-monospace ms-1 me-3">0.00</span>
                        Advance / Credit: <span id="lblEndorseUnallocated" class="text-success font-monospace ms-1">0.00</span>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-white border-top">
                <button type="button" class="btn btn-light border btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-secondary btn-sm px-4 shadow-sm fw-bold" onclick="vaultApp.executeEndorse()">
                    <i class="fa-solid fa-check-double me-1"></i> Confirm Endorsement
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/finance/cheque-vault.js" asp-append-version="true"></script>
}