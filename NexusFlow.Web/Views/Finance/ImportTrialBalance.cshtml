@{
    ViewData["Title"] = "Trial Balance Migration Wizard";
}

<div class="container-fluid py-3 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-scale-balanced text-primary me-2"></i>Trial Balance Migration Wizard</h4>
            <p class="text-muted mb-0 fs-14">Upload remaining GL balances (Bank, Fixed Assets, Equity). Do NOT include AR, AP, or Inventory accounts.</p>
        </div>
        <div>
            <button class="btn btn-outline-dark btn-sm shadow-sm fw-bold" onclick="tbImportApp.downloadTemplate()">
                <i class="fa-solid fa-download me-1"></i> Download CSV Template
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4" id="uploadSection">
        <div class="card-body p-5 text-center">
            <i class="fa-solid fa-file-csv text-primary mb-3" style="font-size: 3rem;"></i>
            <h5 class="fw-bold">Select Trial Balance CSV File</h5>
            <p class="text-muted fs-13 mb-4">Required columns: AccountCode, Debit, Credit</p>
            
            <input type="file" id="csvFileInput" class="form-control w-50 mx-auto mb-3" accept=".csv">
            <button class="btn btn-primary px-4 fw-bold shadow-sm" onclick="tbImportApp.previewCsv()">
                <i class="fa-solid fa-eye me-2"></i> Parse & Preview Data
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0 d-none" id="previewSection">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-2">
            <span class="fw-bold"><i class="fa-solid fa-table-list me-2"></i>Review Trial Balance</span>
            <div class="d-flex align-items-center">
                <label class="me-2 fw-bold mb-0">Cutover Date:</label>
                <input type="date" id="CutoverDate" class="form-control form-control-sm w-auto fw-bold me-3">
                <button class="btn btn-success btn-sm fw-bold shadow-sm" id="btnCommit" onclick="tbImportApp.executeImport(event)">
                    <i class="fa-solid fa-check-double me-1"></i> Commit to General Ledger
                </button>
            </div>
        </div>
        <div class="card-body p-0" style="max-height: 60vh; overflow-y: auto;">
            <table class="table table-bordered table-hover align-middle mb-0 fs-13" id="previewTable">
                <thead class="table-light sticky-top shadow-sm">
                    <tr>
                        <th style="width: 30%;">GL Account Code</th>
                        <th class="text-end bg-primary bg-opacity-10" style="width: 30%;">Debit Balance</th>
                        <th class="text-end bg-warning bg-opacity-10" style="width: 30%;">Credit Balance</th>
                        <th class="text-center" style="width: 10%;"><i class="fa-solid fa-trash-can text-danger"></i></th>
                    </tr>
                </thead>
                <tbody id="previewBody"></tbody>
            </table>
        </div>
        
        <div class="card-footer bg-light py-3">
            <div class="row text-center fw-bold fs-5">
                <div class="col-4 text-primary">
                    <div class="fs-13 text-muted text-uppercase mb-1">Total Debits</div>
                    <span id="lblTotalDebit">$0.00</span>
                </div>
                <div class="col-4 text-warning text-dark">
                    <div class="fs-13 text-muted text-uppercase mb-1">Total Credits</div>
                    <span id="lblTotalCredit">$0.00</span>
                </div>
                <div class="col-4 border-start border-2">
                    <div class="fs-13 text-muted text-uppercase mb-1">Variance (Must be $0.00)</div>
                    <span id="lblVariance" class="text-danger">$0.00</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/finance/import-tb.js" asp-append-version="true"></script>
}