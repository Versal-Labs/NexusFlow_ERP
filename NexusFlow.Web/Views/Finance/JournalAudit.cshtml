@{
    ViewData["Title"] = "Journal Audit (General Ledger)";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-book-journal-whills text-primary me-2"></i>Journal Audit</h4>
            <p class="text-muted mb-0 fs-14">Immutable General Ledger tracking for all financial movements.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-white">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-center fs-13">
                <div class="col-md-3">
                    <label class="form-label mb-0 fw-bold text-muted">Source Module</label>
                    <select class="form-select form-select-sm" id="filterModule">
                        <option value="">-- All Modules --</option>
                        <option value="Sales">Sales (Invoices & RMAs)</option>
                        <option value="Purchasing">Purchasing (Bills & GRNs)</option>
                        <option value="Inventory">Inventory (Stock Takes)</option>
                        <option value="Treasury">Treasury (Payments & Receipts)</option>
                        <option value="Manual">Manual Journals</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label mb-0 fw-bold text-muted">Transaction Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control" id="filterStartDate">
                        <span class="input-group-text">to</span>
                        <input type="date" class="form-control" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-5 text-end mt-4">
                    <button class="btn btn-sm btn-outline-secondary me-1" onclick="journalApp.resetFilters()"><i class="fa-solid fa-eraser"></i> Clear</button>
                    <button class="btn btn-sm btn-primary px-3" onclick="journalApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Filter Ledger</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="journalGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Reference / Doc #</th>
                        <th>Module</th>
                        <th>Description</th>
                        <th class="text-end">Total Amount</th>
                        <th class="text-end pe-3">Audit</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="journalModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content bg-light border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fw-bold mb-0"><i class="fa-solid fa-scale-balanced me-2"></i>Journal Entry Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-4 bg-white">
                <div class="row mb-4 bg-light p-3 rounded border">
                    <div class="col-md-3">
                        <small class="text-muted fw-bold text-uppercase">Reference No</small>
                        <div class="fs-5 fw-bold text-primary font-monospace" id="lblRefNo"></div>
                    </div>
                    <div class="col-md-3">
                        <small class="text-muted fw-bold text-uppercase">Posting Date</small>
                        <div class="fs-5 fw-bold text-dark" id="lblDate"></div>
                    </div>
                    <div class="col-md-3">
                        <small class="text-muted fw-bold text-uppercase">Module</small>
                        <div class="fs-5 fw-bold text-dark" id="lblModule"></div>
                    </div>
                    <div class="col-md-3 text-end">
                        <button class="btn btn-outline-primary btn-sm mt-2" id="btnViewSource" onclick="journalApp.viewSourceDocument()">
                            <i class="fa-solid fa-magnifying-glass-arrow-right me-1"></i> View Source Document
                        </button>
                    </div>
                    <div class="col-12 mt-2">
                        <small class="text-muted fw-bold text-uppercase">Description</small>
                        <div class="text-dark fs-14" id="lblDesc"></div>
                    </div>
                </div>

                <h6 class="fw-bold text-dark mb-2 border-bottom pb-2">Double-Entry Breakdown</h6>
                <table class="table table-sm table-bordered align-middle fs-13">
                    <thead class="table-secondary text-center">
                        <tr>
                            <th class="text-start" style="width: 15%">Account Code</th>
                            <th class="text-start" style="width: 35%">Account Name</th>
                            <th class="text-start" style="width: 20%">Line Note</th>
                            <th class="text-end text-dark" style="width: 15%">Debit (Dr)</th>
                            <th class="text-end text-dark" style="width: 15%">Credit (Cr)</th>
                        </tr>
                    </thead>
                    <tbody id="journalLinesBody"></tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold text-dark fs-6">Totals:</td>
                            <td class="text-end fw-bold text-success font-monospace fs-6" id="lblTotalDebit">0.00</td>
                            <td class="text-end fw-bold text-danger font-monospace fs-6" id="lblTotalCredit">0.00</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            
            <div class="modal-footer bg-light py-2">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Close Audit</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/finance/journal-audit.js" asp-append-version="true"></script>
}