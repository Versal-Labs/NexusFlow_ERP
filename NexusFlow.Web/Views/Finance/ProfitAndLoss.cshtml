@{
    ViewData["Title"] = "Profit & Loss Statement";
}

<style>
    .acct-row { transition: background-color 0.2s; }
    .acct-row:hover { background-color: #f8f9fa; }
    .acct-indent { padding-left: 2.5rem !important; }
    .total-row { border-top: 1px solid #dee2e6; border-bottom: 1px solid #dee2e6; font-weight: bold; background-color: #fcfcfc; }
    .net-income-row { border-top: 2px solid #212529; border-bottom: 4px double #212529; font-weight: 900; font-size: 1.1rem; }
    .print-header { display: none; }
    @@media print {
        .no-print { display: none !important; }
        .print-header { display: block; text-align: center; margin-bottom: 2rem; }
        .card { border: none !important; box-shadow: none !important; }
    }
</style>

<div class="container py-3 mb-5" style="max-width: 1000px;">
    <div class="d-flex justify-content-between align-items-center mb-3 no-print">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-file-invoice-dollar text-success me-2"></i>Profit & Loss</h4>
            <p class="text-muted mb-0 fs-14">Income Statement based on posted General Ledger entries.</p>
        </div>
        <div>
            <button class="btn btn-outline-secondary shadow-sm btn-sm px-3 fw-bold me-2" onclick="window.print()"><i class="fa-solid fa-print me-1"></i> Print</button>
            <button class="btn btn-success shadow-sm btn-sm px-3 fw-bold" onclick="plApp.exportExcel()"><i class="fa-solid fa-file-excel me-1"></i> Export Excel</button>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4 bg-white no-print">
        <div class="card-body py-3 px-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label mb-1 fw-bold text-muted fs-13">Report Basis</label>
                    <select class="form-select form-select-sm fw-bold" id="ReportBasis">
                        <option value="Accrual">Accrual Basis</option>
                        <option value="Cash">Cash Basis</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted fs-13">Date Range Preset</label>
                    <select class="form-select form-select-sm fw-bold text-primary" id="DatePreset">
                        <option value="ThisMonth">This Month</option>
                        <option value="Today">Today</option>
                        <option value="ThisWeek">This Week</option>
                        <option value="ThisQuarter">This Quarter</option>
                        <option value="ThisYear">This Year</option>
                        <option value="LastMonth">Last Month</option>
                        <option value="LastYear">Last Year</option>
                        <option value="Custom">Custom Range...</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1 fw-bold text-muted fs-13">Start Date</label>
                    <input type="date" class="form-control form-control-sm fw-bold" id="StartDate">
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1 fw-bold text-muted fs-13">End Date</label>
                    <input type="date" class="form-control form-control-sm fw-bold" id="EndDate">
                </div>
                <div class="col-md-3">
                    <button class="btn btn-sm btn-primary w-100 shadow-sm fw-bold" onclick="plApp.generateReport()">
                        <i class="fa-solid fa-bolt me-1"></i> Generate Statement
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0" id="StatementCard" style="display:none;">
        <div class="card-body p-4 p-md-5">
            <div class="print-header">
                <h2 class="fw-bold mb-1">PROFIT & LOSS STATEMENT</h2>
                <h5 class="text-muted" id="lblReportPeriod"></h5>
                <h6 class="text-muted fst-italic" id="lblReportBasis"></h6>
            </div>

            <table class="table table-borderless table-sm fs-14 mb-0" id="plTable">
                <tbody>
                    <tr><td colspan="2" class="fw-bold text-primary fs-6 pt-3 pb-2 border-bottom">Operating Revenue</td></tr>
                    <tbody id="revenueBody"></tbody>
                    <tr class="total-row"><td class="ps-3 py-2">Total Revenue</td><td class="text-end py-2" id="lblTotalRevenue">$0.00</td></tr>

                    <tr><td colspan="2" class="fw-bold text-danger fs-6 pt-4 pb-2 border-bottom">Cost of Goods Sold (COGS)</td></tr>
                    <tbody id="cogsBody"></tbody>
                    <tr class="total-row"><td class="ps-3 py-2">Total Cost of Goods Sold</td><td class="text-end py-2 text-danger" id="lblTotalCogs">$0.00</td></tr>

                    <tr class="bg-light"><td class="fw-bold fs-5 py-3 text-dark">Gross Profit</td><td class="text-end fw-bold fs-5 py-3 text-dark" id="lblGrossProfit">$0.00</td></tr>

                    <tr><td colspan="2" class="fw-bold text-warning text-dark fs-6 pt-4 pb-2 border-bottom">Operating Expenses</td></tr>
                    <tbody id="expenseBody"></tbody>
                    <tr class="total-row"><td class="ps-3 py-2">Total Expenses</td><td class="text-end py-2 text-danger" id="lblTotalExpenses">$0.00</td></tr>

                    <tr class="net-income-row mt-3"><td class="py-3">NET INCOME</td><td class="text-end py-3 text-success" id="lblNetIncome">$0.00</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="~/js/finance/profit-and-loss.js" asp-append-version="true"></script>
}