@{
    ViewData["Title"] = "Sign In - NexusFlow ERP";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --primary-color: #2563EB; /* Modern Tech Blue */
            --primary-hover: #1d4ed8;
            --bg-gradient: linear-gradient(135deg, #f0f4ff 0%, #e0e7ff 100%);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            height: 100vh;
            overflow: hidden;
        }

        /* Split Screen Layout */
        .login-container {
            display: flex;
            height: 100vh;
            width: 100%;
        }

        /* Left Side: Branding/Image */
        .login-sidebar {
            flex: 1;
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

            /* Abstract Pattern Overlay (CSS only art) */
            .login-sidebar::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(37,99,235,0.1) 0%, rgba(0,0,0,0) 70%);
                animation: pulse 10s infinite alternate;
            }

        @@keyframes pulse {
            0% {
                transform: scale(1);
            }

            100% {
                transform: scale(1.1);
            }
        }

        .brand-content {
            z-index: 2;
            text-align: center;
            padding: 2rem;
        }

        .brand-logo i {
            font-size: 4rem;
            margin-bottom: 1rem;
            background: -webkit-linear-gradient(#60a5fa, #2563eb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Right Side: Form */
        .login-form-wrapper {
            flex: 1; /* Default for mobile/tablet */
            max-width: 550px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem;
            background-color: white;
        }

        /* Responsive adjustments */
        @@media (max-width: 992px) {
            .login-sidebar {
                display: none;
            }
            /* Hide image on tablet/mobile */
            .login-form-wrapper {
                max-width: 100%;
                flex: 1;
                background: var(--bg-gradient);
            }

            .card-mobile {
                background: white;
                padding: 2rem;
                border-radius: 1rem;
                box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            }
        }

        /* Form Elements */
        .form-floating > .form-control {
            border-radius: 0.5rem;
            border: 1px solid #e2e8f0;
            background-color: #f8fafc;
        }

            .form-floating > .form-control:focus {
                border-color: var(--primary-color);
                background-color: #fff;
                box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
            }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            padding: 0.8rem;
            font-weight: 600;
            border-radius: 0.5rem;
            transition: all 0.2s;
        }

            .btn-primary:hover {
                background-color: var(--primary-hover);
                transform: translateY(-1px);
            }

        .brand-title {
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .text-muted-small {
            font-size: 0.85rem;
            color: #64748b;
        }
    </style>
</head>
<body>

    <div class="login-container">

        <div class="login-sidebar">
            <div class="brand-content">
                <div class="brand-logo">
                    <img src="../Assets/Group 3.png" alt="NexusFlow Logo" style="width: 100px; height: auto;">
                </div>
                <h1 class="display-5 fw-bold mb-3">Nexus Flow ERP</h1>
                <p class="lead opacity-75">
                    Manage your Inventory, Sales, and Finance <br>
                    in one unified, secure platform.
                </p>
            </div>

            <div class="position-absolute bottom-0 w-100 text-center pb-4 opacity-50 small">
                &copy; 2026 NexusFlow Systems. Secured & Encrypted.
            </div>
        </div>

        <div class="login-form-wrapper">
            <div class="card-mobile">
                <div class="mb-5">
                    <div class="d-lg-none text-center mb-4">
                        <i class="fas fa-cube text-primary fa-3x"></i>
                        <h3 class="fw-bold mt-2">NexusFlow</h3>
                    </div>

                    <h2 class="brand-title">Welcome back</h2>
                    <p class="text-muted">Please enter your details to sign in.</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <div>@ViewBag.Error</div>
                    </div>
                }

                <form method="post" action="/Account/Login">
                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="floatingInput" name="email" placeholder="name@example.com" required value="admin@nexusflow.com">
                        <label for="floatingInput">Email address</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="password" class="form-control" id="floatingPassword" name="password" placeholder="Password" required>
                        <label for="floatingPassword">Password</label>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="" id="rememberMe">
                            <label class="form-check-label text-muted-small" for="rememberMe">
                                Remember me for 30 days
                            </label>
                        </div>
                        <a href="#" class="text-decoration-none text-muted-small fw-bold">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-3 shadow-sm">
                        <i class="fas fa-sign-in-alt me-2"></i> Sign in
                    </button>

                    <div class="text-center mt-4">
                        <span class="text-muted-small">Don't have an account?</span>
                        <a href="#" class="text-decoration-none fw-bold ms-1" style="color: var(--primary-color)">Contact Admin</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>
</html>