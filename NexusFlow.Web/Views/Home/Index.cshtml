@model NexusFlow.AppCore.Features.Dashboard.Queries.DashboardMetricsDto
@{
    ViewData["Title"] = "Executive Dashboard";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
    <div>
        <h2 class="h3 mb-0 fw-bold text-dark"><i class="fa-solid fa-chart-pie text-primary me-2"></i>Executive Dashboard</h2>
        <p class="text-muted fs-13 mb-0">Real-time financial and operational insights.</p>
    </div>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-sm btn-outline-secondary fw-bold bg-white shadow-sm">
            <i class="fas fa-calendar-alt me-1"></i> As of @DateTime.UtcNow.ToString("dd MMM yyyy")
        </button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 border-start border-4 border-success h-100 rounded-3">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 fs-12 text-uppercase fw-bold">Revenue (MTD)</p>
                        <h4 class="mb-0 fw-bold text-dark">@Model.MtdRevenue.ToString("N2")</h4>
                    </div>
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="fas fa-arrow-trend-up fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 border-start border-4 border-primary h-100 rounded-3">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 fs-12 text-uppercase fw-bold">A/R Balance (Owed to us)</p>
                        <h4 class="mb-0 fw-bold text-primary">@Model.AccountsReceivable.ToString("N2")</h4>
                    </div>
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="fas fa-file-invoice-dollar fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 border-start border-4 border-danger h-100 rounded-3">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 fs-12 text-uppercase fw-bold">A/P Balance (We owe)</p>
                        <h4 class="mb-0 fw-bold text-danger">@Model.AccountsPayable.ToString("N2")</h4>
                    </div>
                    <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="fas fa-hand-holding-dollar fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 border-start border-4 border-info h-100 rounded-3">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 fs-12 text-uppercase fw-bold">Total Stock Value</p>
                        <h4 class="mb-0 fw-bold text-dark">@Model.TotalInventoryValue.ToString("N2")</h4>
                    </div>
                    <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="fas fa-boxes-stacked fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-3">
                <div class="row text-center">
                    <div class="col-md-4 border-end border-secondary">
                        <p class="text-uppercase fs-12 fw-bold text-muted mb-1">Total Cash & Bank Balance</p>
                        <h5 class="mb-0 fw-bold text-success"><i class="fa-solid fa-building-columns me-2"></i>@Model.CashOnHand.ToString("N2")</h5>
                    </div>
                    <div class="col-md-4 border-end border-secondary">
                        <p class="text-uppercase fs-12 fw-bold text-muted mb-1">Overdue Receivables (Risk)</p>
                        <h5 class="mb-0 fw-bold text-warning"><i class="fa-solid fa-clock-rotate-left me-2"></i>@Model.OverdueReceivables.ToString("N2")</h5>
                    </div>
                    <div class="col-md-4">
                        <p class="text-uppercase fs-12 fw-bold text-muted mb-1">Committed Spend (Open POs)</p>
                        <h5 class="mb-0 fw-bold text-info"><i class="fa-solid fa-file-contract me-2"></i>@Model.CommittedSpend.ToString("N2")</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0 h-100 rounded-3">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-chart-area text-muted me-2"></i>Sales vs. Purchases (Trailing 6 Months)</h6>
            </div>
            <div class="card-body p-4">
                <canvas id="mainChart" height="110"></canvas>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card shadow-sm border-0 h-100 rounded-3">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-bell text-warning me-2"></i>Action Center</h6>
            </div>
            <div class="list-group list-group-flush">
                
                @if (Model.PendingSalesOrders > 0)
                {
                    <a href="/SalesOrder" class="list-group-item list-group-item-action d-flex align-items-start border-0 px-3 py-3 border-bottom">
                        <div class="bg-primary bg-opacity-10 text-primary me-3 rounded p-2 text-center" style="width: 40px;">
                            <i class="fas fa-shopping-bag"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fs-14 fw-bold text-dark">Pending Sales Orders</h6>
                            <p class="mb-0 text-muted fs-12">You have @Model.PendingSalesOrders orders waiting for fulfillment.</p>
                        </div>
                    </a>
                }

                @if (Model.LowStockItems > 0)
                {
                    <a href="/Inventory/StockValuation" class="list-group-item list-group-item-action d-flex align-items-start border-0 px-3 py-3 border-bottom">
                        <div class="bg-warning bg-opacity-10 text-warning me-3 rounded p-2 text-center" style="width: 40px;">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fs-14 fw-bold text-dark">Low Stock Alert</h6>
                            <p class="mb-0 text-muted fs-12">@Model.LowStockItems product variants are running below minimum thresholds.</p>
                        </div>
                    </a>
                }

                @if (Model.BouncedCheques > 0)
                {
                    <a href="/Finance/ChequeVault" class="list-group-item list-group-item-action d-flex align-items-start border-0 px-3 py-3 border-bottom bg-danger bg-opacity-10">
                        <div class="bg-danger text-white me-3 rounded p-2 text-center shadow-sm" style="width: 40px;">
                            <i class="fas fa-money-bill-transfer"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fs-14 fw-bold text-danger">Bounced Cheques Detected</h6>
                            <p class="mb-0 text-dark fs-12">You have @Model.BouncedCheques bounced cheque(s) requiring reversal or collection.</p>
                        </div>
                    </a>
                }

                <div class="list-group-item d-flex align-items-start border-0 px-3 py-3">
                    <div class="bg-success bg-opacity-10 text-success me-3 rounded p-2 text-center" style="width: 40px;">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div>
                        <h6 class="mb-1 fs-14 fw-bold text-dark">System Running Smoothly</h6>
                        <p class="mb-0 text-muted fs-12">All ERP services are fully operational.</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        var ctx = document.getElementById('mainChart').getContext('2d');

        // Beautiful Gradient for Sales
        var gradientSales = ctx.createLinearGradient(0, 0, 0, 400);
        gradientSales.addColorStop(0, 'rgba(13, 110, 253, 0.4)'); // Primary Blue
        gradientSales.addColorStop(1, 'rgba(13, 110, 253, 0.0)');

        // Faded Gradient for Purchases
        var gradientPurchases = ctx.createLinearGradient(0, 0, 0, 400);
        gradientPurchases.addColorStop(0, 'rgba(108, 117, 125, 0.3)'); // Secondary Grey
        gradientPurchases.addColorStop(1, 'rgba(108, 117, 125, 0.0)');

        var myChart = new Chart(ctx, {
        type: 'line',
        data: {
        labels: @Html.Raw(Json.Serialize(Model.ChartLabels)),
        datasets: [
        {
        label: 'Invoiced Sales (LKR)',
        data: @Html.Raw(Json.Serialize(Model.SalesData)),
        borderColor: '#0d6efd',
        backgroundColor: gradientSales,
        borderWidth: 3,
        pointBackgroundColor: '#0d6efd',
        pointBorderColor: '#fff',
        pointHoverBackgroundColor: '#fff',
        pointHoverBorderColor: '#0d6efd',
        fill: true,
        tension: 0.4 // Smooth curves
        },
        {
        label: 'Purchases / Bills (LKR)',
        data: @Html.Raw(Json.Serialize(Model.PurchaseData)),
        borderColor: '#6c757d',
        backgroundColor: gradientPurchases,
        borderWidth: 2,
        borderDash: [5, 5], // Dashed line for costs
        pointBackgroundColor: '#6c757d',
        fill: true,
        tension: 0.4
        }
        ]
        },
        options: {
        responsive: true,
        interaction: {
        mode: 'index',
        intersect: false,
        },
        plugins: {
        legend: {
        position: 'top',
        align: 'end',
        labels: { usePointStyle: true, boxWidth: 8 }
        },
        tooltip: {
        backgroundColor: 'rgba(0, 0, 0, 0.8)',
        padding: 12,
        titleFont: { size: 13 },
        bodyFont: { size: 14, weight: 'bold' },
        callbacks: {
        label: function(context) {
        let label = context.dataset.label || '';
        if (label) label += ': ';
        if (context.parsed.y !== null) {
        label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'LKR' }).format(context.parsed.y);
        }
        return label;
        }
        }
        }
        },
        scales: {
        y: {
        beginAtZero: true,
        grid: { borderDash: [4, 4], color: '#e9ecef', drawBorder: false },
        ticks: {
        callback: function(value) {
        if (value >= 1000000) return (value / 1000000).toFixed(1) + 'M';
        if (value >= 1000) return (value / 1000).toFixed(1) + 'K';
        return value;
        }
        }
        },
        x: {
        grid: { display: false }
        }
        }
        }
        });
        });
    </script>
}