@model NexusFlow.Web.Models.Dashbaord.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Dashboard</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary">Share</button>
            <button type="button" class="btn btn-sm btn-outline-secondary">Export</button>
        </div>
        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle">
            <i class="fas fa-calendar me-1"></i> This Week
        </button>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 border-start border-4 border-primary h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-0 small text-uppercase fw-bold">Total Stock Value</p>
                        <h4 class="mb-0 fw-bold text-dark">$@Model.TotalInventoryValue.ToString("N2")</h4>
                    </div>
                    <div class="icon-shape bg-primary bg-opacity-10 text-primary rounded p-3">
                        <i class="fas fa-boxes fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 border-start border-4 border-warning h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-0 small text-uppercase fw-bold">Low Stock Items</p>
                        <h4 class="mb-0 fw-bold text-dark">@Model.LowStockItems</h4>
                    </div>
                    <div class="icon-shape bg-warning bg-opacity-10 text-warning rounded p-3">
                        <i class="fas fa-exclamation-triangle fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 border-start border-4 border-success h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-0 small text-uppercase fw-bold">Monthly Revenue</p>
                        <h4 class="mb-0 fw-bold text-dark">$@Model.MonthlyRevenue.ToString("N2")</h4>
                    </div>
                    <div class="icon-shape bg-success bg-opacity-10 text-success rounded p-3">
                        <i class="fas fa-chart-line fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 border-start border-4 border-info h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-0 small text-uppercase fw-bold">Pending Orders</p>
                        <h4 class="mb-0 fw-bold text-dark">@Model.PendingOrders</h4>
                    </div>
                    <div class="icon-shape bg-info bg-opacity-10 text-info rounded p-3">
                        <i class="fas fa-shopping-cart fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">Sales vs Purchases</h6>
                <div class="dropdown">
                    <button class="btn btn-sm btn-light" type="button"><i class="fas fa-ellipsis-v"></i></button>
                </div>
            </div>
            <div class="card-body">
                <canvas id="mainChart" height="100"></canvas>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-transparent border-0">
                <h6 class="fw-bold mb-0">System Alerts</h6>
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item d-flex align-items-start border-0 px-3 py-3">
                    <div class="icon-circle bg-danger bg-opacity-10 text-danger me-3 rounded-circle p-2">
                        <i class="fas fa-server"></i>
                    </div>
                    <div>
                        <h6 class="mb-1 text-sm">Server Maintenance</h6>
                        <p class="mb-0 text-muted small">Scheduled for tonight at 02:00 AM.</p>
                    </div>
                </div>
                <div class="list-group-item d-flex align-items-start border-0 px-3 py-3">
                    <div class="icon-circle bg-warning bg-opacity-10 text-warning me-3 rounded-circle p-2">
                        <i class="fas fa-box-open"></i>
                    </div>
                    <div>
                        <h6 class="mb-1 text-sm">Low Stock: Fabric Roll</h6>
                        <p class="mb-0 text-muted small">Only 50m remaining in Warehouse A.</p>
                    </div>
                </div>
                <div class="list-group-item d-flex align-items-start border-0 px-3 py-3">
                    <div class="icon-circle bg-success bg-opacity-10 text-success me-3 rounded-circle p-2">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <div>
                        <h6 class="mb-1 text-sm">New User Registered</h6>
                        <p class="mb-0 text-muted small">Jane Doe joined the sales team.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Chart.js Initialization
        document.addEventListener("DOMContentLoaded", function() {
            var ctx = document.getElementById('mainChart').getContext('2d');

            // Gradient Fill for a modern look
            var gradientSales = ctx.createLinearGradient(0, 0, 0, 400);
            gradientSales.addColorStop(0, 'rgba(13, 110, 253, 0.2)'); // Primary color faded
            gradientSales.addColorStop(1, 'rgba(13, 110, 253, 0)');

            var myChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.ChartLabels)),
                    datasets: [{
                        label: 'Sales ($)',
                        data: @Html.Raw(Json.Serialize(Model.SalesData)),
                        borderColor: '#0d6efd', // Bootstrap Primary
                        backgroundColor: gradientSales,
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4 // Smooth curves
                    },
                    {
                        label: 'Purchases ($)',
                        data: @Html.Raw(Json.Serialize(Model.PurchaseData)),
                        borderColor: '#6c757d', // Bootstrap Secondary
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        borderDash: [5, 5], // Dashed line for costs
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'top', align: 'end' }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { borderDash: [2, 2], drawBorder: false }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });
        });
    </script>
}