@{
    ViewData["Title"] = "Sales Register";
}

@section Styles {
    <style>
        .dataTables_filter {
            display: none;
        }
        /* We use our own advanced filters */
        .select2-container {
            width: 100% !important;
        }
    </style>
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-file-invoice-dollar text-primary me-2"></i>Master Sales Register</h4>
            <p class="text-muted mb-0 fs-14">Comprehensive ledger of all posted sales invoices, taxes, and profitability.</p>
        </div>
        <div>
            <button class="btn btn-success shadow-sm btn-sm px-3 fw-bold me-2" onclick="salesReportApp.export('excel')">
                <i class="fa-solid fa-file-excel me-1"></i> Export Excel
            </button>
            <button class="btn btn-danger shadow-sm btn-sm px-3 fw-bold" onclick="salesReportApp.export('pdf')">
                <i class="fa-solid fa-file-pdf me-1"></i> Export PDF
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-light">
        <div class="card-body py-3 px-3">
            <div class="row g-3 align-items-end fs-13">
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted">Date Range</label>
                    <div class="input-group input-group-sm shadow-sm">
                        <input type="date" class="form-control" id="filterStartDate">
                        <span class="input-group-text bg-white border-start-0 border-end-0">to</span>
                        <input type="date" class="form-control" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted">Customer</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterCustomer"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted">Sales Representative</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterSalesRep"></select>
                </div>
                <div class="col-md-3 text-end">
                    <button class="btn btn-sm btn-outline-secondary me-1 fw-bold" onclick="salesReportApp.resetFilters()"><i class="fa-solid fa-eraser"></i> Clear</button>
                    <button class="btn btn-sm btn-primary px-4 fw-bold shadow-sm" onclick="salesReportApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Apply Filters</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="salesGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-3">Invoice No</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Sales Rep</th>
                        <th class="text-end">Sub Total</th>
                        <th class="text-end">Tax (VAT)</th>
                        <th class="text-end">Grand Total</th>
                        <th class="text-center pe-3">Payment Status</th>
                    </tr>
                </thead>
                <tfoot>
                    <tr class="bg-light fw-bold text-dark">
                        <td colspan="4" class="text-end pe-3 fs-6">Report Totals:</td>
                        <td class="text-end fs-6" id="footSubTotal">0.00</td>
                        <td class="text-end fs-6 text-danger" id="footVat">0.00</td>
                        <td class="text-end fs-5 text-primary" id="footGrandTotal">0.00</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/reporting/sales-register.js" asp-append-version="true"></script>
}