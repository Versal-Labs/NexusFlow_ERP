@{
    ViewData["Title"] = "Commission Control Report";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-sack-dollar text-success me-2"></i>Commission Control</h4>
            <p class="text-muted mb-0 fs-14">Admin view for tracking Unearned (Unpaid Invoices) vs Earned (Ready for Payroll) commissions.</p>
        </div>
        <div>
            <button class="btn btn-success shadow-sm btn-sm px-3 fw-bold me-2" onclick="commApp.export('excel')">
                <i class="fa-solid fa-file-excel me-1"></i> Export Excel
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-light">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-end fs-13">
                <div class="col-md-4">
                    <label class="form-label mb-1 fw-bold text-muted">Invoice Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control shadow-sm" id="filterStartDate">
                        <span class="input-group-text bg-white border-start-0 border-end-0">to</span>
                        <input type="date" class="form-control shadow-sm" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-sm btn-primary w-100 fw-bold shadow-sm" onclick="commApp.reloadGrid()"><i class="fa-solid fa-filter me-1"></i> Generate</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="commGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary text-center">
                    <tr>
                        <th class="text-start ps-3">Sales Representative</th>
                        <th class="text-end text-danger">Unearned (Pending Cash)</th>
                        <th class="text-end text-warning">Pending Clearance</th>
                        <th class="text-end text-success">Ready to Pay</th>
                        <th class="text-end text-muted">Already Paid</th>
                        <th class="text-center pe-3">Action</th>
                    </tr>
                </thead>
                <tfoot class="bg-light fw-bold">
                    <tr>
                        <td class="text-end pe-3 text-uppercase">Total Liability:</td>
                        <td class="text-end text-warning" id="footUnearned">0.00</td>
                        <td class="text-end text-success" id="footEarned">0.00</td>
                        <td class="text-end text-muted" id="footPaid">0.00</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.commApp = {
            _table: null,
            init: function () {
                const date = new Date();
                const firstDay = new Date(date.getFullYear(), date.getMonth(), 1).toISOString().split('T')[0];
                const lastDay = new Date(date.getFullYear(), date.getMonth() + 1, 0).toISOString().split('T')[0];
                $('#filterStartDate').val(firstDay);
                $('#filterEndDate').val(lastDay);
                this._initGrid();
            },
            _buildQueryString: function () {
                const start = $('#filterStartDate').val();
                const end = $('#filterEndDate').val();
                let q = [];
                if (start) q.push(`StartDate=${start}`);
                if (end) q.push(`EndDate=${end}`);
                return q.length > 0 ? '?' + q.join('&') : '';
            },
            _initGrid: function () {
                this._table = $('#commGrid').DataTable({
                    ajax: async (data, callback) => {
                        try {
                            const res = await api.get('/api/reporting/commission-control' + this._buildQueryString());
                            callback({ data: res.data || res || [] });
                        } catch (e) { callback({ data: [] }); }
                    },
                            columns: [
            { data: 'salesRepName', className: 'fw-bold text-dark ps-3' },
            { data: 'totalUnearned', className: 'text-end text-danger', render: d => parseFloat(d||0).toLocaleString(undefined, { minimumFractionDigits: 2 }) },
            { data: 'totalPendingClearance', className: 'text-end fw-bold text-warning', render: d => parseFloat(d||0).toLocaleString(undefined, { minimumFractionDigits: 2 }) },
            { data: 'totalReadyToPay', className: 'text-end fw-bold text-success', render: d => parseFloat(d||0).toLocaleString(undefined, { minimumFractionDigits: 2 }) },
            { data: 'totalPaid', className: 'text-end text-muted', render: d => parseFloat(d||0).toLocaleString(undefined, { minimumFractionDigits: 2 }) },
            {
                data: null, className: 'text-center pe-3', orderable: false,
                // HR can ONLY click Settle if there is money in the "ReadyToPay" bucket!
                render: (d, t, r) => `<button class="btn btn-sm btn-outline-success shadow-sm" title="Mark as Paid" ${r.totalReadyToPay <= 0 ? 'disabled' : ''}><i class="fa-solid fa-check-double"></i> Settle</button>`
            }
        ],
                    dom: '<"d-flex justify-content-between align-items-center mb-3"l>rt<"d-flex justify-content-between align-items-center mt-3"ip>',
                    footerCallback: function () {
                        let api = this.api();
                        let intVal = i => typeof i === 'string' ? i.replace(/[\$,]/g, '') * 1 : typeof i === 'number' ? i : 0;
                        $('#footUnearned').html(api.column(1, { page: 'current' }).data().reduce((a, b) => intVal(a) + intVal(b), 0).toLocaleString(undefined, { minimumFractionDigits: 2 }));
                        $('#footEarned').html(api.column(2, { page: 'current' }).data().reduce((a, b) => intVal(a) + intVal(b), 0).toLocaleString(undefined, { minimumFractionDigits: 2 }));
                        $('#footPaid').html(api.column(3, { page: 'current' }).data().reduce((a, b) => intVal(a) + intVal(b), 0).toLocaleString(undefined, { minimumFractionDigits: 2 }));
                    }
                });
            },
            reloadGrid: async function () {
                $('#commGrid_processing').show();
                try {
                    const res = await api.get('/api/reporting/commission-control' + this._buildQueryString());
                    this._table.clear().rows.add(res.data || res || []).draw();
                } catch(e) {} finally { $('#commGrid_processing').hide(); }
            },
            export: function () {
                window.open('/api/reporting/commission-control/export/excel' + this._buildQueryString(), '_blank');
            }
        };
        $(document).ready(() => commApp.init());
    </script>
}