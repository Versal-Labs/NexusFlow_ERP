@{
    ViewData["Title"] = "My Commissions Portal";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-wallet text-primary me-2"></i>My Commissions</h4>
            <p class="text-muted mb-0 fs-14">Track your earned commissions line-by-line.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="myCommGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary text-center">
                    <tr>
                        <th class="text-start ps-3">Invoice Date</th>
                        <th class="text-start">Invoice No</th>
                        <th class="text-start">Customer</th>
                        <th class="text-end">Invoice Total</th>
                        <th class="text-end text-primary">My Commission</th>
                        <th class="text-center pe-3">Commission Status</th>
                    </tr>
                </thead>
                <tfoot class="bg-light fw-bold">
                    <tr>
                        <td colspan="4" class="text-end pe-3 text-uppercase">Total Earned (Ready):</td>
                        <td class="text-end text-success" id="footMyEarned">0.00</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.myCommApp = {
            _table: null,
            init: function () {
                this._initGrid();
            },
            _initGrid: function () {
                this._table = $('#myCommGrid').DataTable({
                    ajax: async (data, callback) => {
                        try {
                            // The API automatically knows who is logged in via the JWT token!
                            const res = await api.get('/api/reporting/my-commissions');
                            callback({ data: res.data || res || [] });
                        } catch (e) { callback({ data: [] }); }
                    },
                    columns: [
                        { data: 'invoiceDate', className: 'ps-3 font-monospace' },
                        { data: 'invoiceNo', className: 'fw-bold text-dark font-monospace' },
                        { data: 'customerName', className: 'text-muted' },
                        { data: 'invoiceTotal', className: 'text-end', render: d => parseFloat(d||0).toLocaleString(undefined, { minimumFractionDigits: 2 }) },
                        { data: 'commissionAmount', className: 'text-end fw-bold text-primary', render: d => parseFloat(d||0).toLocaleString(undefined, { minimumFractionDigits: 2 }) },
                        {
                            data: 'status', className: 'text-center pe-3',
                            render: function (d) {
                                // Map the exact Enum names to visual badges
                                if (d === 'Unearned') return '<span class="badge bg-danger bg-opacity-10 text-danger border border-danger"><i class="fa-solid fa-hourglass-start me-1"></i> Waiting on Cust</span>';
                                if (d === 'PendingClearance') return '<span class="badge bg-warning bg-opacity-10 text-warning border border-warning"><i class="fa-solid fa-building-columns me-1"></i> Clearing</span>';
                                if (d === 'ReadyToPay') return '<span class="badge bg-success"><i class="fa-solid fa-money-bill-wave me-1"></i> Ready for Payroll</span>';
                                if (d === 'Paid') return '<span class="badge bg-dark"><i class="fa-solid fa-check me-1"></i> Paid Out</span>';
                                return `<span class="badge bg-secondary">${d}</span>`;
                            }
                        }
                    ],
                    order: [[0, 'desc']], // Sort by Date descending
                    dom: '<"d-flex justify-content-between align-items-center mb-3"f>rt<"d-flex justify-content-between align-items-center mt-3"ip>',
                    pageLength: 25,
                    footerCallback: function () {
                        let api = this.api();
                        // Only sum up rows where Status === 'ReadyToPay' for the footer total
                        let readyTotal = 0;
                        api.rows({ page: 'current' }).every(function () {
                            let data = this.data();
                            if (data.status === 'ReadyToPay') {
                                readyTotal += parseFloat(data.commissionAmount || 0);
                            }
                        });
                        $('#footMyEarned').html(readyTotal.toLocaleString(undefined, { minimumFractionDigits: 2 }));
                    }
                });
            }
        };
        $(document).ready(() => myCommApp.init());
    </script>
}