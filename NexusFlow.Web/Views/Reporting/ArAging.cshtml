@{
    ViewData["Title"] = "AR Aging Dashboard";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-clock-rotate-left text-warning me-2"></i>Accounts Receivable Aging</h4>
            <p class="text-muted mb-0 fs-14">Track overdue customer balances and dispatch payment reminders.</p>
        </div>
        <div>
            <button class="btn btn-success shadow-sm btn-sm px-3 fw-bold me-2" onclick="arApp.export('excel')">
                <i class="fa-solid fa-file-excel me-1"></i> Excel
            </button>
            <button class="btn btn-danger shadow-sm btn-sm px-3 fw-bold" onclick="arApp.export('pdf')">
                <i class="fa-solid fa-file-pdf me-1"></i> PDF
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-light">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-center fs-13">
                <div class="col-md-4">
                    <label class="form-label mb-0 fw-bold text-muted">Specific Customer</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterCustomer"></select>
                </div>
                <div class="col-md-8 text-end mt-4">
                    <button class="btn btn-sm btn-primary px-4 fw-bold shadow-sm" onclick="arApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Apply Filter</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="arGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary text-center">
                    <tr>
                        <th class="text-start ps-3">Customer</th>
                        <th class="text-end text-primary">Total Owed</th>
                        <th class="text-end">Current (Not Due)</th>
                        <th class="text-end">1 - 30 Days</th>
                        <th class="text-end">31 - 60 Days</th>
                        <th class="text-end">61 - 90 Days</th>
                        <th class="text-end text-danger">> 90 Days</th>
                        <th class="text-center pe-3">Action</th>
                    </tr>
                </thead>
                <tfoot class="bg-light fw-bold">
                    <tr>
                        <td class="text-end pe-3">Totals:</td>
                        <td class="text-end text-primary" id="footTotal">0.00</td>
                        <td class="text-end" id="footCurrent">0.00</td>
                        <td class="text-end" id="foot30">0.00</td>
                        <td class="text-end" id="foot60">0.00</td>
                        <td class="text-end" id="foot90">0.00</td>
                        <td class="text-end text-danger" id="footOver90">0.00</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/reporting/ar-aging.js" asp-append-version="true"></script>
}