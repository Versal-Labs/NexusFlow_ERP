@{
    ViewData["Title"] = "Inventory Analytics Cube";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-boxes-stacked text-primary me-2"></i>Inventory Analytics Cube</h4>
            <p class="text-muted mb-0 fs-14">Consolidated ledger for GRNs, Sales, Transfers, Adjustments, and Audits.</p>
        </div>
        <div>
            <button class="btn btn-success shadow-sm btn-sm px-3 fw-bold me-2" onclick="invApp.export('excel')">
                <i class="fa-solid fa-file-excel me-1"></i> Excel
            </button>
            <button class="btn btn-danger shadow-sm btn-sm px-3 fw-bold" onclick="invApp.export('pdf')">
                <i class="fa-solid fa-file-pdf me-1"></i> PDF
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-light">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-end fs-13">
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted">Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control shadow-sm" id="filterStartDate">
                        <span class="input-group-text bg-white border-start-0 border-end-0">to</span>
                        <input type="date" class="form-control shadow-sm" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1 fw-bold text-muted">Transaction Type</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterType">
                        <option value="">All Movements</option>
                        <option value="1">Receipt (GRN)</option>
                        <option value="2">Dispatch (Sale)</option>
                        <option value="3">Adjustment (+/-)</option>
                        <option value="4">Transfer (In/Out)</option>
                        <option value="5">Stock Take (Audit)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1 fw-bold text-muted">Warehouse</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterWarehouse"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted">Product Variant</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterProduct"></select>
                </div>
                <div class="col-md-2 text-end">
                    <button class="btn btn-sm btn-primary w-100 fw-bold shadow-sm" onclick="invApp.reloadGrid()"><i class="fa-solid fa-filter me-1"></i> Analyze</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="invGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary text-center">
                    <tr>
                        <th class="text-start ps-3">Date</th>
                        <th class="text-start">Type</th>
                        <th class="text-start">Ref No</th>
                        <th class="text-start">Warehouse</th>
                        <th class="text-start">Product (SKU)</th>
                        <th class="text-end">Net Qty</th>
                        <th class="text-end">Unit Cost</th>
                        <th class="text-end pe-3">Total Value</th>
                    </tr>
                </thead>
                <tfoot class="bg-light fw-bold">
                    <tr>
                        <td colspan="5" class="text-end pe-3 text-uppercase">Net Movement:</td>
                        <td class="text-end text-primary" id="footQty">0.00</td>
                        <td></td>
                        <td class="text-end text-primary pe-3" id="footValue">0.00</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/reporting/inventory-analytics.js" asp-append-version="true"></script>
}