@{
    ViewData["Title"] = "Treasury & Cheque Vault Analytics";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-money-check-dollar text-success me-2"></i>Cheque Vault Analytics</h4>
            <p class="text-muted mb-0 fs-14">Track PDC maturity, deposited statuses, and bounced cheque risks.</p>
        </div>
        <div>
            <button class="btn btn-success shadow-sm btn-sm px-3 fw-bold me-2" onclick="vaultApp.export('excel')">
                <i class="fa-solid fa-file-excel me-1"></i> Excel
            </button>
            <button class="btn btn-danger shadow-sm btn-sm px-3 fw-bold" onclick="vaultApp.export('pdf')">
                <i class="fa-solid fa-file-pdf me-1"></i> PDF
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-light">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-end fs-13">
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted">PDC Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control shadow-sm" id="filterStartDate">
                        <span class="input-group-text bg-white border-start-0 border-end-0">to</span>
                        <input type="date" class="form-control shadow-sm" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1 fw-bold text-muted">Cheque Status</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterStatus">
                        <option value="">All Statuses</option>
                        <option value="0">In Safe (Not Deposited)</option>
                        <option value="1">Deposited (Waiting Clear)</option>
                        <option value="2">Cleared (Realized)</option>
                        <option value="3">Bounced / Dishonored</option>
                        <option value="4">Returned to Customer</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted">Filter by Bank</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterBank"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1 fw-bold text-muted">Filter by Customer</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterCustomer"></select>
                </div>
                <div class="col-md-1 text-end">
                    <button class="btn btn-sm btn-primary w-100 fw-bold shadow-sm" onclick="vaultApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Go</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="vaultGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary text-center">
                    <tr>
                        <th class="text-start ps-3">Cheque No</th>
                        <th class="text-start">PDC Date</th>
                        <th class="text-start">Customer</th>
                        <th class="text-start">Bank & Branch</th>
                        <th class="text-end">Amount</th>
                        <th class="text-center">Status</th>
                        <th class="text-center pe-3">Maturity</th>
                    </tr>
                </thead>
                <tfoot class="bg-light fw-bold">
                    <tr>
                        <td colspan="4" class="text-end pe-3 text-uppercase">Report Total:</td>
                        <td class="text-end text-primary" id="footAmount">0.00</td>
                        <td colspan="2"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/reporting/cheque-vault-analytics.js" asp-append-version="true"></script>
}