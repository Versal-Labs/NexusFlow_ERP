@{
    ViewData["Title"] = "Customer Statement";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-file-invoice text-primary me-2"></i>Customer Statement</h4>
            <p class="text-muted mb-0 fs-14">Interactive running ledger of all invoices, payments, and credit notes.</p>
        </div>
        <div>
            <button class="btn btn-success shadow-sm btn-sm px-3 fw-bold me-2" onclick="statementApp.export('excel')" id="btnExcel" disabled>
                <i class="fa-solid fa-file-excel me-1"></i> Export Excel
            </button>
            <button class="btn btn-danger shadow-sm btn-sm px-3 fw-bold" onclick="statementApp.export('pdf')" id="btnPdf" disabled>
                <i class="fa-solid fa-file-pdf me-1"></i> Export PDF
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-light">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-center fs-13">
                <div class="col-md-4">
                    <label class="form-label mb-0 fw-bold text-muted">Customer <span class="text-danger">*</span></label>
                    <select class="form-select form-select-sm shadow-sm" id="filterCustomer"></select>
                </div>
                <div class="col-md-5">
                    <label class="form-label mb-0 fw-bold text-muted">Statement Period</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control shadow-sm" id="filterStartDate">
                        <span class="input-group-text bg-white border-start-0 border-end-0">to</span>
                        <input type="date" class="form-control shadow-sm" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-3 text-end mt-4">
                    <button class="btn btn-sm btn-primary px-4 fw-bold shadow-sm" onclick="statementApp.reloadGrid()"><i class="fa-solid fa-bolt me-1"></i> Generate</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="statementGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary text-center">
                    <tr>
                        <th class="text-start ps-3">Date</th>
                        <th class="text-start">Type</th>
                        <th class="text-start">Reference No</th>
                        <th class="text-start">Description</th>
                        <th class="text-end">Debit (Inv)</th>
                        <th class="text-end">Credit (Pay/CN)</th>
                        <th class="text-end pe-3 text-primary">Running Balance</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/reporting/customer-statement.js" asp-append-version="true"></script>
}