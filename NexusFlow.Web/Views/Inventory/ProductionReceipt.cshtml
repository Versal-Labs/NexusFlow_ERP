@{
    ViewData["Title"] = "Production Receipts";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-boxes-packing text-primary me-2"></i>Production Receipts</h4>
            <p class="text-muted mb-0 fs-14">Receive finished goods from subcontractors and auto-capitalize manufacturing costs.</p>
        </div>
        <button class="btn btn-primary shadow-sm btn-lg px-4 rounded-pill" onclick="window.receiptApp.openCreateModal()">
            <i class="fa-solid fa-plus me-2"></i>New Receipt
        </button>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <table id="receiptsGrid" class="table table-hover table-striped align-middle mb-0 w-100 fs-13">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-4">Receipt #</th>
                        <th>Date</th>
                        <th>Finished Good</th>
                        <th class="text-center">Qty Received</th>
                        <th class="text-end">Total Capitalized Cost</th>
                        <th class="text-end">Unit Cost</th>
                        <th class="text-center pe-4">Status</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="receiptModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-light">
            <div class="modal-header bg-white border-bottom shadow-sm py-2">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-clipboard-check text-primary me-2"></i>Post Job Work Receipt</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-4">
                <form id="receiptForm">
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-header bg-white py-3">
                            <h6 class="mb-0 fw-bold text-primary"><i class="fa-solid fa-link me-2"></i>Link to Material Issue</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold fs-13 mb-1">Issue Note Ref # <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="issueReferenceNo" placeholder="e.g., MIN-0001" required>
                                    <div class="form-text fs-12">Required to pull Work-In-Progress RM Costs.</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold fs-13 mb-1">Receipt Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" id="receiptDate" required>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold fs-13 mb-1">Finished Good Received <span class="text-danger">*</span></label>
                                    <select class="form-select select2" id="finishedGoodId" required style="width: 100%;"></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold fs-13 mb-1">Destination Warehouse <span class="text-danger">*</span></label>
                                    <select class="form-select" id="warehouseId" required></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold fs-13 mb-1">Batch Number (Optional)</label>
                                    <input type="text" class="form-control" id="batchNo" placeholder="Leave blank to auto-generate">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold fs-13 mb-1 text-success">Quantity Received <span class="text-danger">*</span></label>
                                    <input type="number" class="form-control fw-bold" id="quantityReceived" min="1" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold fs-13 mb-1 text-danger">Subcontractor Labor Bill <span class="text-danger">*</span></label>
                                    <input type="number" class="form-control fw-bold" id="subcontractorCharge" step="0.01" min="0" required>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            
            <div class="modal-footer bg-white border-top shadow-sm py-2">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4 fw-bold" id="btnSaveReceipt">
                    <i class="fa-solid fa-check me-2"></i> Post Receipt & GL
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/inventory/production-receipt.js" asp-append-version="true"></script>
}