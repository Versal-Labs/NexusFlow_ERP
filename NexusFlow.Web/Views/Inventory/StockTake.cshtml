@{
    ViewData["Title"] = "Physical Stock Take";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-clipboard-check text-primary me-2"></i>Physical Stock Take</h4>
            <p class="text-muted mb-0 fs-14">Initiate blind counts, submit physical quantities, and reconcile variances.</p>
        </div>
        <button class="btn btn-primary shadow-sm" onclick="stockTakeApp.openInitiateModal()">
            <i class="fa-solid fa-play me-2"></i>Start New Count
        </button>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <table id="stockTakeGrid" class="table table-hover table-striped align-middle mb-0 w-100 fs-13">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-4">Batch #</th>
                        <th>Date</th>
                        <th>Warehouse</th>
                        <th class="text-center">Status</th>
                        <th class="text-end">Net Variance Value</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="initiateModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-bottom">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-play text-primary me-2"></i>Initiate Stock Take</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="initiateForm">
                    <div class="mb-3">
                        <label class="form-label fw-bold mb-1">Target Warehouse <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm" id="WarehouseId" required></select>
                        <div class="form-text">This will snapshot current inventory levels for variance calculations.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold mb-1">Notes</label>
                        <textarea class="form-control form-control-sm" id="Notes" rows="2" placeholder="e.g., Q3 Annual Audit"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light border-top p-3">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm" onclick="stockTakeApp.submitInitiate()">Generate Count Sheet</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="countModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-warning text-dark py-3">
                <h5 class="modal-title fw-bold fs-6"><i class="fa-solid fa-clipboard-list me-2"></i>Guided Physical Count</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 bg-light">
                <input type="hidden" id="CountStockTakeId" />

                <div class="p-3 bg-white border-bottom d-flex justify-content-between align-items-center sticky-top" style="z-index: 10;">
                    <div class="input-group input-group-sm w-50 shadow-sm">
                        <span class="input-group-text bg-white"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" id="searchCountItems" placeholder="Search product name or SKU...">
                    </div>
                    <span class="badge bg-dark fs-6 shadow-sm" id="lblCountProgress">0 Items Total</span>
                </div>

                <div class="table-responsive" style="max-height: 55vh;">
                    <table class="table table-sm table-hover align-middle mb-0 fs-13" id="countTable">
                        <thead class="table-light shadow-sm" style="position: sticky; top: 0; z-index: 5;">
                            <tr>
                                <th class="ps-3">Product Description / SKU</th>
                                <th class="text-center" style="width: 15%">System Qty</th>
                                <th class="text-center" style="width: 15%">Physical Count</th>
                                <th class="text-center" style="width: 15%">Live Variance</th>
                            </tr>
                        </thead>
                        <tbody id="countBody">
                        </tbody>
                    </table>
                </div>
                <div class="p-3 bg-white border-top">
                    <p class="text-muted fs-12 mb-0 fw-bold">
                        <i class="fa-solid fa-circle-info text-primary me-1"></i>
                        Inputs are pre-filled with the System Quantity. Use the search bar to find the specific items you need to correct. Unchanged items will be submitted with zero variance.
                    </p>
                </div>
            </div>
            <div class="modal-footer bg-light border-top p-3">
                <button type="button" class="btn btn-secondary btn-sm px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success btn-sm px-4 shadow-sm fw-bold" onclick="stockTakeApp.submitCount()">
                    <i class="fa-solid fa-paper-plane me-1"></i> Submit Count for Review
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="approveModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-scale-balanced me-2"></i>Variance Reconciliation</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 bg-light">
                <input type="hidden" id="ApproveStockTakeId" />
                <div class="table-responsive" style="max-height: 60vh;">
                    <table class="table table-sm table-hover align-middle mb-0 fs-13">
                        <thead class="table-light sticky-top shadow-sm">
                            <tr>
                                <th class="ps-3">Product</th>
                                <th class="text-center">System Qty</th>
                                <th class="text-center bg-warning bg-opacity-25">Counted Qty</th>
                                <th class="text-center">Variance</th>
                                <th class="text-end pe-3">Financial Impact</th>
                            </tr>
                        </thead>
                        <tbody id="approveBody">
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer bg-white border-top p-3 d-flex justify-content-between align-items-center">
                <div class="fs-5 text-dark">
                    Net Impact: <span id="lblNetImpact" class="fw-bold font-monospace">0.00</span>
                </div>
                <div>
                    <button type="button" class="btn btn-light border btn-sm px-4 me-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger btn-sm px-4 shadow-sm fw-bold" onclick="stockTakeApp.approveCount()">
                        <i class="fa-solid fa-lock me-2"></i>Approve & Adjust GL
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/inventory/stock-take.js" asp-append-version="true"></script>
}