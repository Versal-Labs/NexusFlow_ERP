@{
    ViewData["Title"] = "Stock Valuation (FIFO)";
}

<div class="container-fluid py-3 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-chart-pie text-success me-2"></i>Stock Valuation</h4>
            <p class="text-muted mb-0 fs-14">Real-time inventory asset valuation based on strict FIFO cost layering.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-white">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-center fs-13">
                <div class="col-md-3">
                    <label class="form-label mb-0 fw-bold text-muted">Warehouse</label>
                    <select class="form-select form-select-sm" id="filterWarehouse">
                        <option value="">All Warehouses</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-0 fw-bold text-muted">Item Category</label>
                    <select class="form-select form-select-sm" id="filterCategory">
                        <option value="">All Categories</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label mb-0 fw-bold text-muted">Search Item</label>
                    <input type="text" class="form-control form-control-sm" id="filterSearch" placeholder="SKU or Product Name...">
                </div>
                <div class="col-md-2 text-end mt-4">
                    <button class="btn btn-sm btn-primary w-100 shadow-sm fw-bold" onclick="valApp.reloadGrid()">
                        <i class="fa-solid fa-filter me-1"></i> Apply Filters
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-3 g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body d-flex justify-content-between align-items-center p-3">
                    <div>
                        <h6 class="mb-1 opacity-75 text-uppercase fw-bold" style="font-size: 11px;">Total Inventory Value</h6>
                        <h3 class="mb-0 fw-bold font-monospace" id="lblTotalValue">$0.00</h3>
                    </div>
                    <i class="fa-solid fa-sack-dollar fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-dark text-white h-100">
                <div class="card-body d-flex justify-content-between align-items-center p-3">
                    <div>
                        <h6 class="mb-1 opacity-75 text-uppercase fw-bold" style="font-size: 11px;">Total Units in Stock</h6>
                        <h3 class="mb-0 fw-bold font-monospace" id="lblTotalUnits">0</h3>
                    </div>
                    <i class="fa-solid fa-boxes-stacked fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="valuationGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th>Warehouse</th>
                        <th>Category</th>
                        <th>SKU</th>
                        <th>Product Description</th>
                        <th class="text-end">On Hand Qty</th>
                        <th class="text-end">Blended Cost</th>
                        <th class="text-end pe-3">Total Asset Value</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/inventory/stock-valuation.js" asp-append-version="true"></script>
}