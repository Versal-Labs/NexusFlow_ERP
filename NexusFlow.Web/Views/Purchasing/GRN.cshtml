@{
    ViewData["Title"] = "Goods Receipt Notes (GRN)";
}

@section Styles {
    <style>
        .dataTables_filter { text-align: left !important; }
        .dataTables_filter label { width: 100%; display: flex; align-items: center; }
        .dataTables_filter input { margin-left: 10px; width: auto; flex-grow: 1; max-width: 300px; }
        .select2-container { width: 100% !important; }
    </style>
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-truck-ramp-box text-primary me-2"></i>Goods Receipt (GRN)</h4>
            <p class="text-muted mb-0 fs-14">Receive physical inventory against approved Purchase Orders.</p>
        </div>
        <button class="btn btn-primary btn-sm shadow-sm fw-bold px-3" onclick="grnApp.openModal()">
            <i class="fa-solid fa-plus me-1"></i> Receive Goods
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-light">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-center fs-13">
                <div class="col-md-3">
                    <label class="form-label mb-0 fw-bold text-muted">Supplier</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterSupplier"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-0 fw-bold text-muted">Warehouse</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterWarehouse"></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label mb-0 fw-bold text-muted">Receipt Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control" id="filterStartDate">
                        <span class="input-group-text">to</span>
                        <input type="date" class="form-control" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-2 text-end mt-4">
                    <button class="btn btn-sm btn-outline-secondary me-1 fw-bold" onclick="window.grnApp.resetFilters()"><i class="fa-solid fa-eraser"></i> Clear</button>
                    <button class="btn btn-sm btn-primary px-3 fw-bold" onclick="window.grnApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Apply</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="grnGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th>GRN #</th>
                        <th>PO #</th>
                        <th>Receipt Date</th>
                        <th>Supplier</th>
                        <th>Warehouse</th>
                        <th>Supplier Ref</th>
                        <th class="text-end">Total Value</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="grnModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light">
                <h5 class="modal-title fs-6 fw-bold"><i class="fa-solid fa-boxes-packing text-primary me-2"></i>New Goods Receipt</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body fs-13 p-4">
                <form id="grnForm">
                    <div class="row g-3 mb-4 pb-4 border-bottom">
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-1">Link to Purchase Order <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm select2" id="PurchaseOrderId" required style="width:100%"></select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold mb-1">Destination Warehouse <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm" id="WarehouseId" required></select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold mb-1">Receipt Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control form-control-sm" id="DateReceived" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold mb-1">Supplier Ref (Delivery Note)</label>
                            <input type="text" class="form-control form-control-sm font-monospace" id="SupplierInvoiceNo" placeholder="e.g. DEL-88901">
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="text-primary mb-0 fw-bold"><i class="fa-solid fa-list-check me-2"></i>Items to Receive</h6>
                        <span class="badge bg-warning text-dark px-3 py-2" id="poStatusBadge" style="display:none;"></span>
                    </div>

                    <div class="table-responsive mb-4 border rounded">
                        <table class="table table-sm table-bordered align-middle mb-0" id="linesTable">
                            <thead class="table-light text-center">
                                <tr>
                                    <th style="width: 35%" class="text-start">Product / Variant</th>
                                    <th style="width: 10%">Ordered</th>
                                    <th style="width: 10%">Rcvd So Far</th>
                                    <th style="width: 15%" class="bg-primary bg-opacity-10 border-primary">Receive Now <span class="text-danger">*</span></th>
                                    <th style="width: 15%">Unit Cost</th>
                                    <th style="width: 15%" class="text-end">Line Total</th>
                                </tr>
                            </thead>
                            <tbody id="linesBody">
                                <tr><td colspan="6" class="text-center text-muted fst-italic py-4">Select a Purchase Order to load items.</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="row justify-content-end">
                        <div class="col-md-4">
                            <div class="bg-light p-3 border rounded shadow-sm d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-muted">Total Receipt Value:</span>
                                <span class="fs-5 fw-bold text-dark font-monospace" id="lblGrandTotal">Rs. 0.00</span>
                                <input type="hidden" id="TotalAmount" value="0">
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-3 border-top">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm fw-bold" onclick="grnApp.save(event)">
                    <i class="fa-solid fa-check-double me-1"></i> Post GRN & Receive Stock
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="grnViewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-light">
            <div class="modal-header bg-dark text-white py-2 d-flex justify-content-between align-items-center">
                <h5 class="modal-title fw-bold mb-0 fs-6"><i class="fa-solid fa-file-signature me-2"></i>Goods Receipt Note</h5>
                <div>
                    <button class="btn btn-sm btn-light text-dark me-1 fw-bold" onclick="window.print()" title="Export PDF"><i class="fa-solid fa-print me-1"></i> Print</button>
                    <button class="btn btn-sm btn-success me-1 fw-bold text-dark" id="btnModalCreateBill" title="Create Supplier Bill"><i class="fa-solid fa-file-invoice-dollar me-1"></i> Create Bill</button>
                    <button type="button" class="btn-close btn-close-white ms-2" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body p-0">
                <div class="bg-white p-5 m-3 shadow-sm border rounded" id="printableArea" style="min-height: 500px;">
                    <div class="row border-bottom pb-4 mb-4">
                        <div class="col-6">
                            <h2 class="fw-bold text-dark mb-0">RECEIPT (GRN)</h2>
                            <h5 class="text-muted font-monospace" id="docGrnNo">GRN-0000</h5>
                            <span class="badge bg-success">Posted to Inventory</span>
                        </div>
                        <div class="col-6 text-end">
                            <h3 class="fw-bold text-primary mb-0" id="docTotalLarge">$0.00</h3>
                            <div class="text-muted fs-13 text-uppercase fw-bold">Total Receipt Value</div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-6">
                            <h6 class="fw-bold text-muted mb-1 fs-12 text-uppercase">Supplier:</h6>
                            <div class="fs-15 fw-bold text-dark" id="docSupplier"></div>
                            <div class="fs-13 text-muted mt-2"><strong>Target Warehouse:</strong> <span id="docWarehouse"></span></div>
                        </div>
                        <div class="col-6 text-end fs-13">
                            <div><strong>Receipt Date:</strong> <span id="docDate"></span></div>
                            <div><strong>Linked PO:</strong> <span id="docPoNo" class="fw-bold text-primary font-monospace"></span></div>
                            <div><strong>Supplier Ref:</strong> <span id="docRefNo"></span></div>
                        </div>
                    </div>
                    <table class="table table-sm table-bordered align-middle fs-13 mb-4">
                        <thead class="table-light text-secondary text-center">
                            <tr>
                                <th class="text-start">Product / SKU</th>
                                <th style="width: 15%">Qty Received</th>
                                <th class="text-end" style="width: 20%">Unit Cost</th>
                                <th class="text-end" style="width: 20%">Total Value</th>
                            </tr>
                        </thead>
                        <tbody id="docItemsBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer bg-light border-top shadow-sm py-2">
                <button type="button" class="btn btn-secondary btn-sm px-4 fw-bold" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/purchasing/grn.js" asp-append-version="true"></script>
}