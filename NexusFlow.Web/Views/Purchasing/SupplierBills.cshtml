@{
    ViewData["Title"] = "Supplier Bills (AP)";
}

@section Styles {
    <style>
        .dataTables_filter { text-align: left !important; }
        .dataTables_filter label { width: 100%; display: flex; align-items: center; }
        .dataTables_filter input { margin-left: 10px; width: auto; flex-grow: 1; max-width: 300px; }
        .select2-container { width: 100% !important; }
    </style>
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-file-invoice-dollar text-primary me-2"></i>Supplier Bills (AP)</h4>
            <p class="text-muted mb-0 fs-14">Record vendor invoices, clear GRN liabilities, and post direct expenses.</p>
        </div>
        <button class="btn btn-primary btn-sm shadow-sm fw-bold px-3" onclick="billApp.openModal()">
            <i class="fa-solid fa-plus me-1"></i> Enter Bill
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-light">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-center fs-13">
                <div class="col-md-3">
                    <label class="form-label mb-0 fw-bold text-muted">Supplier</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterSupplier"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-0 fw-bold text-muted">Payment Status</label>
                    <select class="form-select form-select-sm shadow-sm" id="filterStatus">
                        <option value="">All Statuses</option>
                        <option value="Unpaid">Open (Unpaid)</option>
                        <option value="Partial">Partially Paid</option>
                        <option value="Paid">Paid in Full</option>
                        <option value="Draft">Drafts</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label mb-0 fw-bold text-muted">Bill Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control" id="filterStartDate">
                        <span class="input-group-text">to</span>
                        <input type="date" class="form-control" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-2 text-end mt-4">
                    <button class="btn btn-sm btn-outline-secondary me-1 fw-bold" onclick="window.billApp.resetFilters()"><i class="fa-solid fa-eraser"></i> Clear</button>
                    <button class="btn btn-sm btn-primary px-3 fw-bold" onclick="window.billApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Apply</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="billGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th>Bill #</th>
                        <th>Bill Date</th>
                        <th>Due Date</th>
                        <th>Supplier</th>
                        <th>Vendor Ref</th>
                        <th class="text-end">Grand Total</th>
                        <th class="text-end">Paid</th>
                        <th class="text-end">Balance</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="billModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fs-6 fw-bold" id="billModalTitle"><i class="fa-solid fa-file-invoice-dollar text-success me-2"></i>New Supplier Bill</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body fs-13 p-4">
                <form id="billForm">
                    <input type="hidden" id="BillId" value="0" />
                    <div class="row g-3 mb-4 pb-4 border-bottom">
                        <div class="col-md-5">
                            <label class="form-label fw-bold mb-1">Supplier <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm select2" id="SupplierId" required style="width:100%"></select>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label fw-bold mb-1 text-primary"><i class="fa-solid fa-link me-1"></i>Link to Unbilled GRNs</label>
                            <select class="form-select form-select-sm select2" id="LinkedGrnIds" multiple="multiple" style="width:100%"></select>
                            <div class="form-text small text-muted">Select GRNs to auto-populate the bill. Only unbilled GRNs are shown.</div>
                        </div>
                        <div class="col-md-3 mt-3">
                            <label class="form-label fw-bold mb-1">Vendor Invoice # <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-sm font-monospace fw-bold" id="SupplierInvoiceNo" required>
                        </div>
                        <div class="col-md-3 mt-3">
                            <label class="form-label fw-bold mb-1">Bill Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control form-control-sm" id="BillDate" required>
                        </div>
                        <div class="col-md-3 mt-3">
                            <label class="form-label fw-bold mb-1">Due Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control form-control-sm" id="DueDate" required>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="text-primary mb-0 fw-bold"><i class="fa-solid fa-list me-2"></i>Bill Lines</h6>
                        <button type="button" class="btn btn-sm btn-outline-dark bg-light shadow-sm fw-bold border" onclick="billApp.addLine()">
                            <i class="fa-solid fa-plus text-success me-1"></i> Add Direct Expense
                        </button>
                    </div>

                    <div class="table-responsive mb-4 border rounded" style="min-height: 200px; overflow: visible;">
                        <table class="table table-sm table-bordered align-middle mb-0" id="linesTable">
                            <thead class="table-light text-center text-secondary">
                                <tr>
                                    <th style="width: 15%">Line Type</th>
                                    <th style="width: 30%">Item / Account</th>
                                    <th style="width: 20%">Description</th>
                                    <th style="width: 10%">Qty</th>
                                    <th style="width: 10%">Unit Price</th>
                                    <th style="width: 10%" class="text-end">Line Total</th>
                                    <th style="width: 5%"></th>
                                </tr>
                            </thead>
                            <tbody id="linesBody"></tbody>
                        </table>
                    </div>

                    <div class="row">
                        <div class="col-md-7">
                            <label class="form-label fw-bold mb-1">Remarks</label>
                            <textarea class="form-control form-control-sm mb-3" id="Remarks" rows="2"></textarea>
                            <div class="form-check form-switch p-3 bg-light border rounded d-inline-block">
                                <input class="form-check-input ms-0 me-2 mt-1 calc-trigger" type="checkbox" id="ApplyVat" checked style="cursor:pointer">
                                <label class="form-check-label fw-bold" for="ApplyVat" style="cursor:pointer">Apply Input VAT (18%)</label>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="bg-light p-3 border rounded shadow-sm">
                                <div class="d-flex justify-content-between mb-2"><span class="fw-bold text-muted">Sub Total:</span><span class="font-monospace fs-6" id="lblSubTotal">0.00</span></div>
                                <div class="d-flex justify-content-between mb-2" id="vatRow"><span class="fw-bold text-muted">Input VAT:</span><span class="font-monospace text-danger" id="lblTax">+ 0.00</span></div>
                                <hr class="my-2 border-secondary">
                                <div class="d-flex justify-content-between fs-5 text-dark mt-2"><span class="fw-bold">Grand Total:</span><span class="font-monospace fw-bold text-primary" id="lblGrandTotal">0.00</span></div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-3 border-top">
                <button type="button" class="btn btn-secondary btn-sm px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                <div class="ms-auto">
                    <button type="button" class="btn btn-warning btn-sm px-4 shadow-sm me-2 text-dark fw-bold" onclick="billApp.save(true)">
                        <i class="fa-solid fa-file-pen me-1"></i> Save Draft
                    </button>
                    <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm fw-bold" onclick="billApp.save(false)">
                        <i class="fa-solid fa-check-double me-1"></i> Post to AP Ledger
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="billViewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-light">
            <div class="modal-header bg-dark text-white py-2 d-flex justify-content-between align-items-center">
                <h5 class="modal-title fw-bold mb-0 fs-6"><i class="fa-solid fa-magnifying-glass-chart me-2"></i>Bill Details</h5>
                <div>
                    <button class="btn btn-sm btn-light text-dark me-1 fw-bold" onclick="window.print()" title="Export PDF"><i class="fa-solid fa-print me-1"></i> Print</button>
                    <button class="btn btn-sm btn-success me-1 fw-bold text-dark" id="btnModalPay" title="Record Payment"><i class="fa-solid fa-money-bill-transfer me-1"></i> Pay Bill</button>
                    <button type="button" class="btn-close btn-close-white ms-2" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body p-0">
                <div class="bg-white p-5 m-3 shadow-sm border rounded" id="printableArea" style="min-height: 500px;">
                    <div class="row border-bottom pb-4 mb-4">
                        <div class="col-6">
                            <h2 class="fw-bold text-dark mb-0">SUPPLIER BILL</h2>
                            <h5 class="text-muted font-monospace" id="docBillNo">BILL-0000</h5>
                            <small class="text-muted fw-bold">Vendor Ref: <span id="docRefNo" class="text-dark"></span></small>
                        </div>
                        <div class="col-6 text-end">
                            <h3 class="fw-bold text-danger mb-0" id="docBalanceDueLarge">$0.00</h3>
                            <div class="text-muted fs-13 text-uppercase fw-bold">Balance Due</div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-6">
                            <h6 class="fw-bold text-muted mb-1 fs-12 text-uppercase">Vendor:</h6>
                            <div class="fs-15 fw-bold text-dark" id="docSupplier"></div>
                        </div>
                        <div class="col-6 text-end fs-13">
                            <div><strong>Bill Date:</strong> <span id="docDate"></span></div>
                            <div><strong>Due Date:</strong> <span id="docDueDate" class="fw-bold text-danger"></span></div>
                        </div>
                    </div>
                    <table class="table table-sm table-bordered align-middle fs-13 mb-4">
                        <thead class="table-light text-secondary text-center">
                            <tr>
                                <th class="text-start">Description / Item</th>
                                <th style="width: 10%">Qty</th>
                                <th class="text-end" style="width: 15%">Rate</th>
                                <th class="text-end" style="width: 20%">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="docItemsBody"></tbody>
                    </table>
                    <div class="row mt-4">
                        <div class="col-7">
                            <h6 class="fw-bold text-muted mb-1 fs-12 text-uppercase">Remarks</h6>
                            <div class="text-dark fs-13 bg-light p-2 rounded border" style="min-height: 60px;" id="docNotes">-</div>
                        </div>
                        <div class="col-5">
                            <table class="table table-sm table-borderless text-end fs-14 mb-0">
                                <tr><td class="text-muted">Subtotal</td><td class="fw-bold" id="docSubtotal">0.00</td></tr>
                                <tr><td class="text-muted border-bottom">Tax (VAT)</td><td class="fw-bold border-bottom text-danger" id="docTax">0.00</td></tr>
                                <tr><td class="text-dark fw-bold fs-5">Grand Total</td><td class="text-dark fw-bold fs-5 text-primary" id="docTotal">0.00</td></tr>
                                <tr><td class="text-success pb-2 border-bottom">Amount Paid</td><td class="text-success pb-2 border-bottom" id="docPaid">-0.00</td></tr>
                                <tr><td class="text-danger fw-bold fs-5">Balance Due</td><td class="text-danger fw-bold fs-5" id="docBalanceDue">0.00</td></tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light border-top shadow-sm py-2">
                <button type="button" class="btn btn-secondary btn-sm px-4 fw-bold" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/purchasing/supplier-bills.js" asp-append-version="true"></script>
}