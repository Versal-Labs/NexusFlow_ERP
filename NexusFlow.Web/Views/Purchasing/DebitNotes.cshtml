@{
    ViewData["Title"] = "Debit Notes (Purchase Returns)";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-truck-ramp-box text-primary me-2"></i>Debit Notes (Returns)</h4>
            <p class="text-muted mb-0 fs-14">View supplier returns, AP reversals, and strict FIFO inventory deductions.</p>
        </div>
        <a href="/Purchasing/SupplierBills" class="btn btn-outline-primary btn-sm shadow-sm"><i class="fa-solid fa-file-invoice-dollar me-1"></i> Go to AP Bills to Process Return</a>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-white">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-center fs-13">
                <div class="col-md-4">
                    <label class="form-label mb-0 fw-bold text-muted">Supplier</label>
                    <select class="form-select form-select-sm select2" id="filterSupplier">
                        <option value="">All Suppliers</option>
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label mb-0 fw-bold text-muted">Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control" id="filterStartDate">
                        <span class="input-group-text bg-light border-0">to</span>
                        <input type="date" class="form-control" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-3 text-end mt-4">
                    <button class="btn btn-sm btn-light border me-1 shadow-sm" onclick="dnApp.resetFilters()"><i class="fa-solid fa-rotate-right"></i> Reset</button>
                    <button class="btn btn-sm btn-primary px-3 shadow-sm" onclick="dnApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Apply Filters</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="dnGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-3">DN Number</th>
                        <th>Date</th>
                        <th>Supplier</th>
                        <th class="text-end">AP Reversed Amount</th>
                        <th class="text-center pe-3">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="viewDnModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-light border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2 d-flex justify-content-between align-items-center">
                <h5 class="modal-title fw-bold mb-0"><i class="fa-solid fa-magnifying-glass-chart me-2"></i>Debit Note Details</h5>
                <div>
                    <button class="btn btn-sm btn-light text-dark me-2 shadow-sm" id="btnModalPrint"><i class="fa-solid fa-print me-1"></i> Print</button>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
            </div>
            
            <div class="modal-body p-0">
                <div class="bg-white p-5 m-3 shadow-sm border" style="min-height: 500px;">
                    <div class="row border-bottom pb-4 mb-4">
                        <div class="col-6">
                            <h2 class="fw-bold text-dark mb-0">DEBIT NOTE</h2>
                            <h5 class="text-muted font-monospace" id="docDnNo">DN-0000</h5>
                        </div>
                        <div class="col-6 text-end">
                            <h3 class="fw-bold text-primary mb-0" id="docTotalLarge">$0.00</h3>
                            <div class="text-muted fs-13 text-uppercase">Total AP Liability Reversal</div>
                        </div>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-6">
                            <h6 class="fw-bold text-muted mb-1 fs-12 text-uppercase">Sent To (Supplier):</h6>
                            <div class="fs-15 fw-bold text-dark" id="docSupplier"></div>
                        </div>
                        <div class="col-6 text-end fs-13">
                            <div><strong>Date Issued:</strong> <span id="docDate"></span></div>
                        </div>
                    </div>

                    <table class="table table-sm table-bordered align-middle fs-13 mb-4">
                        <thead class="table-light text-secondary text-center">
                            <tr>
                                <th class="text-start">Returned Item</th>
                                <th style="width: 15%">SKU</th>
                                <th style="width: 10%">Qty</th>
                                <th class="text-end" style="width: 15%">Unit Rate</th>
                                <th class="text-end" style="width: 15%">Total</th>
                            </tr>
                        </thead>
                        <tbody id="docItemsBody"></tbody>
                    </table>
                    
                    <div class="row">
                        <div class="col-7">
                            <h6 class="fw-bold text-muted mb-1 fs-12 text-uppercase">RMA Reason</h6>
                            <div class="text-dark fs-13 bg-light p-2 rounded border border-warning" id="docReason">-</div>
                        </div>
                        <div class="col-5 text-end">
                            <table class="table table-sm table-borderless fs-14 mb-0">
                                <tr><td class="text-muted">Subtotal</td><td class="fw-bold" id="docSubtotal">0.00</td></tr>
                                <tr><td class="text-muted border-bottom">Tax Reversal</td><td class="fw-bold border-bottom" id="docTax">0.00</td></tr>
                                <tr><td class="text-primary fw-bold fs-5">Total AP Credit</td><td class="text-primary fw-bold fs-5" id="docTotal">0.00</td></tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/purchasing/debit-notes.js" asp-append-version="true"></script>
}