@{
    ViewData["Title"] = "Purchase Orders";
}

@section Styles {
    <style>
        .dataTables_filter { text-align: left !important; }
        .dataTables_filter label { width: 100%; display: flex; align-items: center; }
        .dataTables_filter input { margin-left: 10px; width: auto; flex-grow: 1; max-width: 300px; }
        .select2-container { width: 100% !important; }
    </style>
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-file-contract text-primary me-2"></i>Purchase Orders</h4>
            <p class="text-muted mb-0 fs-14">Manage procurement contracts, raw material sourcing, and pending receipts.</p>
        </div>
        <button class="btn btn-primary shadow-sm btn-sm px-3 fw-bold" onclick="window.poApp.openCreateModal()">
            <i class="fa-solid fa-plus me-1"></i> Create PO
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3 bg-white">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-center fs-13">
                <div class="col-md-3">
                    <label class="form-label mb-0 fw-bold text-muted">Supplier</label>
                    <select class="form-select form-select-sm" id="filterSupplier"></select>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-0 fw-bold text-muted">Status</label>
                    <select class="form-select form-select-sm" id="filterStatus">
                        <option value="">All Statuses</option>
                        <option value="1">Draft</option>
                        <option value="2">Approved</option>
                        <option value="6">Partial Receipt</option>
                        <option value="3">Fully Received</option>
                        <option value="4">Closed</option>
                        <option value="5">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label mb-0 fw-bold text-muted">Order Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control" id="filterStartDate">
                        <span class="input-group-text">to</span>
                        <input type="date" class="form-control" id="filterEndDate">
                    </div>
                </div>
                <div class="col-md-3 text-end mt-4">
                    <button class="btn btn-sm btn-outline-secondary me-1 fw-bold" onclick="window.poApp.resetFilters()"><i class="fa-solid fa-eraser"></i> Clear</button>
                    <button class="btn btn-sm btn-primary px-3 fw-bold" onclick="window.poApp.reloadGrid()"><i class="fa-solid fa-filter"></i> Apply</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <table id="poGrid" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th>PO Number</th>
                        <th>Date</th>
                        <th>Supplier</th>
                        <th>Status</th>
                        <th class="text-end">Amount</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="poModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fs-6 fw-bold"><i class="fa-solid fa-file-contract text-primary me-2"></i>New Purchase Order</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body fs-13 p-4 bg-white">
                <form id="frmPO">
                    <input type="hidden" id="Id" value="0" />
                    <div class="row g-3 border-bottom pb-4 mb-4">
                        <div class="col-md-2">
                            <label class="form-label fw-bold mb-1">PO Number</label>
                            <input type="text" class="form-control form-control-sm font-monospace text-primary fw-bold" value="[Auto-Generated]" readonly disabled>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-1">Supplier <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm select2" id="SupplierId" required></select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold mb-1">Order Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control form-control-sm" id="Date" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold mb-1">Expected Delivery (ETA)</label>
                            <input type="date" class="form-control form-control-sm" id="ExpectedDate">
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="text-primary mb-0 fw-bold"><i class="fa-solid fa-boxes-packing me-2"></i>Order Items (Raw Materials Only)</h6>
                        <button type="button" class="btn btn-sm btn-outline-dark bg-light shadow-sm fw-bold border" onclick="poApp.addLine()">
                            <i class="fa-solid fa-plus text-success me-1"></i> Add Material
                        </button>
                    </div>

                    <div class="table-responsive mb-4 border rounded" style="overflow: visible;">
                        <table class="table table-sm table-bordered align-middle mb-0" id="tblPoItems">
                            <thead class="table-light text-center text-secondary">
                                <tr>
                                    <th style="width: 45%" class="text-start">Raw Material / SKU</th>
                                    <th style="width: 20%">Quantity required</th>
                                    <th style="width: 15%">Unit Cost</th>
                                    <th style="width: 15%" class="text-end">Line Total</th>
                                    <th style="width: 5%"></th>
                                </tr>
                            </thead>
                            <tbody id="poItemsBody"></tbody>
                            <tfoot class="bg-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold fs-6 pt-2 pb-2">Grand Total:</td>
                                    <td class="text-end fw-bold fs-5 text-primary pt-2 pb-2" id="lblGrandTotal">0.00</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <label class="form-label fw-bold mb-1">Internal Notes & Terms</label>
                            <textarea class="form-control form-control-sm" id="Note" rows="2" placeholder="Add specific terms, shipping notes, or warehouse instructions here..."></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-3 border-top">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <div class="ms-auto">
                    <button type="button" class="btn btn-warning btn-sm px-4 shadow-sm me-2 fw-bold text-dark" onclick="poApp.savePO(true)">
                        <i class="fa-solid fa-file-pen me-1"></i> Save as Draft
                    </button>
                    <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm fw-bold" onclick="poApp.savePO(false)">
                        <i class="fa-solid fa-check-double me-1"></i> Confirm & Approve
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="poViewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-light">
            <div class="modal-header bg-dark text-white py-2 d-flex justify-content-between align-items-center">
                <h5 class="modal-title fw-bold mb-0 fs-6"><i class="fa-solid fa-magnifying-glass-chart me-2"></i>Purchase Order Details</h5>
                <div>
                    <button class="btn btn-sm btn-light text-dark me-1 fw-bold" onclick="window.print()" title="Export PDF"><i class="fa-solid fa-print me-1"></i> Print</button>
                    <button type="button" class="btn-close btn-close-white ms-2" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body p-0">
                <div class="bg-white p-5 m-3 shadow-sm border rounded" id="printableArea" style="min-height: 500px;">
                    <div class="row border-bottom pb-4 mb-4">
                        <div class="col-6">
                            <h2 class="fw-bold text-dark mb-0">PURCHASE ORDER</h2>
                            <h5 class="text-muted font-monospace" id="docPoNo">PO-0000</h5>
                            <span class="badge" id="docStatusBadge"></span>
                        </div>
                        <div class="col-6 text-end">
                            <h3 class="fw-bold text-primary mb-0" id="docTotalLarge">$0.00</h3>
                            <div class="text-muted fs-13 text-uppercase fw-bold">Order Total</div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-6">
                            <h6 class="fw-bold text-muted mb-1 fs-12 text-uppercase">Vendor:</h6>
                            <div class="fs-15 fw-bold text-dark" id="docSupplier"></div>
                        </div>
                        <div class="col-6 text-end fs-13">
                            <div><strong>Order Date:</strong> <span id="docDate"></span></div>
                            <div><strong>Expected ETA:</strong> <span id="docExpectedDate" class="fw-bold text-success"></span></div>
                        </div>
                    </div>
                    <table class="table table-sm table-bordered align-middle fs-13 mb-4">
                        <thead class="table-light text-secondary text-center">
                            <tr>
                                <th class="text-start">Raw Material / SKU</th>
                                <th style="width: 15%">Qty Ordered</th>
                                <th style="width: 15%">Qty Received</th>
                                <th class="text-end" style="width: 15%">Unit Cost</th>
                                <th class="text-end" style="width: 20%">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="docItemsBody"></tbody>
                    </table>
                    <div class="row mt-4">
                        <div class="col-8">
                            <h6 class="fw-bold text-muted mb-1 fs-12 text-uppercase">Notes</h6>
                            <div class="text-dark fs-13 bg-light p-2 rounded border" style="min-height: 60px;" id="docNotes">-</div>
                        </div>
                        <div class="col-4 text-end">
                            <table class="table table-sm table-borderless text-end fs-14 mb-0">
                                <tr><td class="text-dark fw-bold fs-5">Total</td><td class="text-dark fw-bold fs-5 text-primary" id="docTotal">0.00</td></tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light border-top shadow-sm py-2">
                <button type="button" class="btn btn-secondary btn-sm px-4 fw-bold" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/purchasing/purchase-order.js" asp-append-version="true"></script>
}