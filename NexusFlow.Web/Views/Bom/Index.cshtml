@{
    ViewData["Title"] = "Bill of Materials Registry";
}

<div class="container-fluid py-4">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 text-dark fw-bold">
                <i class="fa-solid fa-sitemap text-primary me-2"></i>Bill of Materials
            </h4>
            <p class="text-muted mb-0 fs-14">Configure manufacturing recipes and raw material requirements for finished goods.</p>
        </div>
        <button class="btn btn-primary btn-sm shadow-sm px-3" type="button" onclick="window.bomApp.openCreateModal()">
            <i class="fa-solid fa-plus me-1"></i> Create BOM
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table id="bomTable" class="table table-hover table-striped align-middle mb-0 w-100 fs-13">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>BOM Name</th>
                        <th>Finished Good</th>
                        <th class="text-center">RM Count</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="bomModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-light">
            
            <div class="modal-header bg-white border-bottom shadow-sm py-2">
                <h5 class="modal-title fw-bold text-dark">
                    <i class="fa-solid fa-flask text-primary me-2"></i>Configure Bill of Materials
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4 fs-13">
                <form id="bomForm">
                    <input type="hidden" id="bomId" value="0" />
                    
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <div class="row g-3 mb-2">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold fs-13 mb-1">BOM Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="bomName" placeholder="e.g., Standard Long Sleeve Recipe" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold fs-13 mb-1">Target Finished Good <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="productVariantId" required style="width: 100%;"></select>
                                </div>
                            </div>
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" id="isActive" checked>
                                <label class="form-check-label fw-bold" for="isActive">Active Recipe (Available for Production)</label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
                            <h6 class="fw-bold text-primary mb-0"><i class="fa-solid fa-cubes me-2"></i>Raw Material Components</h6>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="addRmBtn">
                                <i class="fa-solid fa-plus me-1"></i> Add Component
                            </button>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-sm table-hover align-middle mb-0" id="rmTable">
                                    <thead class="table-light text-secondary">
                                        <tr>
                                            <th class="ps-3" style="width: 60%;">Material Variant (Raw Material)</th>
                                            <th style="width: 25%;">Qty Needed</th>
                                            <th style="width: 15%; text-align: center;">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="rmList">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    
                </form>
            </div>
            
            <div class="modal-footer bg-white border-top shadow-sm py-2">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4 fw-bold" id="btnSaveBom">
                    <i class="fa-solid fa-check me-2"></i>Save Configuration
                </button>
            </div>
            
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/bom-master.js" asp-append-version="true"></script>
}