@{
    ViewData["Title"] = "Bill of Materials Setup";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="m-0 text-dark">Bill of Materials</h4>
        <button class="btn btn-primary btn-sm" onclick="openBomModal()">+ Create BOM</button>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table id="bomTable" class="table table-hover table-bordered table-sm w-100" style="font-size: 13px;">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>FG Variant ID</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="bomModal" tabindex="-1" aria-labelledby="bomModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="font-size: 13px;">
            <div class="modal-header">
                <h5 class="modal-title" id="bomModalLabel">BOM Configuration</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="bomForm">
                    <input type="hidden" id="bomId" value="0" />
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">BOM Name</label>
                            <input type="text" id="bomName" class="form-control form-control-sm" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Finished Good (Variant ID)</label>
                            <input type="number" id="bomFgId" class="form-control form-control-sm" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Active</label>
                            <div class="form-check form-switch mt-1">
                                <input class="form-check-input" type="checkbox" id="bomIsActive" checked>
                            </div>
                        </div>
                    </div>
                    
                    <hr />
                    <h6 class="fw-bold">Raw Material Components</h6>
                    <table class="table table-sm table-bordered" id="bomComponentsTable">
                        <thead class="table-light">
                            <tr>
                                <th>RM Variant ID</th>
                                <th>Quantity</th>
                                <th><button type="button" class="btn btn-success btn-sm w-100" onclick="addComponentRow()">Add</button></th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="saveBom()">Save BOM</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/bom-master.js"></script>
}