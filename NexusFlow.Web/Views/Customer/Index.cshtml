@{
    ViewData["Title"] = "Customer Master";
}
@section styles{
    <style>
        /* Force DataTables search box to align left */
        .dataTables_filter {
            text-align: left !important;
        }

            .dataTables_filter label {
                width: 100%;
                display: flex;
                align-items: center;
            }

            .dataTables_filter input {
                margin-left: 10px;
                width: auto;
                flex-grow: 1;
                max-width: 300px;
            }
    </style>
}
    


<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0">Customer Directory</h4>
            <small class="text-muted">Manage B2B clients, showrooms, and their financial mappings.</small>
        </div>
        <button class="btn btn-primary btn-sm shadow-sm" onclick="customerApp.openCreateModal()">
            <i class="fa-solid fa-plus"></i> New Customer
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="customerTable" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Customer Name</th>
                        <th>Tax Reg No</th>
                        <th>Contact Person</th>
                        <th>Phone</th>
                        <th>City</th>
                        <th class="text-end">Credit Limit</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="customerModal" tabindex="-1" aria-labelledby="customerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light">
                <h5 class="modal-title fs-6" id="customerModalLabel">
                    <i class="fa-solid fa-building text-primary me-2"></i>Customer Registration
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body fs-13 p-4 bg-white">
                <form id="customerForm">
                    <div class="row">

                        <div class="col-lg-6 pe-lg-4 border-end">
                            <h6 class="text-primary border-bottom pb-1 mb-3"><i class="fa-solid fa-id-card me-2"></i>1. Identity & Classification</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-md-8">
                                    <label class="form-label fw-semibold mb-1">Legal Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="Name" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold mb-1">Tax Reg No <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="TaxRegNo" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Customer Group</label>
                                    <select class="form-select form-select-sm" name="CustomerGroupId" id="CustomerGroupId" required></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Price Level</label>
                                    <select class="form-select form-select-sm" name="PriceLevelId" id="PriceLevelId" required></select>
                                </div>
                            </div>

                            <h6 class="text-primary border-bottom pb-1 mb-3"><i class="fa-solid fa-scale-balanced me-2"></i>2. Financial Setup</h6>
                            <div class="row g-2 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">A/R Account (Asset) <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" name="DefaultReceivableAccountId" id="DefaultReceivableAccountId" required></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Revenue Account <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" name="DefaultRevenueAccountId" id="DefaultRevenueAccountId" required></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold mb-1">Payment Term</label>
                                    <select class="form-select form-select-sm" name="PaymentTermId" id="PaymentTermId" required></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold mb-1">Credit Limit</label>
                                    <input type="number" class="form-control form-control-sm" name="CreditLimit" value="0" step="0.01">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold mb-1">Credit Period (Days)</label>
                                    <input type="number" class="form-control form-control-sm text-end" name="CreditPeriodDays" value="30" min="0">
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 ps-lg-4">
                            <h6 class="text-primary border-bottom pb-1 mb-3"><i class="fa-solid fa-address-book me-2"></i>3. Ownership & Contact</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Assigned Sales Rep</label>
                                    <select class="form-select form-select-sm" name="SalesRepId" id="SalesRepId">
                                        <option value="">-- No Rep Assigned --</option>
                                    </select>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Contact Person <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="ContactPerson" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Email <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control form-control-sm" name="Email" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Phone <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="Phone" required>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold mb-1">Address Line 1 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="AddressLine1" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">City <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="City" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Country <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="Country" value="LKR" required>
                                </div>
                            </div>

                            <h6 class="text-primary border-bottom pb-1 mb-3"><i class="fa-solid fa-building-columns me-2"></i>4. Bank Details</h6>
                            <div class="row g-2 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Bank Name</label>
                                    <input type="text" class="form-control form-control-sm" name="BankName" placeholder="e.g., Commercial Bank">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Branch</label>
                                    <input type="text" class="form-control form-control-sm" name="BankBranch">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Account Number</label>
                                    <input type="text" class="form-control form-control-sm font-monospace" name="BankAccountNumber">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-1">Swift Code</label>
                                    <input type="text" class="form-control form-control-sm font-monospace" name="BankSwiftCode">
                                </div>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-3 border-top">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm" onclick="customerApp.saveCustomer()">
                    <i class="fa-solid fa-save"></i> Save Customer
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/master/customer-master.js" asp-append-version="true"></script>
}
