@{
    ViewData["Title"] = "Customer Master";
}

@section styles{
    <style>
        .dataTables_filter { text-align: left !important; }
        .dataTables_filter label { width: 100%; display: flex; align-items: center; }
        .dataTables_filter input { margin-left: 10px; width: auto; flex-grow: 1; max-width: 300px; }
        .locked-field { background-color: #e9ecef; cursor: not-allowed; border-color: #dee2e6; }
    </style>
}
    
<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-users text-primary me-2"></i>Customer Directory</h4>
            <small class="text-muted">Manage B2B clients, locations, and strict financial mappings.</small>
        </div>
        <button class="btn btn-primary btn-sm shadow-sm fw-bold" onclick="customerApp.openCreateModal()">
            <i class="fa-solid fa-plus me-1"></i> New Customer
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-3 bg-light">
        <div class="card-body py-2 px-3 d-flex gap-3 align-items-center">
            <span class="fw-bold text-muted fs-13"><i class="fa-solid fa-filter me-1"></i> Filters:</span>
            <select class="form-select form-select-sm w-auto shadow-sm" id="filterDistrict">
                <option value="">All Districts</option>
            </select>
            <select class="form-select form-select-sm w-auto shadow-sm" id="filterCity">
                <option value="">All Cities</option>
            </select>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="customerTable" class="table table-hover table-sm w-100 fs-13 align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th>Customer Name</th>
                        <th>Tax Reg No</th>
                        <th>Contact Person</th>
                        <th>Phone</th>
                        <th>District</th>
                        <th>City</th>
                        <th class="text-end">Credit Limit</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="customerModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fs-6 fw-bold" id="customerModalLabel">Customer Registration</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body fs-13 p-4 bg-white">
                <form id="customerForm">
                    <input type="hidden" name="Id" id="CustomerId" value="0">
                    <div class="row">

                        <div class="col-lg-6 pe-lg-4 border-end">
                            <h6 class="text-primary border-bottom pb-1 mb-3 fw-bold"><i class="fa-solid fa-id-card me-2"></i>1. Identity & Classification</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-md-8">
                                    <label class="form-label fw-bold mb-1">Legal Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="Name" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">Tax Reg No <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm font-monospace" name="TaxRegNo" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Customer Group <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" name="CustomerGroupId" id="CustomerGroupId" required></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Price Level <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" name="PriceLevelId" id="PriceLevelId" required></select>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1">Assigned Sales Rep</label>
                                    <select class="form-select form-select-sm" name="SalesRepId" id="SalesRepId">
                                        <option value="">-- No Rep Assigned --</option>
                                    </select>
                                </div>
                            </div>

                            <h6 class="text-primary border-bottom pb-1 mb-3 fw-bold"><i class="fa-solid fa-address-book me-2"></i>2. Contact Details</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1">Contact Person <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="ContactPerson" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Email <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control form-control-sm" name="Email" required placeholder="name@company.com">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Phone <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="Phone" required pattern="^\+?[0-9\s\-\(\)]{9,15}$" title="Valid phone number required">
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 ps-lg-4">
                            <h6 class="text-primary border-bottom pb-1 mb-3 fw-bold"><i class="fa-solid fa-map-location-dot me-2"></i>3. Geographic Location</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1">Address Line 1 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" name="AddressLine1" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">Province <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" name="Province" id="Province" required></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">District <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" name="District" id="District" required disabled></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">City <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" name="City" id="City" required disabled></select>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-end border-bottom pb-1 mb-3">
                                <h6 class="text-primary mb-0 fw-bold"><i class="fa-solid fa-scale-balanced me-2"></i>4. Financial & Banking</h6>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="unlockAccountsToggle">
                                    <label class="form-check-label fs-12 text-muted" for="unlockAccountsToggle">Unlock GL Mapping</label>
                                </div>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">A/R Account (Asset) <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm locked-field" name="DefaultReceivableAccountId" id="DefaultReceivableAccountId" required></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1">Revenue Account <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm locked-field" name="DefaultRevenueAccountId" id="DefaultRevenueAccountId" required></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">Payment Term</label>
                                    <select class="form-select form-select-sm" name="PaymentTermId" id="PaymentTermId" required></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">Credit Limit</label>
                                    <input type="number" class="form-control form-control-sm text-end fw-bold text-dark" name="CreditLimit" value="0" step="0.01">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold mb-1">Credit Period (Days)</label>
                                    <input type="number" class="form-control form-control-sm text-end" name="CreditPeriodDays" value="30" min="0">
                                </div>
                            </div>

                            <div class="row g-2 mb-2 bg-light p-2 rounded border mt-2">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1 text-muted">Bank Name</label>
                                    <select class="form-select form-select-sm" name="BankId" id="BankId">
                                        <option value="">-- Select Bank --</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold mb-1 text-muted">Branch</label>
                                    <select class="form-select form-select-sm" name="BankBranchId" id="BankBranchId" disabled>
                                        <option value="">-- Select Branch --</option>
                                    </select>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold mb-1 text-muted">Account Number</label>
                                    <input type="text" class="form-control form-control-sm font-monospace" name="BankAccountNumber" placeholder="Numeric account number">
                                </div>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-2 border-top">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm fw-bold" onclick="customerApp.saveCustomer(event)">
                    <i class="fa-solid fa-check-double me-1"></i> Save Customer
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/master/customer-master.js" asp-append-version="true"></script>
}