@{
    ViewData["Title"] = "System Configuration";
}

<style>
    :root {
        --erp-font-base: 0.85rem; /* 13.6px - Standard SaaS size */
        --erp-font-head: 0.75rem; /* 12px for headers */
    }

    /* Global Typography Fix */
    .erp-container { font-size: var(--erp-font-base); }
    h2 { font-size: 1.5rem; }
    p.text-muted { font-size: 0.8rem; }

    /* Compact Tables */
    .table-erp th {
        font-size: var(--erp-font-head);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background-color: #f8f9fa;
        border-bottom: 2px solid #e9ecef;
        padding-top: 10px;
        padding-bottom: 10px;
    }
    .table-erp td {
        vertical-align: middle;
        padding-top: 6px;
        padding-bottom: 6px; /* Tighter rows */
    }

    /* Tabs Styling */
    .nav-tabs .nav-link {
        color: #64748b;
        font-size: 0.9rem;
        padding: 0.75rem 1.25rem;
        font-weight: 500;
    }
    .nav-tabs .nav-link.active {
        color: #0f172a;
        font-weight: 600;
        border-bottom: 2px solid #0f172a; /* Active Indicator */
    }
</style>

<div class="erp-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="fw-bold text-dark mb-1">System Configuration</h4>
            <p class="text-muted mb-0">Control panel for global settings and document references.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom pt-2 px-3">
            <ul class="nav nav-tabs card-header-tabs border-bottom-0" id="configTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-general">
                        <i class="bi bi-sliders me-2"></i>General Settings
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-sequences">
                        <i class="bi bi-hash me-2"></i>Number Sequences
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-lookups">
                        <i class="bi bi-list-check me-2"></i>Dropdown Lists
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body p-0">
            <div class="tab-content">

                <div class="tab-pane fade show active" id="tab-general">
                    <div class="bg-light p-2 border-bottom d-flex justify-content-end">
                        <button class="btn btn-sm btn-primary shadow-sm" onclick="configApp.openCreateModal()">
                            <i class="bi bi-plus-lg me-1"></i> New Setting
                        </button>
                    </div>

                    <table id="settingsGrid" class="table table-erp table-hover w-100 mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4" style="width: 30%">Setting Key</th>
                                <th style="width: 35%">Description</th>
                                <th style="width: 25%">Value</th>
                                <th class="text-end pe-4" style="width: 10%"></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <div class="tab-pane fade" id="tab-sequences">
                    <div class="d-flex justify-content-between align-items-center p-3 border-bottom bg-light bg-opacity-50">
                        <div class="d-flex align-items-center text-muted small">
                            <i class="bi bi-info-circle-fill text-info me-2"></i>
                            <span>Changes affect <strong>future</strong> documents only.</span>
                        </div>
                        <button class="btn btn-sm btn-primary shadow-sm" onclick="configApp.openCreateSequenceModal()">
                            <i class="bi bi-plus-lg me-1"></i> New Sequence
                        </button>
                    </div>

                    <table id="sequenceGrid" class="table table-erp table-hover w-100 mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4" style="width: 20%">Module</th>
                                <th style="width: 15%">Prefix</th>
                                <th style="width: 15%">Next #</th>
                                <th style="width: 20%">Preview</th>
                                <th style="width: 20%">Last Used</th>
                                <th class="text-end pe-4" style="width: 10%"></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <div class="tab-pane fade p-5 text-center text-muted" id="tab-lookups">
                    <div class="py-5">
                        <i class="bi bi-cone-striped fs-1 text-secondary opacity-50"></i>
                        <p class="mt-3 fw-medium">Dropdown Management Module</p>
                        <small>Scheduled for Sprint 3</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="settingModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2 bg-light">
                <h6 class="modal-title fw-bold" id="modalTitle">Edit Setting</h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="settingForm">
                    <input type="hidden" id="IsEditMode">

                    <div class="mb-2">
                        <label class="form-label fw-bold small mb-1">Setting Key <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm font-monospace" id="ConfigKey" placeholder="e.g. Sales.TaxRate">
                        <div class="form-text small" style="font-size: 0.75rem;">System identifier (cannot be changed later).</div>
                    </div>

                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small mb-1">Data Type</label>
                            <select class="form-select form-select-sm" id="ConfigDataType" onchange="configApp.renderInput()">
                                <option value="String">String (Text)</option>
                                <option value="Decimal">Decimal (Number)</option>
                                <option value="Boolean">Boolean (Switch)</option>
                                <option value="Integer">Integer (Count)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-bold small mb-1">Description</label>
                        <input type="text" class="form-control form-control-sm" id="ConfigDescription">
                    </div>

                    <div class="mb-2 p-2 bg-light border rounded">
                        <label class="form-label fw-bold small mb-1">Value <span class="text-danger">*</span></label>
                        <div id="dynamicInputContainer">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-white border" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" onclick="configApp.saveSetting()">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="sequenceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2 bg-light">
                <h6 class="modal-title fw-bold">Number Sequence</h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="sequenceForm">
                    <input type="hidden" id="SeqId">

                    <div class="mb-3">
                        <label class="form-label fw-bold small mb-1">Module Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm font-monospace" id="SeqModule" placeholder="e.g. SalesOrder">
                        <div class="form-text small" style="font-size: 0.75rem;">Internal code used by the backend logic.</div>
                    </div>

                    <div class="row g-2 align-items-end mb-3">
                        <div class="col-4">
                            <label class="form-label fw-bold small mb-1">Prefix</label>
                            <input type="text" class="form-control form-control-sm text-uppercase" id="SeqPrefix" maxlength="5" onkeyup="configApp.updatePreview()" placeholder="INV">
                        </div>
                        <div class="col-3">
                            <label class="form-label fw-bold small mb-1">Delimiter</label>
                            <select class="form-select form-select-sm" id="SeqDelimiter" onchange="configApp.updatePreview()">
                                <option value="-">-</option>
                                <option value="/">/</option>
                                <option value=".">.</option>
                            </select>
                        </div>
                        <div class="col-5">
                            <label class="form-label fw-bold small mb-1">Next Number</label>
                            <input type="number" class="form-control form-control-sm" id="SeqNext" min="1" onkeyup="configApp.updatePreview()">
                        </div>
                    </div>

                    <div class="text-center p-3 bg-light border rounded-3 dashed-border">
                        <label class="small text-muted text-uppercase fw-bold mb-1" style="font-size: 0.7rem;">Preview Generated ID</label>
                        <div id="SeqPreview" class="fs-5 font-monospace fw-bold text-dark">INV-1001</div>
                    </div>

                </form>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-white border" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" onclick="configApp.saveSequence()">Save Sequence</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/system-config.js" asp-append-version="true"></script>
}