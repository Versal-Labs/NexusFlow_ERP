@{
    ViewData["Title"] = "System Configuration";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <div>
        <h1 class="h2">System Configuration</h1>
        <p class="text-muted small mb-0">Manage global system parameters and document numbering.</p>
    </div>
</div>

<ul class="nav nav-tabs mb-3" id="configTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general-pane" type="button" role="tab">
            <i class="bi bi-sliders me-1"></i> General Settings
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="sequences-tab" data-bs-toggle="tab" data-bs-target="#sequences-pane" type="button" role="tab">
            <i class="bi bi-hash me-1"></i> Number Sequences
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="lookups-tab" data-bs-toggle="tab" data-bs-target="#lookups-pane" type="button" role="tab">
            <i class="bi bi-list-check me-1"></i> Dropdown Lists
        </button>
    </li>
</ul>

<div class="tab-content" id="configTabsContent">

    <div class="tab-pane fade show active" id="general-pane" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold">Global Parameters</h6>
                    <button class="btn btn-sm btn-primary" onclick="configApp.openSettingPanel()">
                        <i class="bi bi-plus-lg"></i> New Setting
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="settingsGrid" class="table table-striped table-hover w-100">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width: 30%">Key</th>
                                <th style="width: 35%">Description</th>
                                <th style="width: 25%">Value</th>
                                <th class="text-end pe-4" style="width: 10%">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="sequences-pane" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-bold">Document Numbering</h6>
                        <small class="text-muted">Changes affect future documents only.</small>
                    </div>
                    <button class="btn btn-sm btn-primary" onclick="configApp.openSequencePanel()">
                        <i class="bi bi-plus-lg"></i> New Sequence
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="sequenceGrid" class="table table-striped table-hover w-100">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Module</th>
                                <th>Prefix</th>
                                <th>Next #</th>
                                <th>Preview</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="lookups-pane" role="tabpanel">
        <div class="alert alert-light border text-center p-5">
            <h5 class="text-muted"><i class="bi bi-cone-striped"></i> Module Pending</h5>
            <p>Dropdown Management is scheduled for Sprint 3.</p>
        </div>
    </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasSetting" aria-labelledby="offcanvasSettingLabel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title" id="offcanvasSettingLabel">Manage Setting</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <form id="frmSetting">
            <input type="hidden" id="IsEditMode" value="false">

            <div class="mb-3">
                <label class="form-label fw-bold">Setting Key <span class="text-danger">*</span></label>
                <input type="text" class="form-control font-monospace" id="ConfigKey" placeholder="e.g. Sales.TaxRate" required>
                <div class="form-text">Unique system identifier. Cannot be changed once created.</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Data Type</label>
                <select class="form-select" id="ConfigDataType" onchange="configApp.renderInput()">
                    <option value="String">String (Text)</option>
                    <option value="Decimal">Decimal (Number)</option>
                    <option value="Boolean">Boolean (Switch)</option>
                    <option value="Integer">Integer (Count)</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Description</label>
                <input type="text" class="form-control" id="ConfigDescription">
            </div>

            <div class="mb-4 p-3 bg-light border rounded">
                <label class="form-label fw-bold text-primary">Configuration Value <span class="text-danger">*</span></label>
                <div id="dynamicInputContainer">
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasSequence" aria-labelledby="offcanvasSequenceLabel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title" id="offcanvasSequenceLabel">Manage Sequence</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <form id="frmSequence">
            <input type="hidden" id="SeqId" value="0">

            <div class="mb-3">
                <label class="form-label fw-bold">Module Name <span class="text-danger">*</span></label>
                <input type="text" class="form-control font-monospace" id="SeqModule" placeholder="e.g. SalesOrder" required>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-4">
                    <label class="form-label fw-bold">Prefix</label>
                    <input type="text" class="form-control text-uppercase" id="SeqPrefix" maxlength="5" onkeyup="configApp.updatePreview()" placeholder="INV">
                </div>
                <div class="col-4">
                    <label class="form-label fw-bold">Delimiter</label>
                    <select class="form-select" id="SeqDelimiter" onchange="configApp.updatePreview()">
                        <option value="-">-</option>
                        <option value="/">/</option>
                        <option value=".">.</option>
                        <option value="">(None)</option>
                    </select>
                </div>
                <div class="col-4">
                    <label class="form-label fw-bold">Next #</label>
                    <input type="number" class="form-control" id="SeqNext" min="1" onkeyup="configApp.updatePreview()" required>
                </div>
            </div>

            <div class="text-center p-3 mb-3 bg-light border rounded dashed-border">
                <label class="small text-muted text-uppercase fw-bold mb-1">Preview ID</label>
                <div id="SeqPreview" class="fs-4 font-monospace fw-bold text-dark">INV-1001</div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Save Sequence</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/system-config.js" asp-append-version="true"></script>
}