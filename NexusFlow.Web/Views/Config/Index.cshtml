@{
    ViewData["Title"] = "System Configuration";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1">System Configuration</h2>
        <p class="text-muted mb-0 small">Manage global settings, document numbering, and dropdown lists.</p>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom-0 pt-3 px-3">
        <ul class="nav nav-tabs card-header-tabs" id="configTabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-general">
                    <i class="bi bi-sliders me-2"></i>General Settings
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-sequences">
                    <i class="bi bi-123 me-2"></i>Document Numbering
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-lookups">
                    <i class="bi bi-list-ul me-2"></i>Dropdown Lists
                </button>
            </li>
        </ul>
    </div>

    <div class="card-body p-0">
        <div class="tab-content">

            <div class="tab-pane fade show active" id="tab-general">
                <table id="settingsGrid" class="table table-hover align-middle w-100 mb-0">
                    <thead class="bg-light text-uppercase small text-muted">
                        <tr>
                            <th class="ps-4">Setting Key</th>
                            <th>Description</th>
                            <th>Value</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <div class="tab-pane fade" id="tab-sequences">
                <div class="alert alert-info bg-opacity-10 border-0 m-3 d-flex align-items-center">
                    <i class="bi bi-info-circle-fill text-info me-2"></i>
                    <small>Changing prefixes will affect <strong>new</strong> documents only. Existing documents remain unchanged.</small>
                </div>
                <table id="sequenceGrid" class="table table-hover align-middle w-100 mb-0">
                    <thead class="bg-light text-uppercase small text-muted">
                        <tr>
                            <th class="ps-4">Module</th>
                            <th>Prefix</th>
                            <th>Next #</th>
                            <th>Preview</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <div class="tab-pane fade p-5 text-center text-muted" id="tab-lookups">
                <i class="bi bi-cone-striped fs-1"></i>
                <p class="mt-2">Dropdown Management Module (Coming in next Sprint)</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="settingModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Edit Setting</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="settingForm">
                    <input type="hidden" id="ConfigKey">
                    <input type="hidden" id="ConfigDataType">

                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Setting</label>
                        <input type="text" class="form-control-plaintext fw-bold" id="ConfigKeyDisplay" readonly>
                        <div class="form-text" id="ConfigDescDisplay"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">New Value</label>
                        <div id="dynamicInputContainer">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="configApp.saveSetting()">Update</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="sequenceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Edit Number Sequence</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="sequenceForm">
                    <input type="hidden" id="SeqId">

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Module</label>
                        <input type="text" class="form-control-plaintext fw-bold" id="SeqModule" readonly>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label small">Prefix</label>
                            <input type="text" class="form-control text-uppercase" id="SeqPrefix" maxlength="5" onkeyup="configApp.updatePreview()">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small">Delimiter</label>
                            <select class="form-select" id="SeqDelimiter" onchange="configApp.updatePreview()">
                                <option value="-">-</option>
                                <option value="/">/</option>
                                <option value=".">.</option>
                                <option value="">(None)</option>
                            </select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label small">Next Number</label>
                            <input type="number" class="form-control" id="SeqNext" min="1" onkeyup="configApp.updatePreview()">
                        </div>
                    </div>

                    <div class="mt-4 p-3 bg-light rounded text-center border border-dashed">
                        <label class="small text-muted d-block mb-1">PREVIEW NEXT DOCUMENT ID</label>
                        <span id="SeqPreview" class="fs-4 font-monospace fw-bold text-primary">INV-1001</span>
                    </div>

                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="configApp.saveSequence()">Save Changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/system-config.js" asp-append-version="true"></script>
}
