@{
    ViewData["Title"] = "Employee Master";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="bi bi-people-fill me-2 text-primary"></i>Employee Directory</h4>
            <p class="text-muted mb-0 fs-14">Manage staff, payroll hooks, and system access roles.</p>
        </div>
        <button class="btn btn-primary shadow-sm" onclick="employeeApp.openEditor()">
            <i class="bi bi-person-plus-fill me-2"></i>New Employee
        </button>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table id="employeesGrid" class="table table-hover table-striped align-middle mb-0 w-100 fs-13">
                    <thead class="table-light text-secondary">
                        <tr>
                            <th>EMP Code</th>
                            <th>Full Name</th>
                            <th>Email (Login)</th>
                            <th>Phone</th>
                            <th>Role / Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="employeeModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-bottom">
                <h5 class="modal-title fw-bold" id="modalTitle"><i class="bi bi-person-badge text-primary me-2"></i>Employee Onboarding</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4 bg-white">
                <form id="employeeForm" class="needs-validation" novalidate>
                    <input type="hidden" id="hdnEmployeeId" value="0" />
                    
                    <div class="row">
                        <div class="col-lg-6 pe-lg-4 border-end">
                            <h6 class="text-primary border-bottom pb-2 mb-3 fs-14 fw-bold"><i class="bi bi-person-vcard me-2"></i>1. Personal Identity</h6>
                            
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold fs-13 mb-1">First Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="FirstName" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold fs-13 mb-1">Last Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="LastName" required>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold fs-13 mb-1">Email Address (System Username) <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control form-control-sm" id="Email" placeholder="name@company.com" required>
                                    <div class="invalid-feedback">A valid corporate email is required for system login.</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold fs-13 mb-1">Phone Number <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="Phone" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold fs-13 mb-1">National ID (NIC) <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="NIC" required>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 ps-lg-4">
                            <h6 class="text-primary border-bottom pb-2 mb-3 fs-14 fw-bold"><i class="bi bi-bank me-2"></i>2. Payroll Hooks</h6>
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold fs-13 mb-1">Basic Salary</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">$</span>
                                        <input type="number" class="form-control" id="BasicSalary" step="0.01" value="0">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold fs-13 mb-1">EPF / SSN Number</label>
                                    <input type="text" class="form-control form-control-sm" id="EPF_No">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold fs-13 mb-1">Bank Name</label>
                                    <input type="text" class="form-control form-control-sm" id="BankName">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold fs-13 mb-1">Bank Account No.</label>
                                    <input type="text" class="form-control form-control-sm" id="BankAccountNo">
                                </div>
                            </div>

                            <h6 class="text-primary border-bottom pb-2 mb-3 fs-14 fw-bold"><i class="bi bi-shield-lock me-2"></i>3. Operational Roles</h6>
                            <div class="card border-0 bg-light shadow-sm">
                                <div class="card-body p-3">
                                    <div class="form-check form-switch mb-2">
                                        <input class="form-check-input" type="checkbox" role="switch" id="IsSalesRep">
                                        <label class="form-check-label fw-bold text-dark" for="IsSalesRep">Assign "Sales Representative" Role</label>
                                    </div>
                                    <div id="salesRepAlert" class="alert alert-warning py-2 mb-0 fs-12" style="display: none;">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i> <strong>Auto-Provisioning Active:</strong> Saving this will instantly generate an ERP Login and email the secure credentials to the employee. They will be added to the Commission Matrix.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            
            <div class="modal-footer bg-light border-top p-3">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm" id="btnSaveEmployee" onclick="employeeApp.save()">
                    <i class="bi bi-save me-2"></i>Onboard Employee
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/hr/employees.js" asp-append-version="true"></script>
}