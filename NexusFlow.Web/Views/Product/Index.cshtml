@{
    ViewData["Title"] = "Product Master";
}

@section Styles {
    <style>
        /* Force DataTables search box to align left */
        .dataTables_filter {
            text-align: left !important;
        }

            .dataTables_filter label {
                width: 100%;
                display: flex;
                align-items: center;
            }

            .dataTables_filter input {
                margin-left: 10px;
                width: auto;
                flex-grow: 1;
                max-width: 300px;
            }

        td.dt-control {
            cursor: pointer;
        }
    </style>
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0">Product Catalog</h4>
            <small class="text-muted">Manage products, variants, and execute bulk migrations.</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-light border shadow-sm text-success" onclick="importApp.openWizard()">
                <i class="fa-solid fa-file-import me-2"></i>Import / Migrate
            </button>
            <button class="btn btn-primary btn-sm shadow-sm" onclick="productApp.openEditor()">
                <i class="fa-solid fa-plus me-1"></i> New Product
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="productsGrid" class="table table-hover table-sm align-middle w-100 fs-13 mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="max-width: 20px;"></th>
                        <th>Product Name</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Brand</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light">
                <h5 class="modal-title fs-6" id="drawerTitle">
                    <i class="fa-solid fa-box text-primary me-2"></i>Create Product
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body fs-13 p-4 bg-white">
                <form id="productForm">
                    <input type="hidden" id="hdnProductId" value="0">

                    <div class="row">
                        <div class="col-lg-4 pe-lg-4 border-end">
                            <h6 class="text-primary border-bottom pb-1 mb-3"><i class="fa-solid fa-tag me-2"></i>1. Classification</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-12">
                                    <label class="form-label fw-semibold mb-1">Product Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="Name" required placeholder="e.g. Oxford Shirt">
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold mb-1">Type</label>
                                    <select class="form-select form-select-sm" id="Type">
                                        <option value="1">Finished Good (Stock)</option>
                                        <option value="0">Raw Material (Stock)</option>
                                        <option value="2">Service (Non-Stock)</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold mb-1">Category <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="CategoryId" required></select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold mb-1">Brand <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="BrandId" required></select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold mb-1">Unit <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="UnitOfMeasureId" required></select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold mb-1">Description</label>
                                    <textarea class="form-control form-control-sm" id="Description" rows="2"></textarea>
                                </div>
                            </div>

                            <h6 class="text-primary border-bottom pb-1 mb-3"><i class="fa-solid fa-scale-balanced me-2"></i>2. Financial Mapping</h6>
                            <div class="row g-2 mb-3">
                                <div class="col-12">
                                    <label class="form-label fw-semibold mb-1">Income Account (Revenue) <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="SalesAccountId" required></select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold mb-1">Expense Account (COGS) <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="CogsAccountId" required></select>
                                </div>
                                <div class="col-12" id="divInventoryAccount">
                                    <label class="form-label fw-semibold mb-1">Inventory Asset Account <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="InventoryAccountId"></select>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-8 ps-lg-4">
                            <div class="d-flex justify-content-between align-items-center border-bottom pb-1 mb-3">
                                <h6 class="text-primary mb-0"><i class="fa-solid fa-layer-group me-2"></i>3. Product Variants</h6>
                                <button type="button" class="btn btn-sm btn-light border" onclick="productApp.addVariantRow()">
                                    <i class="fa-solid fa-plus text-success"></i> Add Variant
                                </button>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-sm table-bordered align-middle" id="variantTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Size</th>
                                            <th>Color</th>
                                            <th>SKU (Unique) <span class="text-danger">*</span></th>
                                            <th style="width: 100px;">Cost</th>
                                            <th style="width: 100px;">Price</th>
                                            <th style="width: 40px;" class="text-center"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="variantList"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-3 border-top">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm px-4 shadow-sm" onclick="productApp.save()">
                    <i class="fa-solid fa-save me-1"></i> Save Product
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="importModal" tabindex="-1" data-bs-backdrop="static">
</div>

@section Scripts {
    <script src="~/js/master/product-master.js" asp-append-version="true"></script>
    <script src="~/js/master/product-import.js" asp-append-version="true"></script>
}