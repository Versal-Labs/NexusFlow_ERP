@{
    ViewData["Title"] = "Product Master";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <div>
        <h2 class="fw-bold text-dark mb-1">Product Catalog</h2>
        <p class="text-muted mb-0 small">Manage products, variants, and execute bulk migrations.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-white border shadow-sm text-success" onclick="importApp.openWizard()">
            <i class="bi bi-file-earmark-spreadsheet me-2"></i>Import / Migrate
        </button>
        <button class="btn btn-primary shadow-sm" onclick="productApp.openEditor()">
            <i class="bi bi-plus-lg me-2"></i>New Product
        </button>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table id="productsGrid" class="table table-hover align-middle w-100 mb-0">
                <thead class="bg-light text-uppercase small text-muted">
                    <tr>
                        <th style="max-width: 20px;"></th>
                        <th class="ps-4">Product Name</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Brand</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="offcanvas offcanvas-end shadow" tabindex="-1" id="productDrawer" style="width: 900px;">
    <div class="offcanvas-header border-bottom bg-light">
        <h5 class="offcanvas-title fw-bold" id="drawerTitle">Create Product</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-0">
        <form id="productForm">
            <input type="hidden" id="hdnProductId" value="0">

            <div class="p-4 border-bottom">
                <div class="row g-3">
                    <div class="col-8">
                        <label class="form-label small fw-bold">Product Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="Name" required placeholder="e.g. Slim Fit Oxford Shirt">
                    </div>
                    <div class="col-4">
                        <label class="form-label small fw-bold">Type</label>
                        <select class="form-select" id="Type">
                            <option value="1">Finished Good</option>
                            <option value="0">Raw Material</option>
                            <option value="2">Service</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold">Description</label>
                        <textarea class="form-control" id="Description" rows="2"></textarea>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Category <span class="text-danger">*</span></label>
                        <select class="form-select select2" id="CategoryId" required style="width:100%"></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Brand <span class="text-danger">*</span></label>
                        <select class="form-select select2" id="BrandId" required style="width:100%"></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Unit <span class="text-danger">*</span></label>
                        <select class="form-select select2" id="UnitOfMeasureId" required style="width:100%"></select>
                    </div>
                </div>
            </div>

            <div class="p-4 bg-light h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-uppercase small text-muted fw-bold mb-0">Variants</h6>
                    <button type="button" class="btn btn-sm btn-white border" onclick="productApp.addVariantRow()">
                        <i class="bi bi-plus-lg"></i> Add Line
                    </button>
                </div>
                <table class="table table-sm bg-white border rounded" id="variantTable">
                    <thead class="table-light">
                        <tr>
                            <th>Size</th>
                            <th>Color</th>
                            <th>SKU (Unique)</th>
                            <th>Cost</th>
                            <th>Price</th>
                            <th style="width:50px"></th>
                        </tr>
                    </thead>
                    <tbody id="variantList"></tbody>
                </table>
            </div>
            <div class="card border shadow-sm mb-3 border-start border-4 border-info">
                <div class="card-body">
                    <h6 class="card-title fw-bold text-info mb-3 small text-uppercase">
                        <i class="bi bi-bank me-1"></i> Financial Mapping
                    </h6>

                    <div class="row g-2">
                        <div class="col-12 mb-2">
                            <label class="form-label fw-bold small">Income Account (Revenue) <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="SalesAccountId" required style="width:100%"></select>
                            <div class="form-text small text-muted">Account credited when this item is sold.</div>
                        </div>

                        <div class="col-12 mb-2">
                            <label class="form-label fw-bold small">Expense Account (COGS) <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="CogsAccountId" required style="width:100%"></select>
                            <div class="form-text small text-muted">Account debited for the cost of this item.</div>
                        </div>

                        <div class="col-12 mb-2" id="divInventoryAccount">
                            <label class="form-label fw-bold small">Inventory Asset Account <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="InventoryAccountId" style="width:100%"></select>
                            <div class="form-text small text-muted">Account holding the value of this stock.</div>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>
    <div class="offcanvas-footer p-3 border-top bg-white d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-light border" data-bs-dismiss="offcanvas">Cancel</button>
        <button type="button" class="btn btn-primary px-4" onclick="productApp.save()">Save Product</button>
    </div>
</div>

<div class="modal fade" id="importModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold"><i class="bi bi-magic me-2"></i>Data Migration Wizard</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="progress" style="height: 4px;">
                    <div class="progress-bar" id="wizardProgress" style="width: 33%"></div>
                </div>

                <div class="p-4">
                    <div id="step1" class="wizard-step">
                        <div class="text-center py-5">
                            <i class="bi bi-cloud-upload display-4 text-primary opacity-50"></i>
                            <h4 class="mt-3">Upload Legacy Data</h4>
                            <p class="text-muted">Supports .CSV or .XLSX. First row must contain headers.</p>
                            <input type="file" id="fileUpload" class="d-none" accept=".csv, .xlsx">
                            <button class="btn btn-lg btn-outline-primary mt-2" onclick="$('#fileUpload').click()">
                                Choose File
                            </button>
                        </div>
                    </div>

                    <div id="step2" class="wizard-step d-none">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold">Validate Data</h6>
                            <div class="badge bg-warning text-dark" id="errorCountBadge">0 Errors Found</div>
                        </div>
                        <div class="alert alert-info small">
                            <i class="bi bi-info-circle me-1"></i>
                            The system has analyzed your file. Rows with <span class="text-danger fw-bold">RED</span> cells have invalid data (e.g., missing Brand).
                            <strong>Click any cell to edit and fix it before importing.</strong>
                        </div>
                        <div class="table-responsive border rounded" style="max-height: 400px;">
                            <table class="table table-sm table-bordered mb-0" id="validationGrid">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Status</th>
                                        <th>Product Name</th>
                                        <th>Brand (Exact Match)</th>
                                        <th>Category (Exact Match)</th>
                                        <th>Unit</th>
                                        <th>Price</th>
                                    </tr>
                                </thead>
                                <tbody id="validationBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button class="btn btn-secondary" onclick="importApp.reset()">Reset</button>
                <button class="btn btn-primary" id="btnCommitImport" disabled onclick="importApp.commit()">
                    Import Valid Rows
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/master/product-master.js" asp-append-version="true"></script>
    <script src="~/js/master/product-import.js" asp-append-version="true"></script>
}