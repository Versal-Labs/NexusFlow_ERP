@{
    ViewData["Title"] = "Product Master";
}

@section Styles {
    <style>
        .dataTables_filter { text-align: left !important; }
        .dataTables_filter label { width: 100%; display: flex; align-items: center; }
        .dataTables_filter input { margin-left: 10px; width: auto; flex-grow: 1; max-width: 300px; }
        td.dt-control { cursor: pointer; }
        .bulk-edit-input { width: 100%; border: 1px solid transparent; background: transparent; padding: 2px 4px; transition: all 0.2s; }
        .bulk-edit-input:focus, .bulk-edit-input:hover { border: 1px solid #0d6efd; background: #fff; outline: none; border-radius: 3px; }
        .modified-cell { background-color: #fff3cd !important; }

        #bulkGrid { table-layout: fixed; width: 100% !important; }
#bulkGrid th, #bulkGrid td { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    </style>


}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-boxes-stacked text-primary me-2"></i>Product Catalog</h4>
            <small class="text-muted">Manage items, raw materials, and execute bulk updates.</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-warning btn-sm shadow-sm fw-bold text-dark" onclick="bulkApp.openModal()">
                <i class="fa-solid fa-table-cells me-1"></i> Bulk Edit Grid
            </button>
            @* <button class="btn btn-light border btn-sm shadow-sm text-success" onclick="importApp.openWizard()">
                <i class="fa-solid fa-file-import me-2"></i>Import
            </button> *@
            <button class="btn btn-primary btn-sm shadow-sm fw-bold" onclick="productApp.openEditor()">
                <i class="fa-solid fa-plus me-1"></i> New Product
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <table id="productsGrid" class="table table-hover table-sm align-middle w-100 fs-13 mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th style="max-width: 20px;"></th>
                        <th>Product Name</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Brand</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="productModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fs-6 fw-bold" id="drawerTitle">Create Product</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body fs-13 p-4 bg-white">
                <form id="productForm">
                    <input type="hidden" id="hdnProductId" value="0">
                    <div class="row">
                        <div class="col-lg-4 pe-lg-4 border-end">
                            <h6 class="text-primary border-bottom pb-1 mb-3 fw-bold">1. Classification</h6>
                            <div class="row g-2 mb-4">
                                <div class="col-12">
                                    <label class="form-label fw-bold mb-1">Type <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm fw-bold text-primary" id="Type">
                                        <option value="2">Finished Good (Sellable Stock)</option>
                                        <option value="1">Raw Material (Non-Sellable Stock)</option>
                                        <option value="3">Service (Non-Stock)</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-bold mb-1">Product Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" id="Name" required placeholder="e.g. Oxford Shirt or Cotton Thread">
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-bold mb-1">Category <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="CategoryId" required></select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-bold mb-1">Brand <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="BrandId" required></select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-bold mb-1">Unit <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" id="UnitOfMeasureId" required></select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-bold mb-1">Description</label>
                                    <textarea class="form-control form-control-sm" id="Description" rows="2"></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-8 ps-lg-4">
                            <div class="d-flex justify-content-between align-items-center border-bottom pb-1 mb-3">
                                <h6 class="text-primary mb-0 fw-bold">2. Item Configurations (Variants / SKUs)</h6>
                                <button type="button" class="btn btn-sm btn-outline-dark bg-light shadow-sm fw-bold" onclick="productApp.addVariantRow()">
                                    <i class="fa-solid fa-plus text-success me-1"></i> Add Row
                                </button>
                            </div>
                            <div class="alert alert-info py-2 fs-12 mb-3 d-none" id="rawMaterialAlert">
                                <i class="fa-solid fa-circle-info me-1"></i> <strong>Raw Materials</strong> do not require selling prices. Attributes can be left blank if the item has no variations.
                            </div>
                            <div class="table-responsive border rounded">
                                <table class="table table-sm table-hover align-middle mb-0" id="variantTable">
                                    <thead class="table-light text-secondary">
                                        <tr>
                                            <th class="th-size">Size</th>
                                            <th class="th-color">Color</th>
                                            <th>SKU (Unique) <span class="text-danger">*</span></th>
                                            <th style="width: 100px;">Standard Cost</th>
                                            <th style="width: 100px;" class="th-price">Selling Price</th>
                                            <th style="width: 40px;" class="text-center"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="variantList"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light py-2">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm px-4 fw-bold shadow-sm" onclick="productApp.save()">
                    <i class="fa-solid fa-check-double me-1"></i> Save Catalog Item
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="bulkModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content">
            <div class="modal-header bg-warning py-2">
                <h5 class="modal-title fs-6 fw-bold text-dark"><i class="fa-solid fa-table-cells me-2"></i>Excel-Style Bulk Editor</h5>
                <div class="d-flex align-items-center gap-3 ms-auto me-3">
                    <select class="form-select form-select-sm shadow-sm" id="bulkTypeFilter" style="width: 180px;">
                        <option value="">-- All Types --</option>
                        <option value="Finished Good">Finished Goods</option>
                        <option value="Raw Material">Raw Materials</option>
                        <option value="Service">Services</option>
                    </select>
                    <select class="form-select form-select-sm shadow-sm" id="bulkCategoryFilter" style="width: 180px;">
                        <option value="">-- All Categories --</option>
                    </select>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <table id="bulkGrid" class="table table-bordered table-sm table-hover align-middle w-100 fs-13 mb-0 bg-white">
                    <thead class="table-dark">
                        <tr>
                            <th>Type</th>
                            <th>Category</th>
                            <th>Product Name</th>
                            <th>SKU</th>
                            <th>Attr 1 (Size)</th>
                            <th>Attr 2 (Color)</th>
                            <th class="text-end" style="width: 120px;">Cost Price</th>
                            <th class="text-end" style="width: 120px;">Sell Price</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="modal-footer bg-white py-2 border-top">
                <span class="text-muted fs-13 me-auto"><i class="fa-solid fa-pen text-primary me-1"></i> Click any cell to edit. Changes are highlighted in yellow.</span>
                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">Discard Changes</button>
                <button type="button" class="btn btn-success btn-sm px-4 fw-bold shadow-sm" onclick="bulkApp.saveChanges()">
                    <i class="fa-solid fa-save me-1"></i> Save All Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/master/product-master.js" asp-append-version="true"></script>
}